<UserControl x:Class="AurumTweaks.Views.DriversView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Brush.Bg.Base}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24,32,32">
            <TextBlock Text="Pilotes" Style="{StaticResource Text.Display}"/>
            <TextBlock Text="Scan des pilotes installés (façon Snappy Driver) : périphériques en erreur + pilotes anciens à vérifier. Outils tiers recommandés."
                       Style="{StaticResource Text.Secondary}" Margin="0,4,0,20"/>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="GPU actuel" Style="{StaticResource Text.Label}"/>
                    <TextBlock Text="{Binding HardwareInfo.GpuPrimary}" Style="{StaticResource Text.H3}" Margin="0,4,0,2"/>
                    <TextBlock Style="{StaticResource Text.Muted}">
                        <Run Text="Driver "/>
                        <Run Text="{Binding HardwareInfo.GpuDriverVersion, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Driver scan (Snappy-style) -->
            <TextBlock Text="Scan des pilotes" Style="{StaticResource Text.H3}" Margin="0,20,0,12"/>
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Scan en cours…" Style="{StaticResource Text.Secondary}"
                               Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisibility}}"/>
                    <TextBlock Text="{Binding ScanReport.Summary}" Style="{StaticResource Text.Secondary}" TextWrapping="Wrap"/>

                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <Border Background="{StaticResource Brush.Danger}" CornerRadius="4" Padding="10,4" Margin="0,0,8,0">
                            <TextBlock Foreground="White" FontWeight="Bold" FontSize="12"
                                       Text="{Binding ScanReport.ProblemCount, StringFormat={}{0} en erreur}"/>
                        </Border>
                        <Border Background="{StaticResource Brush.Warning}" CornerRadius="4" Padding="10,4" Margin="0,0,8,0">
                            <TextBlock Foreground="#0A0A0A" FontWeight="Bold" FontSize="12"
                                       Text="{Binding ScanReport.OldCount, StringFormat={}{0} à vérifier}"/>
                        </Border>
                        <Border Background="{StaticResource Brush.Bg.Elevated}" CornerRadius="4" Padding="10,4">
                            <TextBlock Foreground="{StaticResource Brush.Text.Primary}" FontWeight="Bold" FontSize="12"
                                       Text="{Binding ScanReport.TotalCount, StringFormat={}{0} analysés}"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <Button Content="↻ Re-scanner" Command="{Binding ScanDriversCommand}" Style="{StaticResource Button.Secondary}" Margin="0,0,8,0"/>
                        <Button Content="Windows Update" Command="{Binding OpenWindowsUpdateCommand}" Style="{StaticResource Button.Secondary}" Margin="0,0,8,0"/>
                        <Button Content="Mises à jour optionnelles" Command="{Binding OpenOptionalUpdatesCommand}" Style="{StaticResource Button.Secondary}" Margin="0,0,8,0"/>
                        <Button Content="Gestionnaire de périphériques" Command="{Binding OpenDeviceManagerCommand}" Style="{StaticResource Button.Secondary}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <ItemsControl ItemsSource="{Binding Drivers}" Margin="0,12,0,0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Card.Compact}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Border CornerRadius="4" Padding="8,3" VerticalAlignment="Center" Margin="0,0,10,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{StaticResource Brush.Success}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsOld}" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource Brush.Warning}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsProblem}" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource Brush.Danger}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding StatusLabel}" FontSize="10" FontWeight="Bold" Foreground="#0A0A0A"/>
                                    </Border>
                                    <TextBlock Text="{Binding DeviceName}" Style="{StaticResource Text.Body}" VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,0,10,0"/>
                                    <Border Style="{StaticResource Badge.Subtle}" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DeviceClass}" FontSize="10" FontWeight="Bold" Foreground="{StaticResource Brush.Text.Muted}"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="{Binding ProblemText}" Margin="0,6,0,0" TextWrapping="Wrap"
                                           Foreground="{StaticResource Brush.Danger}"
                                           Visibility="{Binding ProblemText, Converter={StaticResource StringNotEmptyToVisibility}}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <TextBlock Text="{Binding VersionSummary}" Style="{StaticResource Text.Mono}" FontSize="11" Margin="0,0,16,0"/>
                                    <TextBlock Text="{Binding Manufacturer}" Style="{StaticResource Text.Muted}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="DDU" Style="{StaticResource Text.H3}"/>
                        <TextBlock Style="{StaticResource Text.Secondary}" Margin="0,8,0,12" TextWrapping="Wrap"
                                   Text="Display Driver Uninstaller — nettoie complètement pilote GPU. À utiliser en Safe Mode lors d'un switch NVIDIA↔AMD."/>
                        <Button Content="Télécharger DDU" Style="{StaticResource Button.Secondary}" Command="{Binding OpenDduCommand}" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource Card}" Margin="4,0,4,0">
                    <StackPanel>
                        <TextBlock Text="NVCleanstall" Style="{StaticResource Text.H3}"/>
                        <TextBlock Style="{StaticResource Text.Secondary}" Margin="0,8,0,12" TextWrapping="Wrap"
                                   Text="Installation NVIDIA minimale : sans GeForce Experience, sans télémétrie, sans HD Audio si tu veux."/>
                        <Button Content="Télécharger NVCleanstall" Style="{StaticResource Button.Secondary}" Command="{Binding OpenNvCleanstallCommand}" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource Card}" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="NVIDIA Profile Inspector" Style="{StaticResource Text.H3}"/>
                        <TextBlock Style="{StaticResource Text.Secondary}" Margin="0,8,0,12" TextWrapping="Wrap"
                                   Text="Settings cachés du driver : Low Latency Mode Ultra, Threaded Optimization, MSI mode, Negative LOD bias."/>
                        <Button Content="Télécharger NVPI" Style="{StaticResource Button.Secondary}" Command="{Binding OpenNvProfileInspectorCommand}" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>
            </Grid>

            <TextBlock Text="Recommandations adaptées à ton hardware" Style="{StaticResource Text.H3}" Margin="0,20,0,12"/>
            <ItemsControl ItemsSource="{Binding Recommendations}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Card.Compact}">
                            <TextBlock Text="{Binding}" Style="{StaticResource Text.Body}" TextWrapping="Wrap"/>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
