<UserControl x:Class="AurumTweaks.Views.ServiceControlView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Brush.Bg.Base}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24,32,32">
            <TextBlock Text="Services Windows" Style="{StaticResource Text.Display}"/>
            <TextBlock Style="{StaticResource Text.Secondary}" Margin="0,4,0,20" TextWrapping="Wrap"
                       Text="Windows lance en arrière-plan des services de télémétrie, d'accès distant et de fonctions rarement utilisées. Cette liste ne contient que des services connus et sûrs — jamais un vidage complet qui pourrait casser Windows. Chaque changement de type de démarrage est entièrement réversible. Pour la plupart, « Manuel (déclenché) » est préféré à « Désactivé » : le service ne coûte rien à l'arrêt mais démarre encore à la demande. C'est une question de confidentialité et de légèreté : aucun gain de FPS n'est promis ici."/>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Actualiser" Style="{StaticResource Button.Primary}" Command="{Binding RefreshCommand}"/>
                        <Button Content="Console Services (services.msc)" Style="{StaticResource Button.Secondary}" Margin="10,0,0,0"
                                Command="{Binding OpenServicesCommand}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding Status}" Style="{StaticResource Text.Muted}" Margin="0,12,0,0" TextWrapping="Wrap"/>
                    <TextBlock Style="{StaticResource Text.Muted}" Margin="0,4,0,0" TextWrapping="Wrap" FontSize="11"
                               Text="Le type de démarrage et l'état (en cours / arrêté) sont lus en direct depuis Windows. Un service absent de cette édition est indiqué « absent » et n'est jamais inventé. Les services utiles (Xbox, recherche, préchargement) sont signalés « à conserver ». Désactiver arrête aussi le service en cours ; « Manuel » laisse tourner ce qui est déjà démarré."/>

                    <ItemsControl ItemsSource="{Binding Services}" Margin="0,12,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource Card.Compact}" Margin="0,4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Left: identity + live state + advice -->
                                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Label}" Style="{StaticResource Text.Body}" TextWrapping="Wrap"/>
                                                <Border Style="{StaticResource Badge.Gold}" Margin="8,0,0,0" Padding="5,1"
                                                        VerticalAlignment="Center"
                                                        Visibility="{Binding ShowOptimizedBadge, Converter={StaticResource BoolToVisibility}}">
                                                    <TextBlock Text="✓ OPTIMISÉ" FontSize="8" FontWeight="Bold"
                                                               Foreground="{StaticResource Brush.Gold.Bright}"/>
                                                </Border>
                                                <Border Background="#22FFFFFF" CornerRadius="3" Margin="8,0,0,0" Padding="5,1"
                                                        VerticalAlignment="Center"
                                                        Visibility="{Binding ShowAbsentBadge, Converter={StaticResource BoolToVisibility}}">
                                                    <TextBlock Text="ABSENT" FontSize="8" FontWeight="Bold"
                                                               Style="{StaticResource Text.Muted}"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Style="{StaticResource Text.Muted}" Margin="0,2,0,0">
                                                <Run Text="{Binding CategoryDisplay, Mode=OneWay}"/>
                                                <Run Text=" · "/>
                                                <Run Text="{Binding ServiceName, Mode=OneWay}"/>
                                                <Run Text=" · "/>
                                                <Run Text="{Binding StateDisplay, Mode=OneWay}"/>
                                            </TextBlock>
                                            <TextBlock Style="{StaticResource Text.Muted}" FontSize="11" Margin="0,2,0,0">
                                                <Run Text="Démarrage : "/>
                                                <Run Text="{Binding StartupDisplay, Mode=OneWay}" FontWeight="SemiBold"/>
                                            </TextBlock>
                                            <TextBlock Text="{Binding Advice}" Style="{StaticResource Text.Muted}"
                                                       FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                        </StackPanel>

                                        <!-- Right: « à conserver » badge OR the startup-mode trio + recommendation hint -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" MinWidth="150">
                                            <Border Style="{StaticResource Badge.Extreme}" HorizontalAlignment="Right"
                                                    Visibility="{Binding ShowKeepBadge, Converter={StaticResource BoolToVisibility}}">
                                                <TextBlock Text="À CONSERVER" FontSize="9" FontWeight="Bold"
                                                           Foreground="{StaticResource Brush.Danger}"/>
                                            </Border>

                                            <TextBlock Text="{Binding RecommendChip}" Style="{StaticResource Text.Muted}"
                                                       FontSize="10" FontWeight="Bold" HorizontalAlignment="Right" Margin="0,0,0,4"
                                                       Foreground="{StaticResource Brush.Gold.Bright}"
                                                       Visibility="{Binding ShowActions, Converter={StaticResource BoolToVisibility}}"/>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                                        Visibility="{Binding ShowActions, Converter={StaticResource BoolToVisibility}}">
                                                <Button Content="Auto" Style="{StaticResource Button.Tertiary}"
                                                        IsEnabled="{Binding CanSetAuto}"
                                                        Command="{Binding DataContext.SetAutoCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"/>
                                                <Button Content="Manuel" Style="{StaticResource Button.Tertiary}" Margin="6,0,0,0"
                                                        IsEnabled="{Binding CanSetManual}"
                                                        Command="{Binding DataContext.SetManualCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"/>
                                                <Button Content="Désactivé" Style="{StaticResource Button.Tertiary}" Margin="6,0,0,0"
                                                        IsEnabled="{Binding CanSetDisabled}"
                                                        Command="{Binding DataContext.SetDisabledCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
