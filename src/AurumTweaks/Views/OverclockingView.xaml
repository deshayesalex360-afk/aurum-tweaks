<UserControl x:Class="AurumTweaks.Views.OverclockingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Brush.Bg.Base}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24,32,32">
            <TextBlock Text="Overclocking" Style="{StaticResource Text.Display}"/>
            <TextBlock Text="Pousse ton GPU à ses limites — en sécurité. Sliders + auto-OC + tests de stabilité."
                       Style="{StaticResource Text.Secondary}" Margin="0,4,0,20"/>

            <!-- Backend status -->
            <Border Style="{StaticResource Card.Subtle}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="GPU" Style="{StaticResource Text.Label}" Margin="0,0,12,0"/>
                        <Border Style="{StaticResource Badge.Subtle}">
                            <TextBlock Text="{Binding BackendStatus.Vendor, FallbackValue=—}" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource Brush.Text.Secondary}"/>
                        </Border>
                    </StackPanel>
                    <TextBlock Text="{Binding HardwareInfo.GpuPrimary, FallbackValue=Détection…}" Style="{StaticResource Text.H3}" Margin="0,6,0,4"/>
                    <TextBlock Text="{Binding BackendStatus.Message}" Style="{StaticResource Text.Muted}" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="PROFIL D'OVERCLOCK" Style="{StaticResource Text.Label}" Margin="0,0,0,16"/>

                    <!-- Premium lock banner: shown only when a configured build runs Free, so the user knows up-front
                         that "Appliquer profil" is gated rather than discovering it at apply-time. Empty as-shipped. -->
                    <Border Background="{StaticResource Brush.Gold.Subtle}" CornerRadius="6" Padding="12,8" Margin="0,0,0,16"
                            Visibility="{Binding GpuOcLockNote, Converter={StaticResource StringNotEmptyToVisibility}}">
                        <TextBlock Text="{Binding GpuOcLockNote}" Style="{StaticResource Text.Body}" TextWrapping="Wrap"/>
                    </Border>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="90"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Core clock offset" Style="{StaticResource Text.Body}" VerticalAlignment="Center"/>
                        <Slider Grid.Row="0" Grid.Column="1" Minimum="-200" Maximum="500" Value="{Binding GpuCoreOffsetMhz}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding GpuCoreOffsetMhz, StringFormat={}{0:+#;-#;0} MHz}" Style="{StaticResource Text.Gold}" VerticalAlignment="Center" HorizontalAlignment="Right"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Memory clock offset" Style="{StaticResource Text.Body}" VerticalAlignment="Center" Margin="0,14,0,0"/>
                        <Slider Grid.Row="1" Grid.Column="1" Minimum="-500" Maximum="3000" Value="{Binding GpuMemOffsetMhz}" VerticalAlignment="Center" Margin="0,14,12,0"/>
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding GpuMemOffsetMhz, StringFormat={}{0:+#;-#;0} MHz}" Style="{StaticResource Text.Gold}" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,14,0,0"/>

                        <!-- Label follows the backend: "(via Afterburner)" only while the native power-limit
                             path hasn't passed its on-card verification — never claims more nor less. -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding PowerLimitRowLabel}" Style="{StaticResource Text.Body}" VerticalAlignment="Center" Margin="0,14,0,0"/>
                        <!-- Bounds follow the verified backend: the NVIDIA card's real window or the AMD
                             driver's own window — the slider can no longer request an out-of-card value. -->
                        <Slider Grid.Row="2" Grid.Column="1" Minimum="{Binding PowerSliderMinPct}" Maximum="{Binding PowerSliderMaxPct}" Value="{Binding GpuPowerLimitPct}" VerticalAlignment="Center" Margin="0,14,12,0"/>
                        <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding GpuPowerLimitPct, StringFormat={}{0}%}" Style="{StaticResource Text.Gold}" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,14,0,0"/>

                        <!-- Temperature target: the whole row exists ONLY when the native thermal backend passed
                             its on-card verification — a visible-but-unapplied temp slider would be a dead
                             control, and a hidden-but-applied axis would be worse. Bounds are the card's own
                             verified window, so the slider can't even request an out-of-card value. -->
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Cible température" Style="{StaticResource Text.Body}" VerticalAlignment="Center" Margin="0,14,0,0"
                                   Visibility="{Binding TempLimitNative, Converter={StaticResource BoolToVisibility}}"/>
                        <Slider Grid.Row="3" Grid.Column="1" Minimum="{Binding TempSliderMinC}" Maximum="{Binding TempSliderMaxC}" Value="{Binding GpuTempLimitC}" VerticalAlignment="Center" Margin="0,14,12,0"
                                Visibility="{Binding TempLimitNative, Converter={StaticResource BoolToVisibility}}"/>
                        <TextBlock Grid.Row="3" Grid.Column="2" Text="{Binding GpuTempLimitC, StringFormat={}{0} °C}" Style="{StaticResource Text.Gold}" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,14,0,0"
                                   Visibility="{Binding TempLimitNative, Converter={StaticResource BoolToVisibility}}"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Cible voltage — undervolt (via Afterburner)" Style="{StaticResource Text.Body}" VerticalAlignment="Center" Margin="0,14,0,0"/>
                        <Slider Grid.Row="4" Grid.Column="1" Minimum="800" Maximum="1100" Value="{Binding GpuTargetVoltageMv}" VerticalAlignment="Center" Margin="0,14,12,0"/>
                        <TextBlock Grid.Row="4" Grid.Column="2" Text="{Binding GpuTargetVoltageMv, StringFormat={}{0} mV}" Style="{StaticResource Text.Gold}" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,14,0,0"/>

                        <!-- AMD GPU max frequency (ADLX Tuning2, RDNA+): the whole row exists ONLY when the
                             native GFX backend passed its on-card verification — same no-dead-control /
                             no-hidden-write contract as the temp row. Bounds are the driver's own window. -->
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Fréquence GPU max (AMD)" Style="{StaticResource Text.Body}" VerticalAlignment="Center" Margin="0,14,0,0"
                                   Visibility="{Binding GfxTuningNative, Converter={StaticResource BoolToVisibility}}"/>
                        <Slider Grid.Row="5" Grid.Column="1" Minimum="{Binding GfxSliderMinMhz}" Maximum="{Binding GfxSliderMaxMhz}" Value="{Binding GpuAmdMaxFreqMhz}" VerticalAlignment="Center" Margin="0,14,12,0"
                                Visibility="{Binding GfxTuningNative, Converter={StaticResource BoolToVisibility}}"/>
                        <TextBlock Grid.Row="5" Grid.Column="2" Text="{Binding GpuAmdMaxFreqMhz, StringFormat={}{0} MHz}" Style="{StaticResource Text.Gold}" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,14,0,0"
                                   Visibility="{Binding GfxTuningNative, Converter={StaticResource BoolToVisibility}}"/>

                        <!-- AMD memory max frequency (ADLX VRAM Tuning2): same verified-only contract. -->
                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Fréquence mémoire max (AMD)" Style="{StaticResource Text.Body}" VerticalAlignment="Center" Margin="0,14,0,0"
                                   Visibility="{Binding VramTuningNative, Converter={StaticResource BoolToVisibility}}"/>
                        <Slider Grid.Row="6" Grid.Column="1" Minimum="{Binding VramSliderMinMhz}" Maximum="{Binding VramSliderMaxMhz}" Value="{Binding GpuAmdMaxVramFreqMhz}" VerticalAlignment="Center" Margin="0,14,12,0"
                                Visibility="{Binding VramTuningNative, Converter={StaticResource BoolToVisibility}}"/>
                        <TextBlock Grid.Row="6" Grid.Column="2" Text="{Binding GpuAmdMaxVramFreqMhz, StringFormat={}{0} MHz}" Style="{StaticResource Text.Gold}" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,14,0,0"
                                   Visibility="{Binding VramTuningNative, Converter={StaticResource BoolToVisibility}}"/>
                    </Grid>

                    <!-- Honesty: names exactly which axes the native backend applies on this card (core/mem
                         always; power limit only when its on-card verification passed) and that voltage is
                         never applied — so no slider above can read as Aurum-applied when it isn't. -->
                    <TextBlock Text="{Binding GpuSlidersNote}" Style="{StaticResource Text.Muted}" TextWrapping="Wrap" Margin="0,16,0,0"/>

                    <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                        <Button Content="Appliquer profil" Style="{StaticResource Button.Primary}" Command="{Binding ApplyGpuOcCommand}" Margin="0,0,8,0"/>
                        <Button Content="Suggérer un palier prudent" Style="{StaticResource Button.Secondary}" Command="{Binding RunAutoOcCommand}" Margin="0,0,8,0"/>
                        <Button Content="Test de stabilité GPU" Style="{StaticResource Button.Tertiary}" Command="{Binding RunStabilityTestCommand}" Margin="0,0,8,0"/>
                        <Button Content="Reset" Style="{StaticResource Button.Ghost}" Command="{Binding ResetOcCommand}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding AutoOcStatus}" Style="{StaticResource Text.Muted}" Margin="0,14,0,0"/>

                    <!-- Auto-revert safety net (Phase 2b): shown only while the post-apply countdown runs after a
                         risky frequency change. States the automatic outcome up front; « Conserver » cancels it. -->
                    <Border Background="{StaticResource Brush.Gold.Subtle}" CornerRadius="6" Padding="12,8" Margin="0,12,0,0"
                            Visibility="{Binding AutoRevertActive, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding AutoRevertLabel}" Style="{StaticResource Text.Body}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                            <Button Content="Conserver" Style="{StaticResource Button.Primary}" Command="{Binding ConfirmKeepOcCommand}" Margin="12,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Live observed effect (Phase 2c): the real sensor readout, so an « Appliqué » can be
                         corroborated by the measured clock/temp, not just the setting that was written. -->
                    <TextBlock Text="{Binding LiveEffectLabel}" Style="{StaticResource Text.Mono}" Margin="0,10,0,0" Foreground="{StaticResource Brush.Gold.Bright}"/>

                    <TextBlock Text="{Binding StressTestProgress}" Style="{StaticResource Text.Mono}" Margin="0,4,0,0" Foreground="{StaticResource Brush.Gold.Bright}"/>
                </StackPanel>
            </Border>

            <!-- Fan control (Phase 3): the whole card exists ONLY when a native fan backend is available
                 (NVIDIA/NVAPI, verified on-card). No dead control when there's nothing to drive. -->
            <Border Style="{StaticResource Card}" Visibility="{Binding FanAvailable, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Text="Ventilateur GPU" Style="{StaticResource Text.H3}" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Vitesse manuelle" Style="{StaticResource Text.Body}" VerticalAlignment="Center"/>
                        <Slider Grid.Column="1" Minimum="20" Maximum="100" Value="{Binding GpuFanPercent}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBlock Grid.Column="2" Text="{Binding GpuFanPercent, StringFormat={}{0} %}" Style="{StaticResource Text.Gold}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                        <Button Content="Appliquer" Style="{StaticResource Button.Primary}" Command="{Binding SetFanManualCommand}" Margin="0,0,8,0"/>
                        <Button Content="Auto (courbe driver)" Style="{StaticResource Button.Ghost}" Command="{Binding SetFanAutoCommand}"/>
                        <TextBlock Text="{Binding FanRpm, StringFormat={}{0} tr/min}" Style="{StaticResource Text.Gold}" VerticalAlignment="Center" Margin="16,0,0,0"/>
                    </StackPanel>
                    <TextBlock Text="{Binding FanStatusMessage}" Style="{StaticResource Text.Muted}" TextWrapping="Wrap" Margin="0,12,0,0"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Curve Optimizer (Ryzen)" Style="{StaticResource Text.H3}" Margin="0,0,0,8"/>
                    <TextBlock Style="{StaticResource Text.Secondary}" TextWrapping="Wrap">
                        Le PBO Curve Optimizer applique un offset négatif voltage à la courbe V/F. AUCUN risque hardware — au pire instabilité OS.
                        Process : -15 all-core safe pour démarrer. Puis per-core via CoreCycler (Prime95 small FFT 6m → 60m par core).
                        Cores qui crash : remonte l'offset de +3. Itère jusqu'à 8h stable overnight.
                        Gains : -15-20°C Cinebench, +3-5% multi, +100-200 MHz boost effectif single. C'est le best free perf sur Ryzen.
                    </TextBlock>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Process undervolt curve (NVIDIA)" Style="{StaticResource Text.H3}" Margin="0,0,0,8"/>
                    <TextBlock Style="{StaticResource Text.Secondary}" TextWrapping="Wrap">
                        1. Ouvre MSI Afterburner. 2. Ctrl+F pour Curve Editor. 3. Identifie le point à ~900 mV (RTX 30/40) ou ~875 mV (RTX 50).
                        4. Augmente Core Clock pour que ce point atteigne la fréquence boost désirée. 5. Shift+clic sur tous les points à droite pour les flatten.
                        6. Apply (✓). 7. Test stabilité (Heaven, Superposition, jeu open-world 30 min+).
                    </TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
