<UserControl x:Class="AurumTweaks.Views.ProcessControlView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Brush.Bg.Base}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24,32,32">
            <TextBlock Text="Priorité &amp; affinité CPU" Style="{StaticResource Text.Display}"/>
            <TextBlock Style="{StaticResource Text.Secondary}" Margin="0,4,0,20" TextWrapping="Wrap"
                       Text="Donne à un jeu la priorité CPU sur les tâches de fond, et — sur un processeur hybride (cœurs P / cœurs E) — épingle-le sur les cœurs performance. Tout est lu en direct depuis Windows : chaque réglage est réappliqué puis relu, donc l'état affiché est le vrai. Aucun gain de FPS n'est promis — c'est de la régularité (moins de micro-saccades dues à l'ordonnanceur). La persistance est opt-in : Aurum écrit des règles locales et les applique via une tâche planifiée Windows visible, jamais via un driver."/>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Actualiser" Style="{StaticResource Button.Primary}" Command="{Binding RefreshCommand}"/>
                        <Button Content="Gestionnaire des tâches" Style="{StaticResource Button.Secondary}" Margin="10,0,0,0"
                                Command="{Binding OpenTaskManagerCommand}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding Headline}" Style="{StaticResource Text.Body}" Margin="0,14,0,0" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding CpuSummary}" Style="{StaticResource Text.Muted}" Margin="0,2,0,0" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding Status}" Style="{StaticResource Text.Muted}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                    <TextBlock Style="{StaticResource Text.Muted}" Margin="0,4,0,0" TextWrapping="Wrap" FontSize="11"
                               Text="« Temps réel » n'est volontairement pas proposé : cette priorité passe avant les threads système (clavier, souris, audio) et peut figer le PC. Un processus protégé (anticheat / système) que Windows refuse de modifier est affiché sans boutons — Aurum ne prétend pas pouvoir le changer."/>

                    <Border Margin="0,14,0,0" Padding="14" CornerRadius="6"
                            Background="{StaticResource Brush.Bg.Panel}"
                            BorderBrush="{StaticResource Brush.Border.Default}"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Règles persistantes (opt-in)" Style="{StaticResource Text.Body}"/>
                            <TextBlock Text="{Binding PersistenceStatus}" Style="{StaticResource Text.Muted}" Margin="0,3,0,0" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding PersistenceLimit}" Style="{StaticResource Text.Muted}" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"/>
                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <Button Content="Installer la tâche visible" Style="{StaticResource Button.Secondary}"
                                        IsEnabled="{Binding CanInstallPersistenceTask}"
                                        Command="{Binding InstallPersistenceTaskCommand}"/>
                                <Button Content="Retirer la tâche" Style="{StaticResource Button.Secondary}" Margin="10,0,0,0"
                                        IsEnabled="{Binding CanRemovePersistenceTask}"
                                        Command="{Binding RemovePersistenceTaskCommand}"/>
                            </StackPanel>

                            <ItemsControl ItemsSource="{Binding PersistentRules}" Margin="0,10,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding SummaryDisplay}" Style="{StaticResource Text.Muted}" FontSize="11" TextWrapping="Wrap"/>
                                            <Button Grid.Column="1" Content="Retirer" Style="{StaticResource Button.Tertiary}" Margin="10,0,0,0"
                                                    Command="{Binding DataContext.RemovePersistentRuleCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <ItemsControl ItemsSource="{Binding Processes}" Margin="0,12,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource Card.Compact}" Margin="0,4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Left: identity + live state + advice -->
                                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding DisplayName}" Style="{StaticResource Text.Body}"/>
                                                <Border Style="{StaticResource Badge.Gold}" Margin="8,0,0,0" Padding="5,1"
                                                        VerticalAlignment="Center"
                                                        Visibility="{Binding ShowGameBadge, Converter={StaticResource BoolToVisibility}}">
                                                    <TextBlock Text="JEU" FontSize="8" FontWeight="Bold"
                                                               Foreground="{StaticResource Brush.Gold.Bright}"/>
                                                </Border>
                                                <Border Style="{StaticResource Badge.Extreme}" Margin="6,0,0,0" Padding="5,1"
                                                        VerticalAlignment="Center"
                                                        Visibility="{Binding ShowAntiCheat, Converter={StaticResource BoolToVisibility}}">
                                                    <TextBlock Text="{Binding AntiCheatDisplay}" FontSize="8" FontWeight="Bold"
                                                               Foreground="{StaticResource Brush.Danger}"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding SubtitleDisplay}" Style="{StaticResource Text.Muted}" Margin="0,2,0,0"/>
                                            <TextBlock Text="{Binding StateDisplay}" Style="{StaticResource Text.Muted}" Margin="0,2,0,0"
                                                       FontSize="11"/>
                                            <TextBlock Text="{Binding RationaleDisplay}" Style="{StaticResource Text.Muted}"
                                                       FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                            <TextBlock Text="{Binding WarningDisplay}" Foreground="{StaticResource Brush.Danger}"
                                                       FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"
                                                       Visibility="{Binding ShowWarning, Converter={StaticResource BoolToVisibility}}"/>
                                            <TextBlock FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"
                                                       Style="{StaticResource Text.Muted}"
                                                       Text="Processus protégé — Windows refuse l'accès (anticheat / système / intégrité supérieure). Aurum ne peut pas le modifier."
                                                       Visibility="{Binding ShowInaccessible, Converter={StaticResource BoolToVisibility}}"/>
                                        </StackPanel>

                                        <!-- Right: actions (only when accessible) -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center"
                                                    Visibility="{Binding ShowActions, Converter={StaticResource BoolToVisibility}}">
                                            <TextBlock Text="Priorité" Style="{StaticResource Text.Muted}" FontSize="10"
                                                       HorizontalAlignment="Right"/>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,2,0,0">
                                                <Button Content="Normale" Style="{StaticResource Button.Secondary}" Margin="4,0,0,0"
                                                        Command="{Binding DataContext.SetPriorityNormalCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"/>
                                                <Button Content="Au-dessus" Style="{StaticResource Button.Secondary}" Margin="4,0,0,0"
                                                        Command="{Binding DataContext.SetPriorityAboveCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"/>
                                                <Button Content="Haute" Style="{StaticResource Button.Secondary}" Margin="4,0,0,0"
                                                        Command="{Binding DataContext.SetPriorityHighCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"/>
                                            </StackPanel>

                                            <TextBlock Text="Affinité" Style="{StaticResource Text.Muted}" FontSize="10"
                                                       HorizontalAlignment="Right" Margin="0,8,0,0"/>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,2,0,0">
                                                <Button Content="Tous les cœurs" Style="{StaticResource Button.Secondary}" Margin="4,0,0,0"
                                                        Command="{Binding DataContext.SetAffinityAllCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"/>
                                                <Button Content="Cœurs performance" Style="{StaticResource Button.Secondary}" Margin="4,0,0,0"
                                                        Visibility="{Binding ShowPerformanceCores, Converter={StaticResource BoolToVisibility}}"
                                                        Command="{Binding DataContext.SetAffinityPerformanceCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"/>
                                            </StackPanel>

                                            <Button Content="Optimiser (recommandé)" Style="{StaticResource Button.Primary}"
                                                    HorizontalAlignment="Right" Margin="0,8,0,0"
                                                    Visibility="{Binding ShowOptimize, Converter={StaticResource BoolToVisibility}}"
                                                    Command="{Binding DataContext.OptimizeCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"/>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                                                <Button Content="Persister" Style="{StaticResource Button.Tertiary}"
                                                        Command="{Binding DataContext.PersistCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"/>
                                                <Button Content="Persister + plan perf" Style="{StaticResource Button.Tertiary}" Margin="6,0,0,0"
                                                        Command="{Binding DataContext.PersistWithPowerPlanCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
