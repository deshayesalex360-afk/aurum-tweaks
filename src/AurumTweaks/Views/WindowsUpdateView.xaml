<UserControl x:Class="AurumTweaks.Views.WindowsUpdateView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Brush.Bg.Base}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24,32,32">
            <TextBlock Text="Windows Update" Style="{StaticResource Text.Display}"/>
            <TextBlock Style="{StaticResource Text.Secondary}" Margin="0,4,0,20" TextWrapping="Wrap"
                       Text="Reprends la main sur les comportements de Windows Update les plus gênants en jeu : l'envoi P2P de tes mises à jour vers d'autres PC sur Internet (qui mange ton upload), le redémarrage automatique forcé en pleine session, et le remplacement de tes pilotes par Windows Update. Chaque réglage est lu en direct, entièrement réversible, et la valeur est relue après écriture — une écriture refusée affiche la vérité, jamais un faux « fait ». Honnêteté : ces réglages bloquent des comportements, jamais les mises à jour de sécurité elles-mêmes."/>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <WrapPanel>
                        <Button Content="Tout optimiser" Style="{StaticResource Button.Primary}"
                                Command="{Binding OptimizeAllCommand}"/>
                        <Button Content="Tout rétablir" Style="{StaticResource Button.Secondary}" Margin="10,0,0,0"
                                Command="{Binding RestoreAllCommand}"/>
                        <Button Content="Actualiser" Style="{StaticResource Button.Secondary}" Margin="10,0,0,0"
                                Command="{Binding RefreshCommand}"/>
                        <Button Content="Windows Update" Style="{StaticResource Button.Secondary}" Margin="10,0,0,0"
                                Command="{Binding OpenWindowsUpdateCommand}"/>
                        <Button Content="Optimisation de la distribution" Style="{StaticResource Button.Secondary}" Margin="10,0,0,0"
                                Command="{Binding OpenDeliveryOptimizationCommand}"/>
                        <Button Content="Heures d'activité" Style="{StaticResource Button.Secondary}" Margin="10,0,0,0"
                                Command="{Binding OpenActiveHoursCommand}"/>
                    </WrapPanel>

                    <TextBlock Text="{Binding Status}" Style="{StaticResource Text.Muted}" Margin="0,12,0,0" TextWrapping="Wrap"/>
                    <TextBlock Style="{StaticResource Text.Muted}" Margin="0,4,0,0" TextWrapping="Wrap" FontSize="11"
                               Text="Un réglage « Non configuré » utilise le comportement par défaut de Windows ; il n'est jamais inventé. Ce sont des écritures de stratégie à l'échelle de la machine (HKLM, visibles dans gpedit.msc) : un « gpupdate » ou un redémarrage peut être nécessaire, et un PC géré par une entreprise peut refuser l'écriture — le cas échéant, le compteur ci-dessus l'indique. « Rétablir » réécrit la valeur par défaut documentée (il ne supprime pas la clé de stratégie)."/>

                    <ItemsControl ItemsSource="{Binding Tweaks}" Margin="0,12,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource Card.Compact}" Margin="0,4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Left: identity + live state + advice + optional caveat -->
                                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Label}" Style="{StaticResource Text.Body}" TextWrapping="Wrap"/>
                                                <Border Style="{StaticResource Badge.Gold}" Margin="8,0,0,0" Padding="5,1"
                                                        VerticalAlignment="Center"
                                                        Visibility="{Binding ShowOptimizedBadge, Converter={StaticResource BoolToVisibility}}">
                                                    <TextBlock Text="✓ APPLIQUÉ" FontSize="8" FontWeight="Bold"
                                                               Foreground="{StaticResource Brush.Gold.Bright}"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Style="{StaticResource Text.Muted}" Margin="0,2,0,0">
                                                <Run Text="{Binding CategoryLabel, Mode=OneWay}"/>
                                                <Run Text=" · "/>
                                                <Run Text="{Binding StateDisplay, Mode=OneWay}"/>
                                                <Run Text=" · "/>
                                                <Run Text="{Binding ValueName, Mode=OneWay}"/>
                                            </TextBlock>
                                            <TextBlock Text="{Binding Advice}" Style="{StaticResource Text.Muted}"
                                                       FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                            <TextBlock Text="{Binding Note}" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"
                                                       FontStyle="Italic" Foreground="{StaticResource Brush.Gold.Bright}"
                                                       Visibility="{Binding HasNote, Converter={StaticResource BoolToVisibility}}"/>
                                        </StackPanel>

                                        <!-- Right: the Optimiser/Rétablir pair, each gated so no button is ever a no-op -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" MinWidth="150">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                <Button Content="Optimiser" Style="{StaticResource Button.Tertiary}"
                                                        IsEnabled="{Binding CanOptimize}"
                                                        Command="{Binding DataContext.OptimizeCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"/>
                                                <Button Content="Rétablir" Style="{StaticResource Button.Tertiary}" Margin="6,0,0,0"
                                                        IsEnabled="{Binding CanRestore}"
                                                        Command="{Binding DataContext.RestoreCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
