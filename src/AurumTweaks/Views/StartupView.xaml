<UserControl x:Class="AurumTweaks.Views.StartupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Brush.Bg.Base}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24,32,32">
            <TextBlock Text="Démarrage" Style="{StaticResource Text.Display}"/>
            <TextBlock Style="{StaticResource Text.Secondary}" Margin="0,4,0,20" TextWrapping="Wrap"
                       Text="Les programmes que Windows lance automatiquement à l'ouverture de session. Moins de programmes au démarrage = démarrage plus rapide et moins de RAM occupée au boot. La désactivation est entièrement réversible : Aurum déplace l'entrée dans une sauvegarde (clé de registre / dossier dédié) au lieu de la supprimer."/>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Actualiser" Style="{StaticResource Button.Primary}" Command="{Binding ScanCommand}"/>
                        <Button Content="Réglages Windows" Style="{StaticResource Button.Secondary}" Margin="10,0,0,0"
                                Command="{Binding OpenWindowsStartupCommand}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding Status}" Style="{StaticResource Text.Muted}" Margin="0,12,0,0" TextWrapping="Wrap"/>
                    <TextBlock Style="{StaticResource Text.Muted}" Margin="0,4,0,0" TextWrapping="Wrap" FontSize="11"
                               Text="La catégorie et le conseil sont indicatifs (heuristique sur le nom du programme) — à toi de décider. Les pilotes et outils de sécurité sont signalés « à conserver »."/>

                    <ItemsControl ItemsSource="{Binding Entries}" Margin="0,12,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource Card.Compact}" Margin="0,4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}" Style="{StaticResource Text.Body}"/>
                                                <Border Style="{StaticResource Badge.Gold}" Margin="8,0,0,0" Padding="5,1"
                                                        Visibility="{Binding IsEnabled, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                                                    <TextBlock Text="DÉSACTIVÉ" FontSize="8" FontWeight="Bold"
                                                               Foreground="{StaticResource Brush.Gold.Bright}"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Style="{StaticResource Text.Muted}" Margin="0,2,0,0">
                                                <Run Text="{Binding CategoryDisplay, Mode=OneWay}"/>
                                                <Run Text=" ·"/>
                                                <Run Text="{Binding ScopeDisplay, Mode=OneWay}"/>
                                                <Run Text=" ·"/>
                                                <Run Text="{Binding SourceDisplay, Mode=OneWay}"/>
                                            </TextBlock>
                                            <TextBlock Text="{Binding ExecutablePath}" Style="{StaticResource Text.Muted}"
                                                       FontSize="11" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                            <TextBlock Text="{Binding Advice}" Style="{StaticResource Text.Muted}"
                                                       FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                        </StackPanel>

                                        <Border Grid.Column="1" Style="{StaticResource Badge.Extreme}" VerticalAlignment="Center"
                                                Margin="0,0,10,0"
                                                Visibility="{Binding SafeToDisable, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                                            <TextBlock Text="À CONSERVER" FontSize="9" FontWeight="Bold"
                                                       Foreground="{StaticResource Brush.Danger}"/>
                                        </Border>

                                        <Button Grid.Column="2" VerticalAlignment="Center"
                                                Content="{Binding ToggleLabel}" Style="{StaticResource Button.Secondary}"
                                                Command="{Binding DataContext.ToggleCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
