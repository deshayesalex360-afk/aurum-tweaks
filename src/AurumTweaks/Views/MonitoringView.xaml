<UserControl x:Class="AurumTweaks.Views.MonitoringView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:AurumTweaks.Controls"
             Background="{StaticResource Brush.Bg.Base}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24,32,32">
            <TextBlock Text="Monitoring" Style="{StaticResource Text.Display}"/>
            <TextBlock Text="Vue temps réel via LibreHardwareMonitor. 90 secondes d'historique sur chaque sparkline."
                       Style="{StaticResource Text.Secondary}" Margin="0,4,0,20"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- CPU usage -->
                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,5,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="60"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="CPU USAGE" Style="{StaticResource Text.Label}"/>
                        <TextBlock Grid.Row="1" Margin="0,6,0,8" Style="{StaticResource Text.H1}">
                            <Run Text="{Binding Snapshot.CpuUsagePercent, StringFormat={}{0:F0}, FallbackValue=—}"/>
                            <Run Text="%" FontSize="14" Foreground="{StaticResource Brush.Text.Muted}"/>
                        </TextBlock>
                        <controls:Sparkline Grid.Row="2"
                                            Samples="{Binding CpuHistory}"
                                            Stroke="{StaticResource Brush.Gold}"
                                            Fill="{StaticResource Brush.Gold.Whisper}"
                                            Minimum="0" Maximum="100"
                                            StrokeThickness="1.5"/>
                    </Grid>
                </Border>

                <!-- GPU usage -->
                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource Card}" Margin="5,0,0,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="60"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="GPU USAGE" Style="{StaticResource Text.Label}"/>
                        <TextBlock Grid.Row="1" Margin="0,6,0,8" Style="{StaticResource Text.H1}">
                            <Run Text="{Binding Snapshot.GpuUsagePercent, StringFormat={}{0:F0}, FallbackValue=—}"/>
                            <Run Text="%" FontSize="14" Foreground="{StaticResource Brush.Text.Muted}"/>
                        </TextBlock>
                        <controls:Sparkline Grid.Row="2"
                                            Samples="{Binding GpuHistory}"
                                            Stroke="{StaticResource Brush.Gold}"
                                            Fill="{StaticResource Brush.Gold.Whisper}"
                                            Minimum="0" Maximum="100"
                                            StrokeThickness="1.5"/>
                    </Grid>
                </Border>

                <!-- CPU Temp -->
                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,5,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="60"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="CPU TEMP" Style="{StaticResource Text.Label}"/>
                        <TextBlock Grid.Row="1" Margin="0,6,0,8" Style="{StaticResource Text.H1}">
                            <Run Text="{Binding Snapshot.CpuTempC, Converter={StaticResource SensorOrDash}, ConverterParameter=F0, FallbackValue=—}"/>
                            <Run Text="°C" FontSize="14" Foreground="{StaticResource Brush.Text.Muted}"/>
                        </TextBlock>
                        <controls:Sparkline Grid.Row="2"
                                            Samples="{Binding CpuTempHistory}"
                                            Stroke="{StaticResource Brush.Warning}"
                                            Fill="#1AEAB308"
                                            Minimum="20" Maximum="100"
                                            StrokeThickness="1.5"/>
                    </Grid>
                </Border>

                <!-- GPU Temp -->
                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource Card}" Margin="5,0,0,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="60"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="GPU TEMP" Style="{StaticResource Text.Label}"/>
                        <TextBlock Grid.Row="1" Margin="0,6,0,8" Style="{StaticResource Text.H1}">
                            <Run Text="{Binding Snapshot.GpuTempC, Converter={StaticResource SensorOrDash}, ConverterParameter=F0, FallbackValue=—}"/>
                            <Run Text="°C" FontSize="14" Foreground="{StaticResource Brush.Text.Muted}"/>
                        </TextBlock>
                        <controls:Sparkline Grid.Row="2"
                                            Samples="{Binding GpuTempHistory}"
                                            Stroke="{StaticResource Brush.Warning}"
                                            Fill="#1AEAB308"
                                            Minimum="20" Maximum="100"
                                            StrokeThickness="1.5"/>
                    </Grid>
                </Border>

                <!-- RAM -->
                <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource Card}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="3*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="RAM" Style="{StaticResource Text.Label}"/>
                            <TextBlock Style="{StaticResource Text.H1}" Margin="0,6,0,4">
                                <Run Text="{Binding Snapshot.RamUsedGb, StringFormat={}{0:F1}, FallbackValue=—}"/>
                                <Run Text="/" Foreground="{StaticResource Brush.Text.Muted}"/>
                                <Run Text="{Binding Snapshot.RamTotalGb, StringFormat={}{0:F1}, FallbackValue=—}"/>
                                <Run Text="GB" FontSize="12" Foreground="{StaticResource Brush.Text.Muted}"/>
                            </TextBlock>
                            <TextBlock Style="{StaticResource Text.Muted}">
                                <Run Text="{Binding Snapshot.RamUsagePercent, StringFormat={}{0:F0}, FallbackValue=—}"/>
                                <Run Text="%"/>
                            </TextBlock>
                        </StackPanel>
                        <controls:Sparkline Grid.Column="1"
                                            Height="60"
                                            Samples="{Binding RamHistory}"
                                            Stroke="{StaticResource Brush.Gold}"
                                            Fill="{StaticResource Brush.Gold.Whisper}"
                                            Minimum="0" Maximum="100"
                                            StrokeThickness="1.5"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- Shareable live snapshot (current · average · peak over the recent real samples) -->
            <WrapPanel Margin="0,16,0,0">
                <Button Content="Copier l'instantané" Style="{StaticResource Button.Secondary}"
                        Command="{Binding CopySnapshotCommand}"
                        ToolTip="Copie un instantané texte (charge, température et fréquence CPU/GPU, VRAM et RAM système) avec moyenne et pic sur les dernières mesures — lecture seule, jamais envoyé. Une température / fréquence à 0 = capteur non lu."/>
            </WrapPanel>
            <TextBlock Text="{Binding CopyStatus}" Style="{StaticResource Text.Muted}" Margin="0,8,0,0" TextWrapping="Wrap"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
