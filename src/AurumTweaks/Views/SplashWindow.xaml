<Window x:Class="AurumTweaks.Views.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:AurumTweaks.Controls"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Width="520" Height="320"
        ShowInTaskbar="False"
        Topmost="True">
    <Border BorderBrush="{StaticResource Brush.Border.Strong}" BorderThickness="1" CornerRadius="8">
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.6" BlurRadius="40" ShadowDepth="0"/>
        </Border.Effect>
        <Grid ClipToBounds="True">
            <Border CornerRadius="8" ClipToBounds="True">
                <Grid>
                    <!-- Signature marble background -->
                    <controls:MarbleSurface Seed="2026"
                                            VeinDensity="1.4"
                                            VeinIntensity="0.9"
                                            BaseDarkness="0.035"
                                            RenderWidth="520"
                                            RenderHeight="320"/>

                    <!-- Vignette overlay -->
                    <Border>
                        <Border.Background>
                            <RadialGradientBrush Center="0.5,0.5" GradientOrigin="0.5,0.5" RadiusX="0.8" RadiusY="0.8">
                                <GradientStop Color="#00000000" Offset="0"/>
                                <GradientStop Color="#AA000000" Offset="1"/>
                            </RadialGradientBrush>
                        </Border.Background>
                    </Border>

                    <!-- Center content -->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="AURUM" FontFamily="{StaticResource Font.Display}"
                                   FontSize="56" FontWeight="Bold"
                                   Foreground="{StaticResource Brush.Gold.Bright}"
                                   HorizontalAlignment="Center">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#FFD4AF37" Opacity="0.5" BlurRadius="20" ShadowDepth="0"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        <TextBlock Text="TWEAKS" FontFamily="{StaticResource Font.Display}"
                                   FontSize="56" FontWeight="Thin"
                                   Foreground="{StaticResource Brush.Text.Primary}"
                                   HorizontalAlignment="Center"
                                   Margin="0,-14,0,0"/>
                        <Rectangle Width="60" Height="2" Fill="{StaticResource Brush.Gold.Gradient}" Margin="0,16,0,12"/>
                        <TextBlock Text="PREMIUM PC OPTIMIZER"
                                   FontFamily="{StaticResource Font.Body}"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource Brush.Text.Secondary}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Loading indicator -->
                    <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,28">
                        <TextBlock x:Name="StatusText"
                                   Text="Initialisation…"
                                   FontFamily="{StaticResource Font.Body}"
                                   FontSize="11"
                                   Foreground="{StaticResource Brush.Text.Muted}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Version corner -->
                    <TextBlock Text="v0.1.0"
                               FontFamily="{StaticResource Font.Mono}"
                               FontSize="10"
                               Foreground="{StaticResource Brush.Text.Faint}"
                               HorizontalAlignment="Right" VerticalAlignment="Bottom"
                               Margin="0,0,16,12"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
