<UserControl x:Class="AurumTweaks.Views.TipsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:AurumTweaks.Controls"
             Background="{StaticResource Brush.Bg.Base}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24,32,32">

            <!-- Marble hero with verdict -->
            <Border CornerRadius="8" BorderBrush="{StaticResource Brush.Border.Default}"
                    BorderThickness="1" ClipToBounds="True" Margin="0,0,0,20">
                <Grid MinHeight="180">
                    <controls:MarbleSurface Seed="747"
                                            VeinDensity="1.3"
                                            VeinIntensity="0.9"
                                            BaseDarkness="0.03"
                                            RenderWidth="1200"
                                            RenderHeight="360"
                                            Opacity="0.85"/>
                    <Border>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#DD000000" Offset="0"/>
                                <GradientStop Color="#88000000" Offset="0.6"/>
                                <GradientStop Color="#22000000" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <StackPanel Margin="36,24,36,24" VerticalAlignment="Center">
                        <TextBlock Text="LA VÉRITÉ QUI DÉRANGE" FontFamily="{StaticResource Font.Display}"
                                   FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource Brush.Gold.Bright}" Margin="0,0,0,8"/>
                        <TextBlock Text="Conseils &amp; recommandations" Style="{StaticResource Text.Display}"/>
                        <TextBlock Text="{Binding Verdict}" Style="{StaticResource Text.Secondary}"
                                   Margin="0,10,0,0" MaxWidth="800" TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </Border>

            <TextBlock Text="OS RECOMMANDÉS (du plus safe au plus risqué)" Style="{StaticResource Text.Label}" Margin="0,0,0,10"/>
            <ItemsControl ItemsSource="{Binding OperatingSystems}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Name}" Style="{StaticResource Text.H2}" Margin="0,0,10,0"/>
                                    <Border Style="{StaticResource Badge.Gold}" Visibility="{Binding IsOfficial, Converter={StaticResource BoolToVisibility}}">
                                        <TextBlock Text="OFFICIEL" FontSize="9" FontWeight="Bold"
                                                   Foreground="{StaticResource Brush.Gold.Bright}"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="{Binding Tagline}" Style="{StaticResource Text.Gold}" Margin="0,4,0,8"/>
                                <TextBlock Text="{Binding Description}" Style="{StaticResource Text.Secondary}" Margin="0,0,0,12" TextWrapping="Wrap"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                        <TextBlock Text="POUR QUI" Style="{StaticResource Text.Label}"/>
                                        <TextBlock Text="{Binding TargetAudience}" Style="{StaticResource Text.Body}" Margin="0,2,0,12"/>
                                        <TextBlock Text="PERFORMANCE" Style="{StaticResource Text.Label}"/>
                                        <TextBlock Text="{Binding Performance}" Style="{StaticResource Text.Body}" Margin="0,2,0,12"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="SÉCURITÉ" Style="{StaticResource Text.Label}"/>
                                        <TextBlock Text="{Binding SecurityLevel}" Style="{StaticResource Text.Body}" Margin="0,2,0,12"/>
                                        <TextBlock Text="VERDICT AURUM" Style="{StaticResource Text.Label}"/>
                                        <TextBlock Text="{Binding RecommendationVerdict}" Style="{StaticResource Text.Body}"
                                                   Foreground="{StaticResource Brush.Gold.Bright}" Margin="0,2,0,12" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Text="MODIFICATIONS HARDWARE RECOMMANDÉES" Style="{StaticResource Text.Label}" Margin="0,18,0,10"/>
            <ItemsControl ItemsSource="{Binding HardwareMods}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Title}" Style="{StaticResource Text.H3}" Margin="0,0,10,0"/>
                                    <Border Style="{StaticResource Badge.Gold}">
                                        <TextBlock Text="{Binding Category}" FontSize="10" FontWeight="Bold"
                                                   Foreground="{StaticResource Brush.Gold.Bright}"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="{Binding Description}" Style="{StaticResource Text.Secondary}" Margin="0,8,0,12" TextWrapping="Wrap"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Gain : " Style="{StaticResource Text.Muted}"/>
                                    <TextBlock Text="{Binding ExpectedGain}" Style="{StaticResource Text.Gold}" Margin="0,0,16,0"/>
                                    <TextBlock Text="Prix : " Style="{StaticResource Text.Muted}"/>
                                    <TextBlock Text="{Binding PriceRange}" Style="{StaticResource Text.Mono}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
