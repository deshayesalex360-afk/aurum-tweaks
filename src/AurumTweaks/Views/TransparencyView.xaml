<UserControl x:Class="AurumTweaks.Views.TransparencyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Brush.Bg.Base}">
    <Grid Margin="32,24,32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Transparence &amp; confiance" Style="{StaticResource Text.Display}"/>
            <TextBlock Style="{StaticResource Text.Secondary}" Margin="0,4,0,0" TextWrapping="Wrap"
                       MaxWidth="860" HorizontalAlignment="Left"
                       Text="Pourquoi faire confiance à un optimiseur PC téléchargé sur Internet ? Voici, sans détour et vérifiable, ce qu'Aurum Tweaks fait de vos données, ce que vous pouvez annuler, et ce qu'il refuse de faire. Copiez ou exportez ce document pour le partager."/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,16,0,12">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Copier" Style="{StaticResource Button.Tertiary}"
                            Command="{Binding CopyReportCommand}" Margin="0,0,10,0"/>
                    <Button Content="Exporter (.txt)" Style="{StaticResource Button.Secondary}"
                            Command="{Binding ExportReportCommand}" Margin="0,0,10,0"/>
                    <Button Content="Ouvrir le dossier de données" Style="{StaticResource Button.Ghost}"
                            Command="{Binding OpenDataFolderCommand}" Margin="0,0,10,0"/>
                    <Button Content="Rafraîchir" Style="{StaticResource Button.Ghost}"
                            Command="{Binding RefreshCommand}"/>
                </StackPanel>
                <TextBlock Text="{Binding Status}" Style="{StaticResource Text.Body}"
                           Foreground="{StaticResource Brush.Gold.Pale}" Margin="0,10,0,0" TextWrapping="Wrap"
                           Visibility="{Binding Status, Converter={StaticResource StringNotEmptyToVisibility}}"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Padding="16">
                <TextBox Text="{Binding ReportText, Mode=OneWay}"
                         FontFamily="{StaticResource Font.Mono}" FontSize="{StaticResource FontSize.Small}"
                         IsReadOnly="True" IsReadOnlyCaretVisible="False" BorderThickness="0" Background="Transparent"
                         TextWrapping="NoWrap" Foreground="{StaticResource Brush.Text.Primary}"/>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
