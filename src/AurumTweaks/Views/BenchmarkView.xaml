<UserControl x:Class="AurumTweaks.Views.BenchmarkView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Brush.Bg.Base}">
    <UserControl.Resources>
        <!-- Scoped dark input styling (the theme doesn't style ComboBox/TextBox; match Bios/Ram convention) -->
        <Style x:Key="Bench.ComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource Brush.Bg.Elevated}"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Default}"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="Bench.TextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource Brush.Bg.Elevated}"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Default}"/>
            <Setter Property="CaretBrush" Value="{StaticResource Brush.Gold.Bright}"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="Bench.QuickBtn" TargetType="Button" BasedOn="{StaticResource Button.Tertiary}">
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- A single metric chip (label on top, value below) -->
        <Style x:Key="Bench.Chip" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Brush.Bg.Elevated}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="14,9"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="MinWidth" Value="104"/>
        </Style>
        <Style x:Key="Bench.Chip.Label" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource Font.Body}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Muted}"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>
        <Style x:Key="Bench.Chip.Value" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource Font.Mono}"/>
            <Setter Property="FontSize" Value="19"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}"/>
        </Style>

        <!-- A before→after delta, coloured by direction: green = real improvement, red = real regression
             (driven by the MetricDelta's own Improved/Regressed, so a worse result is never painted as a win). -->
        <Style x:Key="Bench.DeltaText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource Font.Mono}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Muted}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Improved}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource Brush.Success}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Regressed}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource Brush.Danger}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- « Régularité de diffusion » badge: colour driven by the pure FrameConsistencyVerdict level (vert = régulière,
             ambre = correcte, rouge = irrégulière), never invented. Tints are the theme's success/warning/danger hues. -->
        <Style x:Key="Bench.Verdict" TargetType="Border">
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="9,4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Background" Value="{StaticResource Brush.Bg.Elevated}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Default}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Level}" Value="Smooth">
                    <Setter Property="Background" Value="#1A22C55E"/>
                    <Setter Property="BorderBrush" Value="{StaticResource Brush.Success}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Level}" Value="Moderate">
                    <Setter Property="Background" Value="#1AEAB308"/>
                    <Setter Property="BorderBrush" Value="{StaticResource Brush.Warning}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Level}" Value="Choppy">
                    <Setter Property="Background" Value="#1AEF4444"/>
                    <Setter Property="BorderBrush" Value="{StaticResource Brush.Danger}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="Bench.VerdictText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Level}" Value="Smooth">
                    <Setter Property="Foreground" Value="{StaticResource Brush.Success}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Level}" Value="Moderate">
                    <Setter Property="Foreground" Value="{StaticResource Brush.Warning}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Level}" Value="Choppy">
                    <Setter Property="Foreground" Value="{StaticResource Brush.Danger}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24,32,32">

            <!-- Header -->
            <StackPanel Margin="0,0,0,4">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Benchmark frame-times" Style="{StaticResource Text.Display}"/>
                    <Border Style="{StaticResource Badge.Subtle}" Margin="14,14,0,0" VerticalAlignment="Center" Height="22">
                        <TextBlock Text="SANS INJECTION · ANTI-TRICHE OK" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource Brush.Text.Secondary}" VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>
                <TextBlock Style="{StaticResource Text.Secondary}" Margin="0,4,0,0"
                           Text="FPS moyen · 1% low · 0,1% low · stutter, mesurés sans injecter aucune DLL. Capture live via ETW DXGI (admin) ou import d'un CSV PresentMon/CapFrameX (toujours dispo)."/>
            </StackPanel>

            <!-- Status line -->
            <TextBlock Text="{Binding StatusText}" Style="{StaticResource Text.Muted}" Margin="0,8,0,16"
                       Visibility="{Binding StatusText, Converter={StaticResource StringNotEmptyToVisibility}}"/>

            <!-- ===== Backend status (honest) ===== -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="CAPTURE LIVE — ETW DXGI" Style="{StaticResource Text.Label}" VerticalAlignment="Center"/>
                        <Border CornerRadius="4" Padding="7,2" Margin="10,0,0,0" BorderThickness="1"
                                Background="#1A4ADE80" BorderBrush="{StaticResource Brush.Success}"
                                Visibility="{Binding BackendStatus.LiveCaptureAvailable, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="DISPONIBLE" FontSize="9" FontWeight="Bold" Foreground="{StaticResource Brush.Success}"/>
                        </Border>
                        <Border CornerRadius="4" Padding="7,2" Margin="10,0,0,0" BorderThickness="1"
                                Background="#1AF59E0B" BorderBrush="{StaticResource Brush.Warning}"
                                Visibility="{Binding BackendStatus.LiveCaptureAvailable, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                            <TextBlock Text="ADMIN REQUIS" FontSize="9" FontWeight="Bold" Foreground="{StaticResource Brush.Warning}"/>
                        </Border>
                    </StackPanel>
                    <TextBlock Text="{Binding BackendStatus.Message}" Style="{StaticResource Text.Secondary}" TextWrapping="Wrap" MaxWidth="900" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <!-- ===== Capture controls ===== -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="CAPTURER" Style="{StaticResource Text.Label}" Margin="0,0,0,16"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Target process picker -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Process cible (jeu en cours d'exécution)" Style="{StaticResource Text.Label}" Margin="0,0,0,6"/>
                            <ComboBox Style="{StaticResource Bench.ComboBox}" IsEditable="True"
                                      ItemsSource="{Binding CandidateProcesses}"
                                      Text="{Binding TargetProcess, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                            <Button Content="Rafraîchir la liste" Style="{StaticResource Button.Tertiary}"
                                    Command="{Binding RefreshProcessesCommand}" Padding="14,8"/>
                        </StackPanel>
                    </Grid>

                    <!-- Duration -->
                    <TextBlock Text="Durée de capture (secondes)" Style="{StaticResource Text.Label}" Margin="0,16,0,6"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBox Style="{StaticResource Bench.TextBox}" Width="100" HorizontalAlignment="Left"
                                 Text="{Binding CaptureDurationSec, UpdateSourceTrigger=PropertyChanged}"/>
                        <ItemsControl ItemsSource="{Binding QuickDurations}" Margin="12,0,0,0" VerticalAlignment="Center">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource Bench.QuickBtn}"
                                            Content="{Binding}" ContentStringFormat="{}{0} s"
                                            Command="{Binding DataContext.SetDurationCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Action buttons -->
                    <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                        <Button Content="Capturer en live" Style="{StaticResource Button.Primary}"
                                Command="{Binding CaptureLiveCommand}" Padding="18,9"/>
                        <Button Content="Arrêter" Style="{StaticResource Button.Secondary}" Margin="10,0,0,0" Padding="18,9"
                                Command="{Binding CancelCaptureCommand}"
                                Visibility="{Binding IsCapturing, Converter={StaticResource BoolToVisibility}}"/>
                        <Border Width="1" Background="{StaticResource Brush.Border.Subtle}" Margin="16,2,16,2"/>
                        <Button Content="Importer un CSV" Style="{StaticResource Button.Secondary}" Padding="18,9"
                                Command="{Binding ImportCsvCommand}"/>
                    </StackPanel>

                    <!-- Progress -->
                    <StackPanel Margin="0,16,0,0"
                                Visibility="{Binding IsCapturing, Converter={StaticResource BoolToVisibility}}">
                        <ProgressBar Height="6" Minimum="0" Maximum="100" Value="{Binding CaptureProgress}"
                                     Background="{StaticResource Brush.Bg.Elevated}" Foreground="{StaticResource Brush.Gold}"
                                     BorderThickness="0"/>
                        <TextBlock Style="{StaticResource Text.Muted}" Margin="0,6,0,0">
                            <Run Text="Capture en cours… "/><Run Text="{Binding CaptureProgress, Mode=OneWay}"/><Run Text=" %"/>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ===== Historique des runs (persistant — survit à la fermeture de l'app) ===== -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="HISTORIQUE DES RUNS" Style="{StaticResource Text.Label}" VerticalAlignment="Center"/>
                        <Button Content="Rafraîchir" Style="{StaticResource Button.Tertiary}" Padding="12,5" FontSize="12"
                                HorizontalAlignment="Right" Command="{Binding RefreshHistoryCommand}"/>
                    </Grid>
                    <TextBlock Style="{StaticResource Text.Secondary}" TextWrapping="Wrap" MaxWidth="900" HorizontalAlignment="Left"
                               Text="Chaque run capturé ou importé est archivé ici automatiquement (seuls les plus récents sont conservés). Recharge un run pour le revoir, ou définis-en un comme « Avant » pour comparer un run d'aujourd'hui à un run d'il y a plusieurs jours."/>

                    <!-- Empty state (no run archived yet) -->
                    <TextBlock Margin="0,12,0,0" Style="{StaticResource Text.Muted}" FontStyle="Italic"
                               Text="Aucun run archivé pour l'instant — capture en live ou importe un CSV, il apparaîtra ici."
                               Visibility="{Binding HasHistory, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"/>

                    <!-- Archived runs, newest first -->
                    <ItemsControl ItemsSource="{Binding History}" Margin="0,12,0,0"
                                  Visibility="{Binding HasHistory, Converter={StaticResource BoolToVisibility}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource Brush.Bg.Elevated}" BorderBrush="{StaticResource Brush.Border.Subtle}"
                                        BorderThickness="1" CornerRadius="6" Padding="14,10" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding ProcessLabel}" FontFamily="{StaticResource Font.Body}"
                                                           FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource Brush.Text.Primary}"/>
                                                <TextBlock Text="{Binding CapturedAtLabel}" Style="{StaticResource Text.Muted}" FontSize="11"
                                                           Margin="10,0,0,0" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding SummaryLabel}" FontFamily="{StaticResource Font.Mono}" FontSize="12"
                                                       Foreground="{StaticResource Brush.Text.Secondary}" Margin="0,3,0,0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Content="Charger" Style="{StaticResource Button.Tertiary}" Padding="12,6" FontSize="12"
                                                    Command="{Binding DataContext.LoadFromHistoryCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="Définir comme « Avant »" Style="{StaticResource Button.Tertiary}" Padding="12,6" FontSize="12" Margin="8,0,0,0"
                                                    ToolTip="Compare un run d'aujourd'hui à celui-ci (A/B inter-sessions)."
                                                    Command="{Binding DataContext.PinFromHistoryAsBaselineCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="Supprimer" Style="{StaticResource Button.Tertiary}" Padding="12,6" FontSize="12" Margin="8,0,0,0"
                                                    Command="{Binding DataContext.DeleteFromHistoryCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- ===== Results ===== -->
            <Border Style="{StaticResource Card.Gold}"
                    Visibility="{Binding HasResult, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Text="{Binding Result.Source}" Style="{StaticResource Text.Label}" Margin="0,0,0,12"/>

                    <!-- Headline numbers -->
                    <StackPanel Orientation="Horizontal">
                        <!-- Avg FPS -->
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Result.Stats.AvgFps, StringFormat={}{0:0.0}}"
                                           FontFamily="{StaticResource Font.Display}" FontSize="52" FontWeight="Bold"
                                           Foreground="{StaticResource Brush.Gold.Bright}"/>
                                <TextBlock Text="FPS" Style="{StaticResource Text.Body}" VerticalAlignment="Bottom" Margin="6,0,0,12"/>
                            </StackPanel>
                            <TextBlock Text="moyen" Style="{StaticResource Text.Muted}" Margin="2,-6,0,0"/>
                        </StackPanel>

                        <Border Width="1" Background="{StaticResource Brush.Border.Subtle}" Margin="28,6,28,6"/>

                        <!-- 1% low -->
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="1% LOW" Style="{StaticResource Bench.Chip.Label}"/>
                            <TextBlock Text="{Binding Result.Stats.P1LowFps, StringFormat={}{0:0.0}}"
                                       FontFamily="{StaticResource Font.Mono}" FontSize="30" FontWeight="SemiBold"
                                       Foreground="{StaticResource Brush.Text.Primary}"/>
                        </StackPanel>

                        <StackPanel VerticalAlignment="Center" Margin="32,0,0,0">
                            <TextBlock Text="0,1% LOW" Style="{StaticResource Bench.Chip.Label}"/>
                            <TextBlock Text="{Binding Result.Stats.P01LowFps, StringFormat={}{0:0.0}}"
                                       FontFamily="{StaticResource Font.Mono}" FontSize="30" FontWeight="SemiBold"
                                       Foreground="{StaticResource Brush.Text.Primary}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Honest hedge: below the shared frame floor the « 1% low » / « 0,1% low » rest on a handful of
                         frames. Same condition + threshold as the paste and the A/B comparer (FrameSampleAdequacy, via
                         the VM), so the live card can't read as more confident than the report. Hidden once it clears. -->
                    <TextBlock Text="{Binding TailLowHint}" Style="{StaticResource Text.Muted}" TextWrapping="Wrap"
                               MaxWidth="860" HorizontalAlignment="Left" Margin="0,12,0,0"
                               Visibility="{Binding TailLowsThin, Converter={StaticResource BoolToVisibility}}"/>

                    <!-- Régularité de diffusion : verdict honnête (régularité, PAS le niveau de FPS qui dépend du jeu/écran) -->
                    <StackPanel DataContext="{Binding ConsistencyAssessment}" Margin="0,18,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="RÉGULARITÉ" Style="{StaticResource Bench.Chip.Label}" VerticalAlignment="Center" Margin="0,1,10,0"/>
                            <Border Style="{StaticResource Bench.Verdict}">
                                <TextBlock Text="{Binding Label}" Style="{StaticResource Bench.VerdictText}"/>
                            </Border>
                        </StackPanel>
                        <TextBlock Text="{Binding Message}" Style="{StaticResource Text.Muted}" TextWrapping="Wrap"
                                   MaxWidth="860" HorizontalAlignment="Left" Margin="0,8,0,0"/>
                    </StackPanel>

                    <!-- Frame-time plot: the REAL captured frames as a spike-preserving envelope (each pixel-column keeps
                         its min AND max, so a 1-frame hitch is never averaged into the baseline). 0 ms at the bottom,
                         spikes up; the dashed line is the average. A fixed 1000×200 logical space scaled to fill. -->
                    <Border Visibility="{Binding HasFrameGraph, Converter={StaticResource BoolToVisibility}}"
                            Background="{StaticResource Brush.Bg.Base}" BorderBrush="{StaticResource Brush.Border.Subtle}"
                            BorderThickness="1" CornerRadius="6" Padding="14,12" Margin="0,18,0,0">
                        <StackPanel DataContext="{Binding FrameGraph}">
                            <Grid>
                                <TextBlock Text="FRAME-TIME" Style="{StaticResource Bench.Chip.Label}" HorizontalAlignment="Left"/>
                                <TextBlock Text="{Binding MaxLabel}" Style="{StaticResource Text.Muted}" FontSize="10"
                                           HorizontalAlignment="Right"/>
                            </Grid>
                            <Border Height="150" Margin="0,8,0,0" ClipToBounds="True">
                                <Viewbox Stretch="Fill">
                                    <Grid Width="{Binding ViewWidth}" Height="{Binding ViewHeight}">
                                        <Line X1="0" X2="{Binding ViewWidth}" Y1="{Binding AverageY}" Y2="{Binding AverageY}"
                                              Stroke="{StaticResource Brush.Text.Secondary}" StrokeThickness="1"
                                              StrokeDashArray="5 4" Opacity="0.8"/>
                                        <Polyline Points="{Binding Envelope}" Stroke="{StaticResource Brush.Gold.Bright}"
                                                  StrokeThickness="1.2" StrokeLineJoin="Round"/>
                                    </Grid>
                                </Viewbox>
                            </Border>
                            <Grid Margin="0,8,0,0">
                                <TextBlock Text="{Binding AverageLabel}" Style="{StaticResource Text.Muted}" FontSize="10"
                                           HorizontalAlignment="Left"/>
                                <TextBlock Text="{Binding Caption}" Style="{StaticResource Text.Muted}" FontSize="10"
                                           HorizontalAlignment="Right" TextAlignment="Right" TextWrapping="Wrap" MaxWidth="560"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Height="1" Background="{StaticResource Brush.Border.Subtle}" Margin="0,18"/>

                    <!-- Detail chips -->
                    <WrapPanel>
                        <Border Style="{StaticResource Bench.Chip}"><StackPanel>
                            <TextBlock Text="FPS min" Style="{StaticResource Bench.Chip.Label}"/>
                            <TextBlock Text="{Binding Result.Stats.MinFps, StringFormat={}{0:0.0}}" Style="{StaticResource Bench.Chip.Value}"/></StackPanel></Border>
                        <Border Style="{StaticResource Bench.Chip}"><StackPanel>
                            <TextBlock Text="FPS max" Style="{StaticResource Bench.Chip.Label}"/>
                            <TextBlock Text="{Binding Result.Stats.MaxFps, StringFormat={}{0:0.0}}" Style="{StaticResource Bench.Chip.Value}"/></StackPanel></Border>
                        <Border Style="{StaticResource Bench.Chip}"><StackPanel>
                            <TextBlock Text="Frame-time moy." Style="{StaticResource Bench.Chip.Label}"/>
                            <TextBlock Text="{Binding Result.Stats.AvgFrameTimeMs, StringFormat={}{0:0.00} ms}" Style="{StaticResource Bench.Chip.Value}"/></StackPanel></Border>
                        <Border Style="{StaticResource Bench.Chip}"><StackPanel>
                            <TextBlock Text="Médiane" Style="{StaticResource Bench.Chip.Label}"/>
                            <TextBlock Text="{Binding Result.Stats.MedianFrameTimeMs, StringFormat={}{0:0.00} ms}" Style="{StaticResource Bench.Chip.Value}"/></StackPanel></Border>
                        <Border Style="{StaticResource Bench.Chip}"><StackPanel>
                            <TextBlock Text="P99 frame-time" Style="{StaticResource Bench.Chip.Label}"/>
                            <TextBlock Text="{Binding Result.Stats.P99FrameTimeMs, StringFormat={}{0:0.00} ms}" Style="{StaticResource Bench.Chip.Value}"/></StackPanel></Border>
                        <Border Style="{StaticResource Bench.Chip}"><StackPanel>
                            <TextBlock Text="P99,9 frame-time" Style="{StaticResource Bench.Chip.Label}"/>
                            <TextBlock Text="{Binding Result.Stats.P999FrameTimeMs, StringFormat={}{0:0.00} ms}" Style="{StaticResource Bench.Chip.Value}"/></StackPanel></Border>
                        <Border Style="{StaticResource Bench.Chip}"><StackPanel>
                            <TextBlock Text="Stutter" Style="{StaticResource Bench.Chip.Label}"/>
                            <TextBlock Text="{Binding Result.Stats.StutterPct, StringFormat={}{0:0.0} %}" Style="{StaticResource Bench.Chip.Value}"/></StackPanel></Border>
                        <Border Style="{StaticResource Bench.Chip}"><StackPanel>
                            <TextBlock Text="Écart-type" Style="{StaticResource Bench.Chip.Label}"/>
                            <TextBlock Text="{Binding Result.Stats.StdDevMs, StringFormat={}{0:0.00} ms}" Style="{StaticResource Bench.Chip.Value}"/></StackPanel></Border>
                        <Border Style="{StaticResource Bench.Chip}"><StackPanel>
                            <TextBlock Text="Var. img-à-img" Style="{StaticResource Bench.Chip.Label}"/>
                            <TextBlock Text="{Binding Result.Stats.ConsecutiveDeltaMs, StringFormat={}{0:0.00} ms}" Style="{StaticResource Bench.Chip.Value}"/></StackPanel></Border>
                        <Border Style="{StaticResource Bench.Chip}"><StackPanel>
                            <TextBlock Text="Frames" Style="{StaticResource Bench.Chip.Label}"/>
                            <TextBlock Text="{Binding Result.Stats.FrameCount}" Style="{StaticResource Bench.Chip.Value}"/></StackPanel></Border>
                        <Border Style="{StaticResource Bench.Chip}"><StackPanel>
                            <TextBlock Text="Durée" Style="{StaticResource Bench.Chip.Label}"/>
                            <TextBlock Text="{Binding Result.Stats.DurationSec, StringFormat={}{0:0.0} s}" Style="{StaticResource Bench.Chip.Value}"/></StackPanel></Border>
                    </WrapPanel>

                    <!-- A/B: pin this run as the "before" reference. WrapPanel so the action buttons wrap instead of
                         clipping on a narrow window once the baseline controls + the two export buttons are all shown. -->
                    <Border Height="1" Background="{StaticResource Brush.Border.Subtle}" Margin="0,18"/>
                    <WrapPanel Orientation="Horizontal">
                        <Button Content="Définir comme référence « Avant »" Style="{StaticResource Button.Secondary}"
                                Command="{Binding SetAsBaselineCommand}" Padding="14,8" Margin="0,0,0,8"/>
                        <Border CornerRadius="4" Padding="8,4" Margin="12,0,0,0" VerticalAlignment="Center"
                                Background="#1A4ADE80" BorderBrush="{StaticResource Brush.Success}" BorderThickness="1"
                                Visibility="{Binding HasBaseline, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="RÉFÉRENCE DÉFINIE" FontSize="9" FontWeight="Bold" Foreground="{StaticResource Brush.Success}"/>
                        </Border>
                        <Button Content="Effacer la référence" Style="{StaticResource Button.Tertiary}" Margin="12,0,0,8" Padding="12,8"
                                Command="{Binding ClearBaselineCommand}"
                                Visibility="{Binding HasBaseline, Converter={StaticResource BoolToVisibility}}"/>
                        <Border Width="1" Height="30" VerticalAlignment="Center" Background="{StaticResource Brush.Border.Subtle}" Margin="16,2,16,2"/>
                        <Button Content="Copier le rapport" Style="{StaticResource Button.Secondary}" Padding="14,8" Margin="0,0,0,8"
                                Command="{Binding CopyReportCommand}"/>
                        <Button Content="Exporter le rapport…" Style="{StaticResource Button.Tertiary}" Margin="10,0,0,8" Padding="12,8"
                                Command="{Binding ExportReportCommand}"/>
                        <Button Content="Exporter frames (CSV)…" Style="{StaticResource Button.Tertiary}" Margin="10,0,0,8" Padding="12,8"
                                ToolTip="Enregistre les frame-times bruts — réimportable ici ou dans CapFrameX (round-trip exact)."
                                Command="{Binding ExportFramesCsvCommand}"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- ===== Before / After comparison (the proof a tweak actually moved the numbers) ===== -->
            <Border Style="{StaticResource Card.Gold}"
                    Visibility="{Binding HasComparison, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Text="AVANT → APRÈS" Style="{StaticResource Text.Label}" Margin="0,0,0,12"/>

                    <!-- Headline: average-FPS movement -->
                    <StackPanel DataContext="{Binding Comparison.Headline}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Before, StringFormat={}{0:0.0}}"
                                       FontFamily="{StaticResource Font.Mono}" FontSize="26"
                                       Foreground="{StaticResource Brush.Text.Secondary}" VerticalAlignment="Bottom"/>
                            <TextBlock Text="→" FontSize="22" Margin="12,0,12,2" VerticalAlignment="Bottom"
                                       Foreground="{StaticResource Brush.Text.Muted}"/>
                            <TextBlock Text="{Binding After, StringFormat={}{0:0.0}}"
                                       FontFamily="{StaticResource Font.Display}" FontSize="42" FontWeight="Bold"
                                       Foreground="{StaticResource Brush.Gold.Bright}"/>
                            <TextBlock Text="FPS moy." Style="{StaticResource Text.Muted}" VerticalAlignment="Bottom" Margin="8,0,0,8"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Style="{StaticResource Bench.DeltaText}" FontSize="20"
                                       Text="{Binding Delta, StringFormat={}{0:+0.0;-0.0;0} FPS}"/>
                            <TextBlock Style="{StaticResource Bench.DeltaText}" FontSize="20" Margin="10,0,0,0"
                                       Text="{Binding PercentChange, StringFormat=({0:+0.0;-0.0;0} %)}"/>
                        </StackPanel>
                    </StackPanel>

                    <Border Height="1" Background="{StaticResource Brush.Border.Subtle}" Margin="0,16"/>

                    <!-- Secondary metric deltas (1% low / 0,1% low / stutter / écart-type) -->
                    <ItemsControl ItemsSource="{Binding Comparison.Metrics}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource Bench.Chip}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Label}" Style="{StaticResource Bench.Chip.Label}"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Before, StringFormat={}{0:0.0}}"
                                                       FontFamily="{StaticResource Font.Mono}" FontSize="12"
                                                       Foreground="{StaticResource Brush.Text.Muted}"/>
                                            <TextBlock Text="→" Margin="5,0,5,0" FontSize="12"
                                                       Foreground="{StaticResource Brush.Text.Muted}"/>
                                            <TextBlock Text="{Binding After, StringFormat={}{0:0.0}}"
                                                       FontFamily="{StaticResource Font.Mono}" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{StaticResource Brush.Text.Primary}"/>
                                        </StackPanel>
                                        <TextBlock Style="{StaticResource Bench.DeltaText}" FontSize="13" Margin="0,3,0,0"
                                                   Text="{Binding PercentChange, StringFormat={}{0:+0.0;-0.0;0} %}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- A/B frame-time overlay: both runs on ONE shared axis (BuildOverlay), so a real win reads as a
                         lower, flatter « Après » line — not just a percentage. Avant under (grey), Après on top (gold). -->
                    <Border Visibility="{Binding HasComparisonGraph, Converter={StaticResource BoolToVisibility}}"
                            Background="{StaticResource Brush.Bg.Base}" BorderBrush="{StaticResource Brush.Border.Subtle}"
                            BorderThickness="1" CornerRadius="6" Padding="14,12" Margin="0,16,0,0">
                        <StackPanel DataContext="{Binding ComparisonGraph}">
                            <Grid>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                    <Rectangle Width="14" Height="3" Fill="{StaticResource Brush.Text.Muted}" VerticalAlignment="Center"/>
                                    <TextBlock Text="Avant" Style="{StaticResource Text.Muted}" FontSize="10" Margin="5,0,0,0"/>
                                    <Rectangle Width="14" Height="3" Fill="{StaticResource Brush.Gold.Bright}" VerticalAlignment="Center" Margin="14,0,0,0"/>
                                    <TextBlock Text="Après" Style="{StaticResource Text.Muted}" FontSize="10" Margin="5,0,0,0"/>
                                </StackPanel>
                                <TextBlock Text="{Binding MaxLabel}" Style="{StaticResource Text.Muted}" FontSize="10" HorizontalAlignment="Right"/>
                            </Grid>
                            <Border Height="150" Margin="0,8,0,0" ClipToBounds="True">
                                <Viewbox Stretch="Fill">
                                    <Grid Width="{Binding ViewWidth}" Height="{Binding ViewHeight}">
                                        <Polyline Points="{Binding Before}" Stroke="{StaticResource Brush.Text.Muted}"
                                                  StrokeThickness="1" StrokeLineJoin="Round" Opacity="0.85"/>
                                        <Polyline Points="{Binding After}" Stroke="{StaticResource Brush.Gold.Bright}"
                                                  StrokeThickness="1.2" StrokeLineJoin="Round"/>
                                    </Grid>
                                </Viewbox>
                            </Border>
                            <TextBlock Text="{Binding Caption}" Style="{StaticResource Text.Muted}" FontSize="10"
                                       Margin="0,8,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Honest comparability caveats (only when the runs aren't a clean A/B) -->
                    <ItemsControl ItemsSource="{Binding Comparison.Caveats}" Margin="0,8,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,3">
                                    <TextBlock Text="⚠  " Foreground="{StaticResource Brush.Warning}" VerticalAlignment="Top"/>
                                    <TextBlock Text="{Binding}" Style="{StaticResource Text.Muted}" TextWrapping="Wrap" MaxWidth="820"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- ===== Notes / honesty ===== -->
            <Border Style="{StaticResource Card}"
                    Visibility="{Binding HasNotes, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Text="NOTES" Style="{StaticResource Text.Label}" Margin="0,0,0,8"/>
                    <ItemsControl ItemsSource="{Binding Result.Notes}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,3">
                                    <TextBlock Text="•  " Foreground="{StaticResource Brush.Gold}" VerticalAlignment="Top"/>
                                    <TextBlock Text="{Binding}" Style="{StaticResource Text.Secondary}" TextWrapping="Wrap" MaxWidth="860"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
