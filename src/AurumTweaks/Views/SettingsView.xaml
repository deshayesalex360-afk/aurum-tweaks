<UserControl x:Class="AurumTweaks.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Brush.Bg.Base}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24,32,32" MaxWidth="760" HorizontalAlignment="Left">
            <TextBlock Text="Paramètres" Style="{StaticResource Text.Display}"/>
            <TextBlock Text="Configurez Aurum Tweaks. Vos préférences sont sauvegardées dans %LOCALAPPDATA%\AurumTweaks\settings.json."
                       Style="{StaticResource Text.Secondary}" Margin="0,4,0,20"/>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="LANGUE" Style="{StaticResource Text.Label}"/>
                    <ComboBox Width="200" HorizontalAlignment="Left"
                              ItemsSource="{Binding AvailableLanguages}"
                              SelectedItem="{Binding SelectedLanguage}"
                              Background="{StaticResource Brush.Bg.Elevated}"
                              Foreground="{StaticResource Brush.Text.Primary}" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="SÉCURITÉ" Style="{StaticResource Text.Label}" Margin="0,0,0,12"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <CheckBox Style="{StaticResource Toggle.Aurum}" IsChecked="{Binding CreateRestorePointBeforeTweaks}" VerticalAlignment="Center"/>
                        <TextBlock Text="Créer un point de restauration avant chaque application de tweak"
                                   Style="{StaticResource Text.Body}" Margin="14,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <CheckBox Style="{StaticResource Toggle.Aurum}" IsChecked="{Binding StrictCompetitiveAntiCheat}" VerticalAlignment="Center"/>
                        <TextBlock Text="Mode compétitif strict (filtre les tweaks risqués pour Vanguard/EAC/BattlEye)"
                                   Style="{StaticResource Text.Body}" Margin="14,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="CONFIDENTIALITÉ" Style="{StaticResource Text.Label}" Margin="0,0,0,8"/>
                    <TextBlock Style="{StaticResource Text.Body}" TextWrapping="Wrap"
                               Text="Aurum Tweaks n'envoie aucune télémétrie. Aucune donnée d'usage, aucun identifiant, rien n'est transmis sur le réseau."/>
                    <TextBlock Style="{StaticResource Text.Muted}" Margin="0,6,0,0" TextWrapping="Wrap"
                               Text="Vos préférences et l'historique des tweaks restent en local, dans %LOCALAPPDATA%\AurumTweaks. Les seuls accès réseau sont ceux que vous déclenchez explicitement (mesure de latence, ouverture d'un lien)."/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="DONNÉES UTILISATEUR" Style="{StaticResource Text.Label}" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding LocalAppDataPath}" Style="{StaticResource Text.Mono}" Margin="0,0,0,12"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Ouvrir le dossier" Style="{StaticResource Button.Tertiary}" Command="{Binding OpenLocalAppDataCommand}" Margin="0,0,10,0"/>
                        <Button Content="Refaire le tour de bienvenue" Style="{StaticResource Button.Ghost}" Command="{Binding ShowWelcomeAgainCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="À PROPOS" Style="{StaticResource Text.Label}" Margin="0,0,0,8"/>
                    <TextBlock Text="Aurum Tweaks — v0.1.0 early preview" Style="{StaticResource Text.Body}"/>
                    <TextBlock Style="{StaticResource Text.Muted}" Margin="0,4,0,0" TextWrapping="Wrap"
                               Text="L'optimiseur PC premium tout-en-un. Inspiré et nourri par les communautés FR/EN du tweaking (FR33THY, Hone, Atlas OS, MSI Afterburner, ExitLag, Razer Cortex, Chris Titus, marvingdt/opti-pc, NAIKO, Mopti, leStripeZ, et beaucoup d'autres)."/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
