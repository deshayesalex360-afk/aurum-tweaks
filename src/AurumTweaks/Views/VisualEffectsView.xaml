<UserControl x:Class="AurumTweaks.Views.VisualEffectsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Brush.Bg.Base}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24,32,32">
            <TextBlock Text="Effets visuels" Style="{StaticResource Text.Display}"/>
            <TextBlock Style="{StaticResource Text.Secondary}" Margin="0,4,0,20" TextWrapping="Wrap"
                       Text="Windows anime les fenêtres, les menus et la barre des tâches. Ces effets consomment un peu de GPU/CPU et ajoutent une légère latence à l'interface. Les désactiver rend le bureau plus direct et plus léger sur une machine modeste — c'est la même chose que « Ajuster pour de meilleures performances » dans Windows. Chaque réglage est lu en direct, entièrement réversible, et ne s'applique qu'à votre session (HKCU). Aucun gain de FPS en jeu n'est promis ici."/>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="{Binding ModeDisplay}" Style="{StaticResource Text.Body}" FontWeight="SemiBold"/>

                    <WrapPanel Margin="0,12,0,0">
                        <Button Content="Tout pour les performances" Style="{StaticResource Button.Primary}"
                                Command="{Binding ApplyPerformanceCommand}"/>
                        <Button Content="Tout pour l'apparence" Style="{StaticResource Button.Secondary}" Margin="10,0,0,0"
                                Command="{Binding ApplyAppearanceCommand}"/>
                        <Button Content="Actualiser" Style="{StaticResource Button.Secondary}" Margin="10,0,0,0"
                                Command="{Binding RefreshCommand}"/>
                        <Button Content="Options de performances Windows" Style="{StaticResource Button.Secondary}" Margin="10,0,0,0"
                                Command="{Binding OpenPerformanceOptionsCommand}"/>
                    </WrapPanel>

                    <TextBlock Text="{Binding Status}" Style="{StaticResource Text.Muted}" Margin="0,12,0,0" TextWrapping="Wrap"/>
                    <TextBlock Style="{StaticResource Text.Muted}" Margin="0,4,0,0" TextWrapping="Wrap" FontSize="11"
                               Text="Un effet « Non défini » utilise le défaut de Windows (activé) ; il n'est jamais inventé. Le préréglage Performances désactive les animations superflues mais conserve ClearType (lisibilité du texte). Certains effets ne s'appliquent visuellement qu'après une fermeture de session ou un redémarrage de l'Explorateur."/>

                    <ItemsControl ItemsSource="{Binding Effects}" Margin="0,12,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource Card.Compact}" Margin="0,4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Left: identity + live state + advice -->
                                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Label}" Style="{StaticResource Text.Body}" TextWrapping="Wrap"/>
                                                <Border Style="{StaticResource Badge.Gold}" Margin="8,0,0,0" Padding="5,1"
                                                        VerticalAlignment="Center"
                                                        Visibility="{Binding ShowPerformanceBadge, Converter={StaticResource BoolToVisibility}}">
                                                    <TextBlock Text="✓ PERFORMANCE" FontSize="8" FontWeight="Bold"
                                                               Foreground="{StaticResource Brush.Gold.Bright}"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Style="{StaticResource Text.Muted}" Margin="0,2,0,0">
                                                <Run Text="{Binding StateDisplay, Mode=OneWay}"/>
                                                <Run Text=" · "/>
                                                <Run Text="{Binding ValueName, Mode=OneWay}"/>
                                            </TextBlock>
                                            <TextBlock Text="{Binding Advice}" Style="{StaticResource Text.Muted}"
                                                       FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                        </StackPanel>

                                        <!-- Right: « à conserver » hint + the Activer/Désactiver pair -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" MinWidth="150">
                                            <TextBlock Text="à conserver" Style="{StaticResource Text.Muted}"
                                                       FontSize="10" FontWeight="Bold" HorizontalAlignment="Right" Margin="0,0,0,4"
                                                       Foreground="{StaticResource Brush.Gold.Bright}"
                                                       Visibility="{Binding ShowKeepHint, Converter={StaticResource BoolToVisibility}}"/>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                <Button Content="Activer" Style="{StaticResource Button.Tertiary}"
                                                        IsEnabled="{Binding CanEnable}"
                                                        Command="{Binding DataContext.EnableCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"/>
                                                <Button Content="Désactiver" Style="{StaticResource Button.Tertiary}" Margin="6,0,0,0"
                                                        IsEnabled="{Binding CanDisable}"
                                                        Command="{Binding DataContext.DisableCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
