<UserControl x:Class="AurumTweaks.Views.NetworkAdaptersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Brush.Bg.Base}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24,32,32">
            <TextBlock Text="Cartes réseau" Style="{StaticResource Text.Display}"/>
            <TextBlock Style="{StaticResource Text.Secondary}" Margin="0,4,0,20" TextWrapping="Wrap"
                       Text="Liste des interfaces réseau telles que Windows les rapporte : type, état, débit du lien, IPv4, DNS et passerelle. Deux actions de maintenance sûres sont proposées — vider le cache DNS (Windows le reconstruit à la demande) et renouveler le bail DHCP (peut brièvement couper la connexion). La modification de l'adresse IP ou des serveurs DNS se fait dans les connexions réseau de Windows (raccourci ci-dessous). Aucune de ces opérations n'augmente les FPS ; elles servent à diagnostiquer et réparer la connectivité."/>

            <!-- Synthesis: active connection + the two real maintenance actions + hand-offs -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Synthèse" Style="{StaticResource Text.Body}" FontWeight="SemiBold"/>

                    <WrapPanel Margin="0,12,0,0">
                        <Border Style="{StaticResource MetricChip}">
                            <StackPanel>
                                <TextBlock Text="Cartes" Style="{StaticResource Text.Muted}" FontSize="10"/>
                                <TextBlock Text="{Binding CountDisplay}" Style="{StaticResource Text.Body}"/>
                            </StackPanel>
                        </Border>
                    </WrapPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                        <Ellipse Width="9" Height="9" VerticalAlignment="Center" Margin="0,2,8,0"
                                 Fill="{StaticResource Brush.Success}"
                                 Visibility="{Binding HasAdapters, Converter={StaticResource BoolToVisibility}}"/>
                        <TextBlock Text="{Binding Headline}" Style="{StaticResource Text.Secondary}"
                                   FontWeight="SemiBold" TextWrapping="Wrap"/>
                    </StackPanel>
                    <TextBlock Text="{Binding Detail}" Style="{StaticResource Text.Muted}"
                               Margin="0,6,0,0" TextWrapping="Wrap"/>

                    <!-- Real, exit-code-verified maintenance actions -->
                    <WrapPanel Margin="0,14,0,0">
                        <Button Content="Actualiser" Style="{StaticResource Button.Secondary}"
                                Command="{Binding RefreshCommand}"/>
                        <Button Content="Vider le cache DNS" Style="{StaticResource Button.Secondary}" Margin="10,0,0,0"
                                Command="{Binding FlushDnsCommand}"/>
                        <Button Content="Renouveler le bail DHCP" Style="{StaticResource Button.Secondary}" Margin="10,0,0,0"
                                Command="{Binding RenewDhcpCommand}"/>
                        <Button Content="Copier le rapport" Style="{StaticResource Button.Secondary}" Margin="10,0,0,0"
                                Command="{Binding CopyReportCommand}"
                                ToolTip="Copie l'inventaire des cartes (type, débit, IPv4, DNS, passerelle, MAC) en texte — lecture seule, jamais envoyé. Contient des identifiants locaux."/>
                    </WrapPanel>

                    <!-- Honest hand-offs to Windows' own tools + the in-app diagnostics page -->
                    <WrapPanel Margin="0,10,0,0">
                        <Button Content="Connexions réseau (ncpa.cpl)" Style="{StaticResource Button.Primary}"
                                Command="{Binding OpenNetworkConnectionsCommand}"/>
                        <Button Content="Paramètres réseau" Style="{StaticResource Button.Secondary}" Margin="10,0,0,0"
                                Command="{Binding OpenNetworkSettingsCommand}"/>
                        <Button Content="Diagnostic latence / DNS" Style="{StaticResource Button.Secondary}" Margin="10,0,0,0"
                                Command="{Binding GoToGamingCommand}"/>
                    </WrapPanel>

                    <TextBlock Text="{Binding Status}" Style="{StaticResource Text.Muted}" Margin="0,12,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Per-adapter inventory -->
            <Border Style="{StaticResource Card}" Margin="0,16,0,0">
                <StackPanel>
                    <TextBlock Text="Interfaces détectées" Style="{StaticResource Text.Body}" FontWeight="SemiBold"/>

                    <TextBlock Style="{StaticResource Text.Muted}" Margin="0,8,0,0" TextWrapping="Wrap"
                               Visibility="{Binding HasAdapters, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"
                               Text="Aucune interface réseau rapportée par Windows. Utilisez « Actualiser » après avoir connecté une carte."/>

                    <ItemsControl ItemsSource="{Binding Adapters}" Margin="0,12,0,0"
                                  Visibility="{Binding HasAdapters, Converter={StaticResource BoolToVisibility}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource Card.Compact}" Margin="0,5">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                                <TextBlock Text="{Binding Name}" Style="{StaticResource Text.Body}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                    <TextBlock Text="{Binding TypeDisplay}" Style="{StaticResource Text.Muted}"/>
                                                    <TextBlock Text=" · " Style="{StaticResource Text.Muted}"/>
                                                    <TextBlock Text="{Binding StatusDisplay}" Style="{StaticResource Text.Muted}"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Description}" Style="{StaticResource Text.Muted}" FontSize="11"
                                                           Margin="0,2,0,0" TextWrapping="Wrap"
                                                           Visibility="{Binding HasDescription, Converter={StaticResource BoolToVisibility}}"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top"
                                                        Visibility="{Binding IsActive, Converter={StaticResource BoolToVisibility}}">
                                                <Ellipse Width="9" Height="9" Fill="{StaticResource Brush.Success}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Text="Connexion active" Foreground="{StaticResource Brush.Success}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>

                                        <WrapPanel Margin="0,10,0,0">
                                            <Border Style="{StaticResource MetricChip}">
                                                <StackPanel>
                                                    <TextBlock Text="Débit du lien" Style="{StaticResource Text.Muted}" FontSize="10"/>
                                                    <TextBlock Text="{Binding SpeedDisplay}" Style="{StaticResource Text.Body}"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Style="{StaticResource MetricChip}">
                                                <StackPanel>
                                                    <TextBlock Text="IPv4" Style="{StaticResource Text.Muted}" FontSize="10"/>
                                                    <TextBlock Text="{Binding IPv4Display}" Style="{StaticResource Text.Body}"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Style="{StaticResource MetricChip}">
                                                <StackPanel>
                                                    <TextBlock Text="DNS" Style="{StaticResource Text.Muted}" FontSize="10"/>
                                                    <TextBlock Text="{Binding DnsDisplay}" Style="{StaticResource Text.Body}"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Style="{StaticResource MetricChip}">
                                                <StackPanel>
                                                    <TextBlock Text="Passerelle" Style="{StaticResource Text.Muted}" FontSize="10"/>
                                                    <TextBlock Text="{Binding GatewayDisplay}" Style="{StaticResource Text.Body}"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Style="{StaticResource MetricChip}">
                                                <StackPanel>
                                                    <TextBlock Text="MAC" Style="{StaticResource Text.Muted}" FontSize="10"/>
                                                    <TextBlock Text="{Binding MacDisplay}" Style="{StaticResource Text.Body}"/>
                                                </StackPanel>
                                            </Border>
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
