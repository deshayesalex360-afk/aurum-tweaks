<UserControl x:Class="AurumTweaks.Views.PrivacyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Brush.Bg.Base}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24,32,32">
            <TextBlock Text="Confidentialité" Style="{StaticResource Text.Display}"/>
            <TextBlock Style="{StaticResource Text.Secondary}" Margin="0,4,0,20" TextWrapping="Wrap"
                       Text="Windows collecte des données de diagnostic et personnalise l'interface (publicité, suggestions, historique d'activité, recherche web). Cette page regroupe les interrupteurs de consentement correspondants. Chaque réglage est lu en direct, entièrement réversible, et la valeur est relue après écriture. Honnêteté : ceci RÉDUIT la collecte, cela ne rend pas Windows « privé » ; les services et tâches planifiées qui transportent la télémétrie se gèrent sur leurs propres pages."/>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <WrapPanel>
                        <Button Content="Tout renforcer" Style="{StaticResource Button.Primary}"
                                Command="{Binding HardenAllCommand}"/>
                        <Button Content="Tout rétablir" Style="{StaticResource Button.Secondary}" Margin="10,0,0,0"
                                Command="{Binding RestoreAllCommand}"/>
                        <Button Content="Actualiser" Style="{StaticResource Button.Secondary}" Margin="10,0,0,0"
                                Command="{Binding RefreshCommand}"/>
                        <Button Content="Paramètres de confidentialité Windows" Style="{StaticResource Button.Secondary}" Margin="10,0,0,0"
                                Command="{Binding OpenPrivacySettingsCommand}"/>
                    </WrapPanel>

                    <TextBlock Text="{Binding Status}" Style="{StaticResource Text.Muted}" Margin="0,12,0,0" TextWrapping="Wrap"/>
                    <TextBlock Style="{StaticResource Text.Muted}" Margin="0,4,0,0" TextWrapping="Wrap" FontSize="11"
                               Text="Un réglage « Non configuré » utilise le défaut de Windows (collecte active) ; il n'est jamais inventé. Certains changements ne prennent effet qu'après une reconnexion. Aucun gain de FPS n'est promis ici — c'est une question de vie privée et de légèreté."/>

                    <ItemsControl ItemsSource="{Binding Settings}" Margin="0,12,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource Card.Compact}" Margin="0,4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Left: identity + live state + advice + optional caveat -->
                                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Label}" Style="{StaticResource Text.Body}" TextWrapping="Wrap"/>
                                                <Border Style="{StaticResource Badge.Gold}" Margin="8,0,0,0" Padding="5,1"
                                                        VerticalAlignment="Center"
                                                        Visibility="{Binding ShowHardenedBadge, Converter={StaticResource BoolToVisibility}}">
                                                    <TextBlock Text="✓ PROTÉGÉ" FontSize="8" FontWeight="Bold"
                                                               Foreground="{StaticResource Brush.Gold.Bright}"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Style="{StaticResource Text.Muted}" Margin="0,2,0,0">
                                                <Run Text="{Binding CategoryLabel, Mode=OneWay}"/>
                                                <Run Text=" · "/>
                                                <Run Text="{Binding StateDisplay, Mode=OneWay}"/>
                                                <Run Text=" · "/>
                                                <Run Text="{Binding ValueName, Mode=OneWay}"/>
                                            </TextBlock>
                                            <TextBlock Text="{Binding Advice}" Style="{StaticResource Text.Muted}"
                                                       FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                            <TextBlock Text="{Binding Note}" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"
                                                       FontStyle="Italic" Foreground="{StaticResource Brush.Gold.Bright}"
                                                       Visibility="{Binding HasNote, Converter={StaticResource BoolToVisibility}}"/>
                                        </StackPanel>

                                        <!-- Right: the Renforcer/Rétablir pair, each gated so no button is ever a no-op -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" MinWidth="150">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                <Button Content="Renforcer" Style="{StaticResource Button.Tertiary}"
                                                        IsEnabled="{Binding CanHarden}"
                                                        Command="{Binding DataContext.HardenCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"/>
                                                <Button Content="Rétablir" Style="{StaticResource Button.Tertiary}" Margin="6,0,0,0"
                                                        IsEnabled="{Binding CanRestore}"
                                                        Command="{Binding DataContext.RestoreCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
