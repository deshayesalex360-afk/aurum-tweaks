<UserControl x:Class="AurumTweaks.Views.PreflightBanner"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Pre-flight safety check: shows the safety-net posture BEFORE applying, so the app is « testable sans peur ».
         Shown only when there's a real caution (HasCaution) — same "silence = fine" rule as the verification/conflict
         banners. It FORECASTS the apply-time restore-point abort (it never fakes a green check), and « Revérifier »
         re-probes after the user fixes the cause. Reused by every apply surface; its DataContext is the shared
         PreflightBannerViewModel, so the Tweaks page and the dashboard's one-click apply show one identical posture. -->
    <Border Margin="0,0,0,12" CornerRadius="6" Padding="10,8" Background="#1AF59E0B"
            BorderBrush="{StaticResource Brush.Gold}" BorderThickness="1"
            Visibility="{Binding HasCaution, Converter={StaticResource BoolToVisibility}}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Style="{StaticResource Text.Secondary}" Foreground="{StaticResource Brush.Gold}"
                           FontWeight="Bold" TextWrapping="Wrap"
                           Text="{Binding Summary, Mode=OneWay}"/>
                <ItemsControl ItemsSource="{Binding Cautions}" Margin="0,6,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,0,0,4">
                                <TextBlock Style="{StaticResource Text.Secondary}" FontWeight="SemiBold"
                                           TextWrapping="Wrap" Text="{Binding Title, Mode=OneWay}"/>
                                <TextBlock Style="{StaticResource Text.Muted}" TextWrapping="Wrap"
                                           Text="{Binding Detail, Mode=OneWay}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Top">
                <Button Content="Revérifier" Style="{StaticResource Button.Ghost}"
                        Command="{Binding RefreshCommand}"
                        ToolTip="Re-sonde la Restauration système et l'état de redémarrage."/>
                <!-- Shown only for the « Restauration système indisponible » caution (CanEnableRestore) — never a dead
                     button: clicking enables System Restore directly (the app runs the elevated Enable-ComputerRestore),
                     then re-probes. The caution clears only if Windows now reads the net back; if the machine blocks it,
                     the warning honestly stays. One selection = one action — the app does it, not the user. -->
                <Button Content="Activer la Restauration système" Style="{StaticResource Button.Ghost}"
                        Margin="0,6,0,0"
                        Command="{Binding EnableRestoreCommand}"
                        Visibility="{Binding CanEnableRestore, Converter={StaticResource BoolToVisibility}}"
                        ToolTip="Active la Restauration système maintenant, puis revérifie le filet de sécurité."/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
