<UserControl x:Class="AurumTweaks.Views.JournalView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Brush.Bg.Base}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24,32,32">
            <TextBlock Text="Journal des modifications" Style="{StaticResource Text.Display}"/>
            <TextBlock Style="{StaticResource Text.Secondary}" Margin="0,4,0,20" TextWrapping="Wrap"
                       Text="La trace honnête des tweaks que l'application a réellement appliqués ou restaurés — depuis la page Tweaks, le set recommandé du tableau de bord, un profil ou la ré-application des régressions depuis les Instantanés : chaque opération y est enregistrée, la plus récente en haut. Chaque ligne montre le décompte VÉRIDIQUE (réussites, échecs) et — pour une application vérifiée — les écritures que la vérification post-application n'a PAS pu confirmer comme actives. Le journal est stocké localement (%LOCALAPPDATA%\AurumTweaks\Journal), limité aux 200 dernières entrées, et n'est jamais envoyé nulle part. C'est un historique de consultation : aucune ligne ne ré-applique ou ne ré-évalue quoi que ce soit. Les autres réglages (DNS, fréquence d'écran, overclocking, services Windows) ont leur propre retour sur leur page et n'apparaissent pas ici."/>

            <!-- Toolbar: reload + the two-step clear gate -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Style="{StaticResource Text.Body}" FontWeight="SemiBold">
                                <Run Text="{Binding EntryCount, Mode=OneWay}"/><Run Text=" entrée(s) enregistrée(s)"/>
                            </TextBlock>
                            <TextBlock Text="{Binding Status}" Style="{StaticResource Text.Muted}" Margin="0,4,0,0"
                                       TextWrapping="Wrap"
                                       Visibility="{Binding Status, Converter={StaticResource StringNotEmptyToVisibility}}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Actualiser" Style="{StaticResource Button.Secondary}"
                                    Command="{Binding ReloadCommand}"/>
                            <Button Content="Copier" Style="{StaticResource Button.Secondary}" Margin="10,0,0,0"
                                    Command="{Binding CopyCommand}"
                                    Visibility="{Binding IsConfirmingClear, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"/>
                            <Button Content="Exporter…" Style="{StaticResource Button.Secondary}" Margin="10,0,0,0"
                                    Command="{Binding ExportCommand}"
                                    Visibility="{Binding IsConfirmingClear, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"/>

                            <!-- Resting: a single "clear" affordance that only arms the gate, never wipes directly -->
                            <Button Content="Effacer le journal" Style="{StaticResource Button.Tertiary}" Margin="10,0,0,0"
                                    Command="{Binding BeginClearCommand}"
                                    Visibility="{Binding IsConfirmingClear, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"/>

                            <!-- Armed: explicit confirm/cancel — the destructive step is deliberately two clicks away -->
                            <Button Content="Confirmer l'effacement" Style="{StaticResource Button.Tertiary}" Margin="10,0,0,0"
                                    Foreground="{StaticResource Brush.Danger}"
                                    Command="{Binding ConfirmClearCommand}"
                                    Visibility="{Binding IsConfirmingClear, Converter={StaticResource BoolToVisibility}}"/>
                            <Button Content="Annuler" Style="{StaticResource Button.Tertiary}" Margin="8,0,0,0"
                                    Command="{Binding CancelClearCommand}"
                                    Visibility="{Binding IsConfirmingClear, Converter={StaticResource BoolToVisibility}}"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Style="{StaticResource Text.Muted}" Margin="0,10,0,0" TextWrapping="Wrap" FontSize="11"
                               Visibility="{Binding IsConfirmingClear, Converter={StaticResource BoolToVisibility}}"
                               Foreground="{StaticResource Brush.Danger}"
                               Text="Effacer le journal supprime définitivement tout l'historique des modifications. Cela ne touche PAS aux tweaks appliqués sur le système — seulement à leur trace ici."/>
                </StackPanel>
            </Border>

            <!-- Synthèse: a read-only aggregate of the whole trail (tallies + the tweaks most often left
                 unconfirmed). A derived view — it re-applies / re-évalue rien, so it honours the page's read-only
                 promise. Shown only when there's history to summarize. -->
            <Border Style="{StaticResource Card}" Margin="0,16,0,0"
                    Visibility="{Binding HasEntries, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Text="Synthèse" Style="{StaticResource Text.H3}"/>
                    <TextBlock Text="{Binding Statistics.Summary}" Style="{StaticResource Text.Secondary}"
                               Margin="0,4,0,0" TextWrapping="Wrap"/>

                    <!-- Tweak-level tallies (the batch breakdown lives in the Summary line above) -->
                    <WrapPanel Margin="0,14,0,0">
                        <StackPanel Margin="0,0,28,8">
                            <TextBlock Text="{Binding Statistics.TotalApplied}" Style="{StaticResource Text.Body}"
                                       FontSize="22" FontWeight="SemiBold"/>
                            <TextBlock Text="tweak(s) appliqué(s)" Style="{StaticResource Text.Muted}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,28,8">
                            <TextBlock Text="{Binding Statistics.TotalReverted}" Style="{StaticResource Text.Body}"
                                       FontSize="22" FontWeight="SemiBold"/>
                            <TextBlock Text="tweak(s) restauré(s)" Style="{StaticResource Text.Muted}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,28,8">
                            <TextBlock Text="{Binding Statistics.TotalFailures}" Style="{StaticResource Text.Body}"
                                       FontSize="22" FontWeight="SemiBold"/>
                            <TextBlock Text="échec(s)" Style="{StaticResource Text.Muted}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,8">
                            <TextBlock Text="{Binding Statistics.TotalUnconfirmed}" Style="{StaticResource Text.Body}"
                                       FontSize="22" FontWeight="SemiBold"/>
                            <TextBlock Text="non confirmé(s)" Style="{StaticResource Text.Muted}"/>
                        </StackPanel>
                    </WrapPanel>

                    <TextBlock Style="{StaticResource Text.Muted}" Margin="0,2,0,0">
                        <Run Text="Activité du "/><Run Text="{Binding Statistics.FirstActivityLabel, Mode=OneWay}"/><Run Text=" au "/><Run Text="{Binding Statistics.LastActivityLabel, Mode=OneWay}"/>
                    </TextBlock>

                    <!-- Diagnostic: the tweaks the post-apply verification most often couldn't confirm. A real count
                         of recorded events, NOT a claim the tweak failed — some operations simply have no readback. -->
                    <StackPanel Margin="0,16,0,0"
                                Visibility="{Binding Statistics.HasUnconfirmed, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="Tweaks le plus souvent non confirmés" Style="{StaticResource Text.Body}"
                                   FontWeight="SemiBold"/>
                        <TextBlock Style="{StaticResource Text.Muted}" TextWrapping="Wrap" Margin="0,2,0,6" FontSize="11"
                                   Text="Combien de fois la vérification post-application n'a pas pu confirmer ces écritures. Un compte d'événements réels — pas une preuve que le tweak a échoué (certaines opérations n'ont aucune relecture)."/>
                        <ItemsControl ItemsSource="{Binding Statistics.MostUnconfirmed}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Style="{StaticResource Text.Mono}" Margin="0,1" Text="{Binding Label}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Empty state -->
            <Border Style="{StaticResource Card}" Margin="0,16,0,0"
                    Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Style="{StaticResource Text.Secondary}" TextWrapping="Wrap"
                           Text="Aucune modification enregistrée pour l'instant. Dès que tu appliques ou restaures des tweaks (page Tweaks), chaque opération apparaîtra ici avec son résultat exact."/>
            </Border>

            <!-- The trail, newest first -->
            <ItemsControl ItemsSource="{Binding Entries}" Margin="0,8,0,0"
                          Visibility="{Binding HasEntries, Converter={StaticResource BoolToVisibility}}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Card.Compact}" Margin="0,4">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Summary}" Style="{StaticResource Text.Body}"
                                               FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,16,0"/>
                                    <TextBlock Grid.Column="1" Text="{Binding LocalTimestampLabel}" Style="{StaticResource Text.Muted}"
                                               HorizontalAlignment="Right" VerticalAlignment="Top"/>
                                </Grid>

                                <TextBlock Style="{StaticResource Text.Mono}" Margin="0,6,0,0" TextWrapping="Wrap"
                                           Text="{Binding TweakIdsLabel, Mode=OneWay}"/>

                                <!-- Only shown when verification genuinely couldn't confirm a write — never a fake clean stamp -->
                                <Border Margin="0,8,0,0" CornerRadius="4" Padding="8,6" Background="#1AEF4444"
                                        BorderBrush="{StaticResource Brush.Danger}" BorderThickness="1"
                                        Visibility="{Binding HasUnconfirmed, Converter={StaticResource BoolToVisibility}}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource Text.Muted}" Foreground="{StaticResource Brush.Danger}"
                                                   FontWeight="SemiBold" TextWrapping="Wrap"
                                                   Text="Non confirmé(s) par la vérification post-application :"/>
                                        <TextBlock Style="{StaticResource Text.Mono}" Margin="0,2,0,0" TextWrapping="Wrap"
                                                   Text="{Binding UnconfirmedLabel, Mode=OneWay}"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
