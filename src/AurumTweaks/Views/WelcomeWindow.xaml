<Window x:Class="AurumTweaks.Views.WelcomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:AurumTweaks.Controls"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Width="780" Height="540"
        ShowInTaskbar="False">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" CornerRadius="0" GlassFrameThickness="0" ResizeBorderThickness="0"/>
    </WindowChrome.WindowChrome>
    <Border BorderBrush="{StaticResource Brush.Border.Strong}" BorderThickness="1" CornerRadius="10">
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.7" BlurRadius="50" ShadowDepth="0"/>
        </Border.Effect>
        <Grid ClipToBounds="True">
            <Border CornerRadius="10" ClipToBounds="True" Background="{StaticResource Brush.Bg.Base}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Marble signature panel -->
                    <Grid Grid.Column="0">
                        <controls:MarbleSurface Seed="111"
                                                VeinDensity="1.5"
                                                VeinIntensity="0.92"
                                                BaseDarkness="0.03"
                                                RenderWidth="320"
                                                RenderHeight="540"/>
                        <Border>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                                    <GradientStop Color="#AA000000" Offset="0"/>
                                    <GradientStop Color="#33000000" Offset="0.4"/>
                                    <GradientStop Color="#00000000" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <StackPanel VerticalAlignment="Bottom" Margin="28,0,28,40">
                            <TextBlock Text="AURUM" FontFamily="{StaticResource Font.Display}"
                                       FontSize="38" FontWeight="Bold"
                                       Foreground="{StaticResource Brush.Gold.Bright}">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="#FFD4AF37" Opacity="0.4" BlurRadius="14" ShadowDepth="0"/>
                                </TextBlock.Effect>
                            </TextBlock>
                            <TextBlock Text="TWEAKS" FontFamily="{StaticResource Font.Display}"
                                       FontSize="38" FontWeight="Thin"
                                       Foreground="{StaticResource Brush.Text.Primary}"
                                       Margin="0,-10,0,12"/>
                            <Rectangle Width="40" Height="2" Fill="{StaticResource Brush.Gold.Gradient}" HorizontalAlignment="Left"/>
                            <TextBlock Text="Premium PC Optimizer"
                                       Style="{StaticResource Text.Muted}" Margin="0,12,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!-- Content -->
                    <Grid Grid.Column="1" Margin="40,40,40,32">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <TextBlock Text="BIENVENUE" Style="{StaticResource Text.Label}"
                                       Foreground="{StaticResource Brush.Gold.Bright}"/>
                            <TextBlock Text="Premier lancement" Style="{StaticResource Text.Display}" Margin="0,4,0,0"/>
                            <TextBlock Style="{StaticResource Text.Secondary}" Margin="0,8,0,0" TextWrapping="Wrap"
                                       Text="Avant de commencer, quelques règles que tu dois connaître sur Aurum Tweaks."/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Margin="0,28,0,0">
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="✓  Réversible par défaut" Style="{StaticResource Text.H3}"
                                               Foreground="{StaticResource Brush.Gold.Bright}"/>
                                    <TextBlock Style="{StaticResource Text.Secondary}" Margin="0,6,0,0" TextWrapping="Wrap"
                                               Text="Chaque tweak est documenté avec ses opérations revert. Par défaut, un point de restauration Windows est créé avant chaque batch d'application (option réglable dans Paramètres)."/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="✓  Matrice anti-cheat" Style="{StaticResource Text.H3}"
                                               Foreground="{StaticResource Brush.Gold.Bright}"/>
                                    <TextBlock Style="{StaticResource Text.Secondary}" Margin="0,6,0,0" TextWrapping="Wrap"
                                               Text="Si tu joues à Valorant, FACEIT ou un jeu avec anti-cheat strict, active le mode compétitif strict dans les paramètres — on filtre les tweaks risqués."/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="✓  Pour le BIOS" Style="{StaticResource Text.H3}"
                                               Foreground="{StaticResource Brush.Gold.Bright}"/>
                                    <TextBlock Style="{StaticResource Text.Secondary}" Margin="0,6,0,0" TextWrapping="Wrap"
                                               Text="Aurum auto-détecte ta carte mère et te guide pas-à-pas dans ton BIOS. Là où se cachent les vrais gains."/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Commencer" Style="{StaticResource Button.Primary}" Click="StartBtn_Click" MinWidth="140"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
