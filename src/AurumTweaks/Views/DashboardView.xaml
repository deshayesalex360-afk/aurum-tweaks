<UserControl x:Class="AurumTweaks.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:AurumTweaks.Controls"
             xmlns:views="clr-namespace:AurumTweaks.Views"
             Background="{StaticResource Brush.Bg.Base}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="32,24,32,32" MaxWidth="1280">

            <!-- ===== MARBLE HERO — the brand signature shows up immediately ===== -->
            <Border CornerRadius="8" BorderBrush="{StaticResource Brush.Border.Default}"
                    BorderThickness="1" ClipToBounds="True" Margin="0,0,0,16">
                <Grid Height="200">
                    <controls:MarbleSurface Seed="404"
                                            VeinDensity="1.5"
                                            VeinIntensity="0.92"
                                            BaseDarkness="0.035"
                                            RenderWidth="1200"
                                            RenderHeight="400"
                                            Opacity="0.9"/>
                    <!-- Right-side fade so text reads -->
                    <Border>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#E6000000" Offset="0"/>
                                <GradientStop Color="#88000000" Offset="0.55"/>
                                <GradientStop Color="#00000000" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <!-- Text content -->
                    <StackPanel Margin="36,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Left">
                        <TextBlock Text="BIENVENUE" FontFamily="{StaticResource Font.Display}"
                                   FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource Brush.Gold.Bright}"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="Ton PC, à son apogée." Style="{StaticResource Text.Display}"/>
                        <TextBlock Style="{StaticResource Text.Secondary}" Margin="0,8,0,0" MaxWidth="500" TextWrapping="Wrap"
                                   Text="Aurum Tweaks combine l'optimisation Windows, le BIOS, l'overclocking GPU et le gaming en une seule app premium."/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ===== REDÉMARRAGE EN ATTENTE — standard Windows signals (servicing / file-rename / computer-rename).
                 Shown only when a restart is genuinely queued; informative and read-only, never a fabricated nudge. ===== -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16"
                    Visibility="{Binding RebootPending, Converter={StaticResource BoolToVisibility}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="3" CornerRadius="2" Margin="0,2,14,2"
                            Background="{StaticResource Brush.Warning}"/>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="REDÉMARRAGE EN ATTENTE" Style="{StaticResource Text.Label}"
                                   Foreground="{StaticResource Brush.Warning}"/>
                        <TextBlock Text="{Binding RebootSummary}" Style="{StaticResource Text.Body}"
                                   FontWeight="SemiBold" Margin="0,5,0,0" TextWrapping="Wrap"/>
                        <ItemsControl ItemsSource="{Binding RebootReasons}" Margin="0,6,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="•" Style="{StaticResource Text.Muted}"
                                                   Margin="0,0,8,0"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Mode=OneWay}"
                                                   Style="{StaticResource Text.Muted}" TextWrapping="Wrap"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Style="{StaticResource Text.Muted}" Margin="0,8,0,0" TextWrapping="Wrap"
                                   Text="Enregistre ton travail puis redémarre pour finaliser. Signaux Windows standards — informatif, lecture seule."/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ===== RECOMMANDÉ POUR TON PC (adaptive engine) ===== -->
            <StackPanel Visibility="{Binding PlanReady, Converter={StaticResource BoolToVisibility}}">

                <!-- ===== SCORE D'OPTIMISATION — the live "à quel point ton PC est optimisé" headline. The ring's
                     number + colour come straight from the on-system probe of the safe recommended set; unverifiable
                     tweaks are excluded (disclosed in the hint), so the number is honest and 100 is reachable.
                     Hidden until there's readable data — never shows a fabricated 0/100. ===== -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16"
                        Visibility="{Binding HasScore, Converter={StaticResource BoolToVisibility}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Grade-coloured score ring -->
                        <Border Grid.Column="0" Width="104" Height="104" CornerRadius="999"
                                Background="{StaticResource Brush.Bg.Elevated}" BorderThickness="3"
                                BorderBrush="{Binding ScoreGrade, Converter={StaticResource ScoreGradeToBrush}}"
                                VerticalAlignment="Center">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock HorizontalAlignment="Center" FontFamily="{StaticResource Font.Display}"
                                           FontSize="38" FontWeight="Bold"
                                           Foreground="{Binding ScoreGrade, Converter={StaticResource ScoreGradeToBrush}}"
                                           Text="{Binding OptimizationScoreValue}"/>
                                <TextBlock Text="{Binding ScoreGradeLabel}" HorizontalAlignment="Center"
                                           FontSize="9" FontWeight="Bold" Margin="0,-2,0,0"
                                           Foreground="{Binding ScoreGrade, Converter={StaticResource ScoreGradeToBrush}}"/>
                            </StackPanel>
                        </Border>

                        <!-- Header + summary + hint + per-category breakdown -->
                        <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="SCORE D'OPTIMISATION" Style="{StaticResource Text.Label}"
                                           Foreground="{StaticResource Brush.Gold}" VerticalAlignment="Center"/>
                                <Border Style="{StaticResource Badge.Gold}" Margin="10,-2,0,0" Padding="7,2">
                                    <TextBlock Text="ÉTAT RÉEL DU SYSTÈME" FontSize="9" FontWeight="Bold"
                                               Foreground="{StaticResource Brush.Gold.Bright}"/>
                                </Border>
                            </StackPanel>
                            <TextBlock Text="{Binding ScoreSummary}" Style="{StaticResource Text.H3}" Margin="0,6,0,0"/>
                            <TextBlock Text="{Binding ScoreHint}" Style="{StaticResource Text.Muted}"
                                       Foreground="{StaticResource Brush.Gold.Pale}" Margin="0,3,0,0" TextWrapping="Wrap"/>

                            <!-- Progression since the last DIFFERENT measure — hidden until a second sample exists,
                                 so a first-ever score never shows a fabricated "+0". Coloured by direction (the same
                                 Success/Danger/Muted convention as the benchmark delta): green = real climb, red =
                                 real drop, muted = stable. The FR text is composed in the VM. -->
                            <TextBlock Visibility="{Binding HasScoreTrend, Converter={StaticResource BoolToVisibility}}"
                                       Text="{Binding ScoreTrendText}" FontSize="12" FontWeight="SemiBold"
                                       Margin="0,5,0,0" TextWrapping="Wrap">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Muted}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ScoreTrendIsImprovement}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource Brush.Success}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ScoreTrendIsRegression}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource Brush.Danger}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- Sparkline of the recorded score timeline — the visual companion to the trend line
                                 above. Fixed 0-100 vertical scale (a small move stays small; the exact magnitude is
                                 in the text), oldest→newest. Same ≥2-samples gate as the trend, so the two appear
                                 together. Neutral gold stroke: the SHAPE tells the story; it's never recoloured by the
                                 latest direction, since the line can rise and fall within the window. Drawn in a Canvas
                                 so the pure core's absolute pixel points map 1:1 into the fixed box. -->
                            <Canvas Visibility="{Binding HasScoreTrend, Converter={StaticResource BoolToVisibility}}"
                                    Width="{Binding SparklineWidth}" Height="{Binding SparklineHeight}"
                                    HorizontalAlignment="Left" Margin="0,8,0,0">
                                <Polyline Points="{Binding ScoreSparklinePoints, Converter={StaticResource ScorePolyline}}"
                                          Stroke="{StaticResource Brush.Gold}" StrokeThickness="2"
                                          StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            </Canvas>

                            <!-- Per-domain bars: where the machine is strong vs. where there's still room -->
                            <ItemsControl ItemsSource="{Binding ScoreCategories}" Margin="0,12,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,3"
                                              ToolTip="{Binding AppliedCount, StringFormat=actives : {0}}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="44"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" VerticalAlignment="Center"
                                                       Style="{StaticResource Text.Muted}"
                                                       Text="{Binding Category, Converter={StaticResource TweakCategoryToLabel}}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <ProgressBar Grid.Column="1" Height="6" Minimum="0" Maximum="100"
                                                         VerticalAlignment="Center" Margin="4,0"
                                                         Value="{Binding Percent, Mode=OneWay}"
                                                         Background="{StaticResource Brush.Bg.Elevated}"
                                                         Foreground="{StaticResource Brush.Gold}" BorderThickness="0"/>
                                            <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                                       HorizontalAlignment="Right" Style="{StaticResource Text.Muted}"
                                                       Text="{Binding Percent, StringFormat={}{0} %}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Section header + machine profile -->
                <StackPanel Margin="2,4,0,10">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="RECOMMANDÉ POUR TON PC" Style="{StaticResource Text.Label}"
                                   Foreground="{StaticResource Brush.Gold}"/>
                        <Border Style="{StaticResource Badge.Gold}" Margin="10,-2,0,0" Padding="7,2">
                            <TextBlock Text="ADAPTÉ À TA CONFIG" FontSize="9" FontWeight="Bold"
                                       Foreground="{StaticResource Brush.Gold.Bright}"/>
                        </Border>
                    </StackPanel>
                    <TextBlock Text="{Binding ProfileSummary}" Style="{StaticResource Text.Secondary}"
                               Margin="0,5,0,0"/>
                </StackPanel>

                <!-- Pre-flight safety check (shared control): the safety-net posture shown ABOVE the one-click apply,
                     so the front-door « Appliquer le set » is « testable sans peur » too. Self-collapsing when
                     all-clear; bound to the SAME PreflightBannerViewModel the Tweaks page uses. -->
                <views:PreflightBanner DataContext="{Binding Preflight}"/>

                <!-- Plan summary card: score gauge + counts + one-click CTA -->
                <Border Style="{StaticResource Card.Gold}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Potential score gauge -->
                        <Border Grid.Column="0" Width="86" Height="86" CornerRadius="999"
                                Background="{StaticResource Brush.Gold.Whisper}"
                                BorderBrush="{StaticResource Brush.Gold}" BorderThickness="2"
                                VerticalAlignment="Center">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock HorizontalAlignment="Center" FontFamily="{StaticResource Font.Display}"
                                           FontSize="30" FontWeight="Bold"
                                           Foreground="{StaticResource Brush.Gold.Bright}"
                                           Text="{Binding PotentialScore}"/>
                                <TextBlock Text="POTENTIEL" HorizontalAlignment="Center" FontSize="8"
                                           FontWeight="Bold" Foreground="{StaticResource Brush.Gold}"
                                           Margin="0,-3,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Counts + description -->
                        <StackPanel Grid.Column="1" Margin="18,0,18,0" VerticalAlignment="Center">
                            <TextBlock Style="{StaticResource Text.H3}">
                                <Run Text="{Binding RecommendedCount, Mode=OneWay}" FontWeight="Bold"
                                     Foreground="{StaticResource Brush.Gold.Bright}"/>
                                <Run Text=" optimisations prêtes à appliquer en un clic"/>
                            </TextBlock>
                            <TextBlock Style="{StaticResource Text.Secondary}" Margin="0,5,0,0">
                                <Run Text="sur"/>
                                <Run Text="{Binding TotalApplicable, Mode=OneWay}"/>
                                <Run Text="compatibles avec ta configuration. Sûres, réversibles, avec point de restauration automatique par défaut."/>
                            </TextBlock>
                        </StackPanel>

                        <!-- One-click apply -->
                        <Button Grid.Column="2" Content="Appliquer le set recommandé"
                                Style="{StaticResource Button.Primary}" VerticalAlignment="Center"
                                Command="{Binding ApplyRecommendedCommand}"/>
                    </Grid>
                </Border>

                <!-- Live status line for the apply action -->
                <TextBlock Text="{Binding PlanStatus}" Style="{StaticResource Text.Muted}"
                           Foreground="{StaticResource Brush.Gold.Pale}" Margin="2,2,0,6"
                           Visibility="{Binding PlanStatus, Converter={StaticResource StringNotEmptyToVisibility}}"/>

                <!-- Post-apply verification for the one-click set — the front-door twin of the Tweaks page banner.
                     Shown only when real (HasUnconfirmed): tweaks the engine reported applied that the live machine
                     does NOT read back as active. An honest "couldn't confirm", never a fabricated ✓ over the status. -->
                <Border CornerRadius="6" Padding="10,8" Margin="2,0,0,6" Background="#1AEF4444"
                        BorderBrush="{StaticResource Brush.Danger}" BorderThickness="1"
                        Visibility="{Binding HasUnconfirmed, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource Text.Secondary}" Foreground="{StaticResource Brush.Danger}"
                                   FontWeight="Bold" TextWrapping="Wrap"
                                   Text="⚠ Vérification après application : ces tweaks ont été appliqués, mais à la relecture la valeur diffère de l'état attendu. Un redémarrage peut être requis, ou l'opération n'a pas pris."/>
                        <TextBlock Style="{StaticResource Text.Mono}" TextWrapping="Wrap" Margin="0,4,0,0"
                                   Text="{Binding LastVerification.UnconfirmedLabel, Mode=OneWay}"/>
                    </StackPanel>
                </Border>

                <!-- Persistance des optimisations : tweaks the app PROVED applied that the system has since undone
                     (Windows Update, Group Policy, another tool). Shown only when real (HasDrift) — never a guess —
                     with a real one-click « Réappliquer » that re-runs exactly those tweaks and re-checks. -->
                <Border CornerRadius="6" Padding="10,8" Margin="2,0,0,6" Background="#1AEAB308"
                        BorderBrush="{StaticResource Brush.Warning}" BorderThickness="1"
                        Visibility="{Binding HasDrift, Converter={StaticResource BoolToVisibility}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock Style="{StaticResource Text.Secondary}" Foreground="{StaticResource Brush.Warning}"
                                       FontWeight="Bold" TextWrapping="Wrap"
                                       Text="⚠ Optimisations annulées par le système"/>
                            <TextBlock Style="{StaticResource Text.Secondary}" TextWrapping="Wrap" Margin="0,3,0,0"
                                       Text="{Binding DriftSummary, Mode=OneWay}"/>
                            <TextBlock Style="{StaticResource Text.Mono}" TextWrapping="Wrap" Margin="0,4,0,0"
                                       Text="{Binding DriftedNames, Mode=OneWay}"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Réappliquer" VerticalAlignment="Center"
                                Style="{StaticResource Button.Secondary}"
                                Command="{Binding ReapplyDriftedCommand}"/>
                    </Grid>
                </Border>

                <!-- Two columns: priority tweaks (left) + hardware insights (right) -->
                <Grid Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- LEFT: top ranked recommendations -->
                    <StackPanel Grid.Column="0" Margin="0,0,6,0">
                        <TextBlock Text="OPTIMISATIONS PRIORITAIRES" Style="{StaticResource Text.Label}"
                                   Margin="2,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding TopRecommendations}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource Card.Compact}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- tier accent bar -->
                                            <Border Grid.Column="0" Width="3" CornerRadius="2" Margin="0,2,12,2"
                                                    Background="{Binding Tweak.Tier, Converter={StaticResource TierToBrush}}"/>
                                            <StackPanel Grid.Column="1">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding DisplayName}" Style="{StaticResource Text.Body}"
                                                               FontWeight="SemiBold" TextWrapping="NoWrap"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <!-- "tuned for this PC" gold dot -->
                                                    <Border Width="6" Height="6" CornerRadius="999" Margin="8,0,0,0"
                                                            VerticalAlignment="Center"
                                                            Background="{StaticResource Brush.Gold.Bright}"
                                                            ToolTip="Spécifiquement réglé pour ton matériel"
                                                            Visibility="{Binding IsTunedForThisPc, Converter={StaticResource BoolToVisibility}}"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding ReasonFr}" Style="{StaticResource Text.Muted}"
                                                           Margin="0,3,0,0"/>
                                                <TextBlock Text="{Binding Tweak.ExpectedImpact}"
                                                           Style="{StaticResource Text.Muted}"
                                                           Foreground="{StaticResource Brush.Gold.Pale}" Margin="0,3,0,0"
                                                           Visibility="{Binding Tweak.ExpectedImpact, Converter={StaticResource StringNotEmptyToVisibility}}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- RIGHT: hardware-derived insights -->
                    <StackPanel Grid.Column="1" Margin="6,0,0,0">
                        <TextBlock Text="CE QUE J'AI REMARQUÉ SUR TON PC" Style="{StaticResource Text.Label}"
                                   Margin="2,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding Insights}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="6" Padding="14" Margin="0,0,0,8"
                                            BorderThickness="1" BorderBrush="{StaticResource Brush.Border.Subtle}"
                                            Background="{Binding Severity, Converter={StaticResource SeverityToBackground}}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="3" CornerRadius="2" Margin="0,2,12,2"
                                                    Background="{Binding Severity, Converter={StaticResource SeverityToBrush}}"/>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding TitleFr}" Style="{StaticResource Text.Body}"
                                                           FontWeight="SemiBold"
                                                           Foreground="{Binding Severity, Converter={StaticResource SeverityToBrush}}"/>
                                                <TextBlock Text="{Binding DetailFr}" Style="{StaticResource Text.Muted}"
                                                           Margin="0,3,0,0"/>
                                                <Button Content="{Binding ActionLabelFr}" Style="{StaticResource Button.Secondary}"
                                                        HorizontalAlignment="Left" Margin="0,8,0,0" Padding="11,4"
                                                        Command="{Binding DataContext.RunInsightActionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Visibility="{Binding ActionPage, Converter={StaticResource StringNotEmptyToVisibility}}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>

                <!-- Section divider before the static system info below -->
                <Border Height="1" Background="{StaticResource Brush.Border.Subtle}" Margin="0,8,0,4"/>
            </StackPanel>

            <!-- ===== ACTIVITÉ RÉCENTE (a window onto the change journal — discoverable from the front door) ===== -->
            <StackPanel Margin="0,16,0,0"
                        Visibility="{Binding HasRecentActivity, Converter={StaticResource BoolToVisibility}}">
                <Grid Margin="2,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="ACTIVITÉ RÉCENTE" Style="{StaticResource Text.Label}"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="Voir le journal" Style="{StaticResource Button.Tertiary}"
                            Padding="11,4" Command="{Binding GoToJournalCommand}"/>
                </Grid>
                <Border Style="{StaticResource Card}">
                    <ItemsControl ItemsSource="{Binding RecentActivity}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                        <TextBlock Text="{Binding Summary}" Style="{StaticResource Text.Body}"
                                                   FontWeight="SemiBold" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding TweakIdsLabel, Mode=OneWay}" Style="{StaticResource Text.Muted}"
                                                   Margin="0,2,0,0" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                        <!-- Carry the honest "couldn't confirm" flag to the front door too — the card must
                                             never paint a cleaner picture than the journal recorded. -->
                                        <TextBlock Style="{StaticResource Text.Muted}" Margin="0,2,0,0" FontSize="11"
                                                   Foreground="{StaticResource Brush.Danger}" TextWrapping="Wrap"
                                                   Visibility="{Binding HasUnconfirmed, Converter={StaticResource BoolToVisibility}}">
                                            <Run Text="Non confirmé(s) : "/><Run Text="{Binding UnconfirmedLabel, Mode=OneWay}"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding LocalTimestampLabel}" Style="{StaticResource Text.Muted}"
                                               HorizontalAlignment="Right" VerticalAlignment="Top"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
            </StackPanel>

            <!-- ===== SYSTEM INFO ===== -->
            <Border Style="{StaticResource Card}" Margin="0,16,0,0">
                <StackPanel>
                    <TextBlock Text="INFORMATIONS SYSTÈME" Style="{StaticResource Text.Label}" Margin="0,0,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                            <TextBlock Text="CPU" Style="{StaticResource Text.Label}"/>
                            <TextBlock Text="{Binding HardwareInfo.CpuName, FallbackValue=Détection…}"
                                       Style="{StaticResource Text.Body}" Margin="0,4,0,12"/>
                            <TextBlock Text="GPU" Style="{StaticResource Text.Label}"/>
                            <TextBlock Text="{Binding HardwareInfo.GpuPrimary, FallbackValue=Détection…}"
                                       Style="{StaticResource Text.Body}" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="0,0,16,0">
                            <TextBlock Text="Carte mère" Style="{StaticResource Text.Label}"/>
                            <TextBlock Text="{Binding HardwareInfo.MotherboardModel}"
                                       Style="{StaticResource Text.Body}" Margin="0,4,0,12"/>
                            <TextBlock Text="BIOS" Style="{StaticResource Text.Label}"/>
                            <TextBlock Text="{Binding HardwareInfo.BiosVersion}"
                                       Style="{StaticResource Text.Body}" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="RAM" Style="{StaticResource Text.Label}"/>
                            <TextBlock Style="{StaticResource Text.Body}" Margin="0,4,0,12">
                                <Run Text="{Binding HardwareInfo.RamType, Mode=OneWay}"/>
                                <Run Text="·"/>
                                <Run Text="{Binding HardwareInfo.RamSpeedMhz, Mode=OneWay}"/>
                            </TextBlock>
                            <TextBlock Text="OS" Style="{StaticResource Text.Label}"/>
                            <TextBlock Text="{Binding HardwareInfo.OsCaption}"
                                       Style="{StaticResource Text.Body}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!-- Shareable system report: hardware + applied tweaks + journal + safety toggles, for a forum
                         or a help request. Local-only; the export claim is honest (no upload). -->
                    <Border Height="1" Background="{StaticResource Brush.Border.Subtle}" Margin="0,16,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                            <TextBlock Style="{StaticResource Text.Muted}" TextWrapping="Wrap"
                                       Text="Un instantané partageable — matériel, tweaks appliqués, plateforme et réglages — pour un forum ou une demande d'aide. Généré localement, jamais envoyé."/>
                            <TextBlock Style="{StaticResource Text.Muted}" Margin="0,4,0,0" TextWrapping="Wrap"
                                       Foreground="{StaticResource Brush.Gold.Pale}"
                                       Text="{Binding ReportStatus}"
                                       Visibility="{Binding ReportStatus, Converter={StaticResource StringNotEmptyToVisibility}}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Content="Copier" Style="{StaticResource Button.Tertiary}"
                                    Command="{Binding CopySystemReportCommand}"/>
                            <Button Content="Exporter un rapport système" Style="{StaticResource Button.Secondary}"
                                    Margin="10,0,0,0" Command="{Binding ExportSystemReportCommand}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Shareable before/after « preuve »: the settings diff (Instantanés), the frame-time A/B
                         (Benchmark) and the optimization score, folded into one paste to back an « après mes tweaks »
                         claim. Each section says « non disponible » when its measure hasn't been produced — never a
                         fabricated delta. Local-only, like the report above. -->
                    <Border Height="1" Background="{StaticResource Brush.Border.Subtle}" Margin="0,16,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                            <TextBlock Style="{StaticResource Text.Muted}" TextWrapping="Wrap"
                                       Text="La preuve avant/après — gain FPS et 1% low (Benchmark), réglages qui ont changé (Instantanés) et score — en un seul bloc à coller. Chaque chiffre vient d'une mesure réelle."/>
                            <TextBlock Style="{StaticResource Text.Muted}" Margin="0,4,0,0" TextWrapping="Wrap"
                                       Foreground="{StaticResource Brush.Gold.Pale}"
                                       Text="{Binding EvidenceStatus}"
                                       Visibility="{Binding EvidenceStatus, Converter={StaticResource StringNotEmptyToVisibility}}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Content="Copier" Style="{StaticResource Button.Tertiary}"
                                    Command="{Binding CopyEvidenceReportCommand}"/>
                            <Button Content="Exporter la preuve avant/après" Style="{StaticResource Button.Secondary}"
                                    Margin="10,0,0,0" Command="{Binding ExportEvidenceReportCommand}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ===== LIVE METRICS ===== -->
            <TextBlock Text="MÉTRIQUES EN DIRECT" Style="{StaticResource Text.Label}" Margin="0,16,0,10"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource Card.Metric}" Margin="0,0,5,0">
                    <StackPanel>
                        <TextBlock Text="CPU" Style="{StaticResource Text.Label}"/>
                        <TextBlock Style="{StaticResource Text.H1}" Margin="0,6,0,0">
                            <Run Text="{Binding LiveSnapshot.CpuUsagePercent, StringFormat={}{0:F0}, FallbackValue=—}"/>
                            <Run Text="%" FontSize="14" Foreground="{StaticResource Brush.Text.Muted}"/>
                        </TextBlock>
                        <TextBlock Margin="0,6,0,0" Style="{StaticResource Text.Muted}">
                            <Run Text="{Binding LiveSnapshot.CpuTempC, StringFormat={}{0:F0}, FallbackValue=—}"/>
                            <Run Text="°C"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource Card.Metric}" Margin="3,0,3,0">
                    <StackPanel>
                        <TextBlock Text="GPU" Style="{StaticResource Text.Label}"/>
                        <TextBlock Style="{StaticResource Text.H1}" Margin="0,6,0,0">
                            <Run Text="{Binding LiveSnapshot.GpuUsagePercent, StringFormat={}{0:F0}, FallbackValue=—}"/>
                            <Run Text="%" FontSize="14" Foreground="{StaticResource Brush.Text.Muted}"/>
                        </TextBlock>
                        <TextBlock Margin="0,6,0,0" Style="{StaticResource Text.Muted}">
                            <Run Text="{Binding LiveSnapshot.GpuTempC, StringFormat={}{0:F0}, FallbackValue=—}"/>
                            <Run Text="°C"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource Card.Metric}" Margin="3,0,3,0">
                    <StackPanel>
                        <TextBlock Text="RAM" Style="{StaticResource Text.Label}"/>
                        <TextBlock Style="{StaticResource Text.H1}" Margin="0,6,0,0">
                            <Run Text="{Binding LiveSnapshot.RamUsagePercent, StringFormat={}{0:F0}, FallbackValue=—}"/>
                            <Run Text="%" FontSize="14" Foreground="{StaticResource Brush.Text.Muted}"/>
                        </TextBlock>
                        <TextBlock Margin="0,6,0,0" Style="{StaticResource Text.Muted}">
                            <Run Text="{Binding LiveSnapshot.RamUsedGb, StringFormat={}{0:F1}, FallbackValue=—}"/>
                            <Run Text="GB"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Style="{StaticResource Card.Metric}" Margin="5,0,0,0">
                    <StackPanel>
                        <TextBlock Text="STATUT" Style="{StaticResource Text.Label}"/>
                        <TextBlock Text="Optimal" Style="{StaticResource Text.H1}"
                                   Foreground="{StaticResource Brush.Gold.Bright}" Margin="0,6,0,0"/>
                        <TextBlock Text="Aucune action requise"
                                   Style="{StaticResource Text.Muted}" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ===== QUICK ACTIONS ===== -->
            <TextBlock Text="ACTIONS RAPIDES" Style="{StaticResource Text.Label}" Margin="0,24,0,10"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,5,0">
                    <StackPanel>
                        <TextBlock Text="Tweaks Tranquille" Style="{StaticResource Text.H3}"/>
                        <TextBlock Style="{StaticResource Text.Secondary}" Margin="0,6,0,16" TextWrapping="Wrap"
                                   Text="Optimisations safe, 100% réversibles. Premier pas idéal."/>
                        <Button Content="Voir les tweaks" Style="{StaticResource Button.Tertiary}"
                                Command="{Binding GoToTweaksCommand}" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource Card.Gold}" Margin="5,0,5,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Configurer ton BIOS" Style="{StaticResource Text.H3}"
                                       Foreground="{StaticResource Brush.Gold.Bright}"/>
                            <Border Style="{StaticResource Badge.Gold}" Margin="10,2,0,0">
                                <TextBlock Text="GROS GAIN" FontSize="9" FontWeight="Bold" Foreground="{StaticResource Brush.Gold.Bright}"/>
                            </Border>
                        </StackPanel>
                        <TextBlock Style="{StaticResource Text.Secondary}" Margin="0,6,0,16" TextWrapping="Wrap"
                                   Text="Là où se cachent les plus gros gains. Guide adapté à ta carte mère."/>
                        <Button Content="Ouvrir le guide BIOS" Style="{StaticResource Button.Primary}"
                                Command="{Binding GoToBiosCommand}" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource Card}" Margin="5,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Mode Gaming" Style="{StaticResource Text.H3}"/>
                        <TextBlock Style="{StaticResource Text.Secondary}" Margin="0,6,0,16" TextWrapping="Wrap"
                                   Text="Détection auto des jeux installés + tweaks par jeu + opti réseau."/>
                        <Button Content="Voir Gaming" Style="{StaticResource Button.Tertiary}"
                                Command="{Binding GoToGamingCommand}" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
