<UserControl x:Class="AurumTweaks.Views.SnapshotView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:AurumTweaks.Views"
             Background="{StaticResource Brush.Bg.Base}">
    <UserControl.Resources>
        <!-- One row per changed tweak: name, the From → To transition, and the bare id (mono) so a power user can
             cross-reference it on the Tweaks page. Shared by every bucket; the danger emphasis lives on the
             regression SECTION, not the row, so rows stay visually consistent. -->
        <DataTemplate x:Key="Snapshot.ChangeRow">
            <Border Style="{StaticResource Card.Compact}" Margin="0,3">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding TweakName}" Style="{StaticResource Text.Body}"
                                   FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,16,0"/>
                        <TextBlock Grid.Column="1" Text="{Binding TransitionLabel}" Style="{StaticResource Text.Muted}"
                                   HorizontalAlignment="Right" VerticalAlignment="Top"/>
                    </Grid>
                    <TextBlock Text="{Binding TweakId}" Style="{StaticResource Text.Mono}" Margin="0,2,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- Scoped dark input styling (the theme doesn't style ComboBox; match the Bench/Ram convention) -->
        <Style x:Key="Snapshot.ComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource Brush.Bg.Elevated}"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Default}"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24,32,32">
            <TextBlock Text="Instantanés système" Style="{StaticResource Text.Display}"/>
            <TextBlock Style="{StaticResource Text.Secondary}" Margin="0,4,0,20" TextWrapping="Wrap"
                       Text="Capture une photo de l'état RÉEL de tous les tweaks du catalogue à un instant T — la même détection sur le système que la page Tweaks (lecture du registre et des services). Plus tard, compare une photo de référence à « maintenant » pour voir ce qui a dérivé : surtout les RÉGRESSIONS, c.-à-d. un tweak qui était confirmé appliqué et qui ne l'est plus (une mise à jour Windows, un autre outil ou un redémarrage l'a annulé). Honnête par construction : un tweak non lisible (commande shell sans relecture) reste « indéterminé » et n'est JAMAIS compté comme une régression — on ne crie pas à la dérive quand on ne peut pas la confirmer. Les instantanés sont stockés localement (%LOCALAPPDATA%\AurumTweaks\Snapshots) et ne sont jamais envoyés nulle part."/>

            <!-- Capture -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Capturer l'état actuel" Style="{StaticResource Text.H3}" Margin="0,0,0,4"/>
                    <TextBlock Style="{StaticResource Text.Muted}" TextWrapping="Wrap" Margin="0,0,0,12"
                               Text="Sonde tout le catalogue et enregistre le résultat comme point de référence. Donne-lui un nom optionnel (ex. « avant MAJ Windows ») pour le retrouver."/>
                    <StackPanel Orientation="Horizontal">
                        <TextBox Width="260" Text="{Binding NewSnapshotLabel, UpdateSourceTrigger=PropertyChanged}"
                                 Background="{StaticResource Brush.Bg.Elevated}"
                                 Foreground="{StaticResource Brush.Text.Primary}"
                                 BorderBrush="{StaticResource Brush.Border.Default}"
                                 Padding="10,6" FontSize="12" VerticalContentAlignment="Center" Margin="0,0,10,0"/>
                        <Button Content="Capturer l'état actuel" Style="{StaticResource Button.Primary}"
                                Command="{Binding CaptureCommand}" Margin="0,0,8,0"/>
                        <Button Content="Actualiser" Style="{StaticResource Button.Secondary}"
                                Command="{Binding ReloadCommand}"/>
                        <Button Content="Importer un instantané…" Style="{StaticResource Button.Secondary}" Margin="8,0,0,0"
                                Command="{Binding ImportSnapshotCommand}"
                                ToolTip="Charge un instantané depuis un fichier .json (un baseline conservé avant une réinstallation, ou partagé par quelqu'un d'autre)."/>
                    </StackPanel>
                    <TextBlock Text="{Binding Status}" Style="{StaticResource Text.Muted}" Margin="0,10,0,0"
                               TextWrapping="Wrap"
                               Visibility="{Binding Status, Converter={StaticResource StringNotEmptyToVisibility}}"/>
                </StackPanel>
            </Border>

            <!-- Compare two SAVED snapshots (historical drift A → B), e.g. « avant MAJ » → « après MAJ ». Reuses the
                 same pure diff and the same panel below; only appears once there are at least two to compare. -->
            <Border Style="{StaticResource Card}" Margin="0,16,0,0"
                    Visibility="{Binding HasMultipleSnapshots, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Text="Comparer deux instantanés sauvegardés" Style="{StaticResource Text.H3}" Margin="0,0,0,4"/>
                    <TextBlock Style="{StaticResource Text.Muted}" TextWrapping="Wrap" Margin="0,0,0,12"
                               Text="Mesure la dérive ENTRE deux photos déjà enregistrées, sans sonder la machine. Purement informatif : la ré-application n'apparaît que pour une comparaison « à maintenant », car elle agit sur l'état actuel du PC."/>
                    <StackPanel Orientation="Horizontal">
                        <ComboBox Width="240" Style="{StaticResource Snapshot.ComboBox}" Margin="0,0,10,0"
                                  ItemsSource="{Binding Snapshots}" SelectedItem="{Binding BaselineA}"
                                  DisplayMemberPath="DisplayLabel"/>
                        <TextBlock Text="→" VerticalAlignment="Center" Margin="0,0,10,0" Style="{StaticResource Text.Secondary}"/>
                        <ComboBox Width="240" Style="{StaticResource Snapshot.ComboBox}" Margin="0,0,10,0"
                                  ItemsSource="{Binding Snapshots}" SelectedItem="{Binding BaselineB}"
                                  DisplayMemberPath="DisplayLabel"/>
                        <Button Content="Comparer" Style="{StaticResource Button.Secondary}"
                                Command="{Binding CompareSavedCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Live comparison: baseline vs now. Visible only after « Comparer à maintenant ». -->
            <Border Style="{StaticResource Card}" Margin="0,16,0,0"
                    Visibility="{Binding HasComparison, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource Text.H3}">
                                <Run Text="Comparaison · "/><Run Text="{Binding ComparisonBaselineLabel, Mode=OneWay}"/><Run Text=" → "/><Run Text="{Binding ComparisonTargetLabel, Mode=OneWay}"/>
                            </TextBlock>
                            <TextBlock Text="{Binding Comparison.Summary, Mode=OneWay}" Style="{StaticResource Text.Secondary}"
                                       Margin="0,4,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                            <!-- Only shown when there is a genuine regression to act on — never a dead button. -->
                            <Button Content="Ré-appliquer les régressions" Style="{StaticResource Button.Primary}" Margin="0,0,8,0"
                                    Command="{Binding ReapplyRegressionsCommand}"
                                    Visibility="{Binding CanReapplyRegressions, Converter={StaticResource BoolToVisibility}}"/>
                            <!-- The capstone: only when there are improvements to UNDO — otherwise « ré-appliquer » above
                                 already does everything and a second button would be a redundant duplicate. -->
                            <Button Content="Aligner sur l'instantané" Style="{StaticResource Button.Secondary}" Margin="0,0,8,0"
                                    Command="{Binding AlignToSnapshotCommand}"
                                    Visibility="{Binding CanAlignToSnapshot, Converter={StaticResource BoolToVisibility}}"
                                    ToolTip="Restaure l'état exact de l'instantané : ré-applique les régressions ET annule les tweaks activés depuis la capture."/>
                            <Button Content="Copier" Style="{StaticResource Button.Secondary}" Margin="0,0,8,0"
                                    Command="{Binding CopyComparisonCommand}"/>
                            <Button Content="Exporter…" Style="{StaticResource Button.Secondary}" Margin="0,0,8,0"
                                    Command="{Binding ExportComparisonCommand}"/>
                            <Button Content="Fermer" Style="{StaticResource Button.Ghost}"
                                    Command="{Binding CloseComparisonCommand}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Same shared safety-net banner as the Tweaks/Profiles pages: « ré-appliquer »/« aligner » mutate
                         the live machine, so the pre-flight posture is shown right where the user commits. Self-hides
                         when all-clear (bound to the SAME shared PreflightBannerViewModel everywhere). -->
                    <views:PreflightBanner DataContext="{Binding Preflight}" Margin="0,12,0,0"/>

                    <!-- Regressions — the load-bearing signal, danger-tinted like the journal's "non confirmé" box. -->
                    <Border Margin="0,14,0,0" CornerRadius="4" Padding="10,8" Background="#1AEF4444"
                            BorderBrush="{StaticResource Brush.Danger}" BorderThickness="1"
                            Visibility="{Binding Comparison.HasRegressions, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource Text.Body}" Foreground="{StaticResource Brush.Danger}"
                                       FontWeight="SemiBold" TextWrapping="Wrap"
                                       Text="Régressions — étaient appliqués, ne le sont plus :"/>
                            <ItemsControl ItemsSource="{Binding Comparison.Regressions}" Margin="0,6,0,0"
                                          ItemTemplate="{StaticResource Snapshot.ChangeRow}"/>
                        </StackPanel>
                    </Border>

                    <!-- Uncertain — honest "can't confirm either way", never folded into regressions. -->
                    <StackPanel Margin="0,14,0,0"
                                Visibility="{Binding Comparison.HasUncertain, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Style="{StaticResource Text.Body}" FontWeight="SemiBold" TextWrapping="Wrap"
                                   Text="Incertains — un état n'a pas pu être relu (non comptés comme régression) :"/>
                        <ItemsControl ItemsSource="{Binding Comparison.Uncertain}" Margin="0,6,0,0"
                                      ItemTemplate="{StaticResource Snapshot.ChangeRow}"/>
                    </StackPanel>

                    <!-- Improvements -->
                    <StackPanel Margin="0,14,0,0"
                                Visibility="{Binding Comparison.HasImprovements, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Style="{StaticResource Text.Body}" FontWeight="SemiBold" TextWrapping="Wrap"
                                   Text="Améliorations — sont appliqués depuis la référence :"/>
                        <ItemsControl ItemsSource="{Binding Comparison.Improvements}" Margin="0,6,0,0"
                                      ItemTemplate="{StaticResource Snapshot.ChangeRow}"/>
                    </StackPanel>

                    <!-- Added / Removed (catalogue changed between the two captures) -->
                    <StackPanel Margin="0,14,0,0"
                                Visibility="{Binding Comparison.HasAdded, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Style="{StaticResource Text.Body}" FontWeight="SemiBold" TextWrapping="Wrap"
                                   Text="Ajoutés au catalogue depuis la référence :"/>
                        <ItemsControl ItemsSource="{Binding Comparison.Added}" Margin="0,6,0,0"
                                      ItemTemplate="{StaticResource Snapshot.ChangeRow}"/>
                    </StackPanel>
                    <StackPanel Margin="0,14,0,0"
                                Visibility="{Binding Comparison.HasRemoved, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Style="{StaticResource Text.Body}" FontWeight="SemiBold" TextWrapping="Wrap"
                                   Text="Retirés du catalogue depuis la référence :"/>
                        <ItemsControl ItemsSource="{Binding Comparison.Removed}" Margin="0,6,0,0"
                                      ItemTemplate="{StaticResource Snapshot.ChangeRow}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Empty state -->
            <Border Style="{StaticResource Card}" Margin="0,16,0,0"
                    Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Style="{StaticResource Text.Secondary}" TextWrapping="Wrap"
                           Text="Aucun instantané pour l'instant. Capture l'état actuel ci-dessus — tu auras un point de référence à comparer après une mise à jour Windows, l'installation d'un pilote ou tout changement susceptible d'annuler tes tweaks."/>
            </Border>

            <!-- Saved snapshots, newest first -->
            <ItemsControl ItemsSource="{Binding Snapshots}" Margin="0,8,0,0"
                          Visibility="{Binding HasSnapshots, Converter={StaticResource BoolToVisibility}}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Card.Compact}" Margin="0,4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DisplayLabel}" Style="{StaticResource Text.Body}" FontWeight="SemiBold"/>
                                    <TextBlock Style="{StaticResource Text.Muted}" Margin="0,2,0,0">
                                        <Run Text="{Binding LocalTimestampLabel, Mode=OneWay}"/><Run Text=" · "/><Run Text="{Binding StateSummaryLabel, Mode=OneWay}"/><Run Text="{Binding CaptureVersionSuffix, Mode=OneWay}"/>
                                    </TextBlock>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Content="Comparer à maintenant" Style="{StaticResource Button.Primary}" Margin="0,0,8,0"
                                            Command="{Binding DataContext.CompareToNowCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                    <!-- Readable-text report (the human-readable counterpart to the .json export): one click to
                                         paste « voici l'état de mes tweaks » on a forum, no capture-twice-and-compare detour. -->
                                    <Button Content="Copier l'état" Style="{StaticResource Button.Secondary}" Margin="0,0,8,0"
                                            Command="{Binding DataContext.CopySnapshotStateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="Copie l'état des tweaks (appliqués / non / indéterminés) en texte lisible, à coller sur un forum ou Discord."/>
                                    <Button Content="Exporter l'état…" Style="{StaticResource Button.Tertiary}" Margin="0,0,8,0"
                                            Command="{Binding DataContext.ExportSnapshotStateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="Enregistre l'état en fichier texte (.txt) lisible."/>
                                    <Button Content="Exporter…" Style="{StaticResource Button.Secondary}" Margin="0,0,8,0"
                                            Command="{Binding DataContext.ExportSnapshotCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="Enregistre l'instantané en fichier .json ré-importable (sauvegarde avant réinstallation, ou à partager)."/>
                                    <Button Content="Supprimer" Style="{StaticResource Button.Danger}"
                                            Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
