<UserControl x:Class="AurumTweaks.Views.TweaksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:AurumTweaks.Views"
             Background="{StaticResource Brush.Bg.Base}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="32,24,32,12">
            <TextBlock Text="Tweaks Windows" Style="{StaticResource Text.Display}"/>
            <TextBlock Text="Catalogue JSON, niveaux et matrice anti-cheat. Chaque tweak est documenté et réversible."
                       Style="{StaticResource Text.Secondary}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Filters -->
        <Border Grid.Row="1" Margin="32,0,32,12" Style="{StaticResource Card.Compact}">
            <StackPanel Orientation="Horizontal">
                <TextBox Width="260" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Background="{StaticResource Brush.Bg.Elevated}"
                         Foreground="{StaticResource Brush.Text.Primary}"
                         BorderBrush="{StaticResource Brush.Border.Default}"
                         Padding="10,6" FontSize="12"
                         VerticalContentAlignment="Center"
                         Margin="0,0,10,0"/>
                <ComboBox Width="140" ItemsSource="{Binding AllTiers}"
                          SelectedItem="{Binding SelectedTier}"
                          Background="{StaticResource Brush.Bg.Elevated}"
                          Foreground="{StaticResource Brush.Text.Primary}"
                          Margin="0,0,10,0"/>
                <ComboBox Width="200" ItemsSource="{Binding AllCategories}"
                          SelectedItem="{Binding SelectedCategory}"
                          Background="{StaticResource Brush.Bg.Elevated}"
                          Foreground="{StaticResource Brush.Text.Primary}"
                          Margin="0,0,10,0"/>
                <CheckBox Style="{StaticResource Toggle.Aurum}"
                          IsChecked="{Binding CompetitiveSafeOnly}"
                          VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="Compétitif sécurisé (anti-cheat safe)"
                           VerticalAlignment="Center"
                           Style="{StaticResource Text.Secondary}"/>
            </StackPanel>
        </Border>

        <!-- Tweaks list -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="32,0,32,0">
            <ItemsControl ItemsSource="{Binding TweaksView}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Card}"
                                Background="{Binding Tier, Converter={StaticResource TierToBackground}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" Style="{StaticResource Toggle.Aurum}"
                                          IsChecked="{Binding IsSelected}"
                                          VerticalAlignment="Top" Margin="0,4,16,0"/>
                                <StackPanel Grid.Column="1">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Id}" Style="{StaticResource Text.H3}" Margin="0,0,10,0"/>
                                        <Border CornerRadius="999" Padding="6,2" BorderThickness="1"
                                                BorderBrush="{Binding Tier, Converter={StaticResource TierToBrush}}"
                                                Background="{Binding Tier, Converter={StaticResource TierToBackground}}">
                                            <TextBlock Text="{Binding Tier}" FontSize="9" FontWeight="Bold"
                                                       Foreground="{Binding Tier, Converter={StaticResource TierToBrush}}"/>
                                        </Border>
                                        <Border Style="{StaticResource Badge.Extreme}" Margin="6,0,0,0"
                                                Visibility="{Binding AntiCheat, Converter={StaticResource AcHasConcern}, ConverterParameter=Visible}">
                                            <TextBlock Text="AC RISK" FontSize="9" FontWeight="Bold" Foreground="{StaticResource Brush.Danger}"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="{Binding ExpectedImpact}" Style="{StaticResource Text.Secondary}" Margin="0,6,0,0"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <TextBlock Text="Catégorie : " Style="{StaticResource Text.Muted}"/>
                                        <TextBlock Text="{Binding Category}" Style="{StaticResource Text.Mono}" Margin="0,0,16,0"/>
                                        <TextBlock Text="Risque : " Style="{StaticResource Text.Muted}"/>
                                        <TextBlock Text="{Binding Risk, Converter={StaticResource RiskToLabel}}" Style="{StaticResource Text.Mono}" Margin="0,0,16,0"/>
                                        <TextBlock Text="Réversible : " Style="{StaticResource Text.Muted}"/>
                                        <TextBlock Text="{Binding Reversible}" Style="{StaticResource Text.Mono}"/>
                                    </StackPanel>

                                    <!-- Honesty: the exact registry keys / services / commands this tweak runs,
                                         derived from the live operation list (never a hand-written paraphrase). -->
                                    <Expander Margin="0,12,0,0" Foreground="{StaticResource Brush.Text.Secondary}">
                                        <Expander.Header>
                                            <TextBlock FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource Brush.Text.Secondary}">
                                                <Run Text="Détails techniques · ce que ça change ("/><Run Text="{Binding Operations.Count, Mode=OneWay}"/><Run Text=" op.)"/>
                                            </TextBlock>
                                        </Expander.Header>
                                        <ItemsControl ItemsSource="{Binding OperationSummaries}" Margin="0,8,0,2">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{StaticResource Brush.Bg.Elevated}"
                                                            BorderBrush="{StaticResource Brush.Border.Default}" BorderThickness="1"
                                                            CornerRadius="6" Padding="10,7" Margin="0,0,0,6">
                                                        <StackPanel>
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <Border Grid.Column="0" CornerRadius="4" Padding="5,1" Margin="0,0,8,0"
                                                                        VerticalAlignment="Top"
                                                                        Background="{StaticResource Brush.Bg.Panel}"
                                                                        BorderBrush="{StaticResource Brush.Border.Default}" BorderThickness="1">
                                                                    <TextBlock Text="{Binding Kind}" FontSize="9" FontWeight="Bold"
                                                                               Foreground="{StaticResource Brush.Gold}"/>
                                                                </Border>
                                                                <TextBlock Grid.Column="1" Text="{Binding Target}" Style="{StaticResource Text.Mono}"
                                                                           TextWrapping="Wrap" VerticalAlignment="Top"
                                                                           Visibility="{Binding Target, Converter={StaticResource StringNotEmptyToVisibility}}"/>
                                                            </Grid>
                                                            <Grid Margin="0,5,0,0"
                                                                  Visibility="{Binding Apply, Converter={StaticResource StringNotEmptyToVisibility}}">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0" Text="Appliquer : " Style="{StaticResource Text.Muted}" VerticalAlignment="Top"/>
                                                                <TextBlock Grid.Column="1" Text="{Binding Apply}" Style="{StaticResource Text.Mono}" TextWrapping="Wrap"/>
                                                            </Grid>
                                                            <Grid Margin="0,2,0,0">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0" Text="Rétablir : " Style="{StaticResource Text.Muted}" VerticalAlignment="Top"/>
                                                                <TextBlock Grid.Column="1" Text="{Binding Revert}" Style="{StaticResource Text.Mono}" TextWrapping="Wrap"/>
                                                            </Grid>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Expander>
                                </StackPanel>
                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <TextBlock Text="✓ Appliqué" Style="{StaticResource Text.Gold}"
                                               Visibility="{Binding IsApplied, Converter={StaticResource BoolToVisibility}}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Footer actions -->
        <Border Grid.Row="3" BorderBrush="{StaticResource Brush.Border.Default}"
                BorderThickness="0,1,0,0"
                Background="{StaticResource Brush.Bg.Panel}"
                Padding="32,14">
            <StackPanel>
                <!-- Bulk-selection tools. "Visibles" / "Non appliqués" / "Inverser" all scope to the FILTERED set
                     (reusing the list's own predicate), so with "anti-cheat safe" on a ban-risk tweak stays hidden
                     and can never be silently armed; "Tout effacer" clears everything, including ticks hidden by a
                     filter, so a later apply never runs a tweak the view can't show. -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="Sélection :" VerticalAlignment="Center"
                               Style="{StaticResource Text.Muted}" Margin="0,0,10,0"/>
                    <Button Content="Tous les visibles" Style="{StaticResource Button.Ghost}"
                            Command="{Binding SelectAllVisibleCommand}" Margin="0,0,8,0"
                            ToolTip="Coche tous les tweaks actuellement affichés par les filtres."/>
                    <Button Content="Non appliqués" Style="{StaticResource Button.Ghost}"
                            Command="{Binding SelectUnappliedVisibleCommand}" Margin="0,0,8,0"
                            ToolTip="Coche les tweaks visibles que le système ne détecte pas comme appliqués."/>
                    <Button Content="Inverser" Style="{StaticResource Button.Ghost}"
                            Command="{Binding InvertVisibleSelectionCommand}" Margin="0,0,8,0"
                            ToolTip="Inverse la sélection des tweaks visibles."/>
                    <Button Content="Tout effacer" Style="{StaticResource Button.Ghost}"
                            Command="{Binding ClearSelectionCommand}"
                            ToolTip="Décoche tout, y compris les tweaks masqués par un filtre."/>
                </StackPanel>

                <!-- Pre-flight safety check (shared control): the safety-net posture BEFORE applying, so the page is
                     « testable sans peur ». Self-collapsing when all-clear; bound to the shared PreflightBannerViewModel
                     so this page and the dashboard's one-click apply forecast the same restore-point abort. -->
                <views:PreflightBanner DataContext="{Binding Preflight}"/>

                <StackPanel Orientation="Horizontal">
                    <Button Content="Aperçu / dry-run" Style="{StaticResource Button.Primary}"
                            Command="{Binding PreviewPlanCommand}" Margin="0,0,10,0"/>
                    <Button Content="Appliquer la sélection" Style="{StaticResource Button.Secondary}"
                            Command="{Binding ApplySelectedCommand}" Margin="0,0,10,0"/>
                    <Button Content="Tout restaurer" Style="{StaticResource Button.Danger}"
                            Command="{Binding RevertAllCommand}" Margin="0,0,10,0"/>
                    <Button Content="Rafraîchir l'état" Style="{StaticResource Button.Secondary}"
                            Command="{Binding RefreshStateCommand}"/>
                    <TextBlock VerticalAlignment="Center" Margin="20,0,0,0" Style="{StaticResource Text.Muted}">
                        <Run Text="{Binding AppliedCount, Mode=OneWay}"/>
                        <Run Text="appliqués ·"/>
                        <Run Text="{Binding SelectedCount, Mode=OneWay}"/>
                        <Run Text="sélectionnés"/>
                    </TextBlock>
                    <TextBlock VerticalAlignment="Center" Margin="16,0,0,0"
                               Style="{StaticResource Text.Secondary}"
                               Text="{Binding StatusMessage, Mode=OneWay}"/>
                </StackPanel>

                <!-- Post-apply verification: tweaks the engine reported applied but that the live machine does NOT
                     read back as active. Shown only when real (HasUnconfirmed) — an honest "couldn't confirm",
                     never a fabricated ✓. Sits in the footer (outside the plan overlay) so it persists after apply. -->
                <Border Margin="0,12,0,0" CornerRadius="6" Padding="10,8" Background="#1AEF4444"
                        BorderBrush="{StaticResource Brush.Danger}" BorderThickness="1"
                        Visibility="{Binding HasUnconfirmed, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource Text.Secondary}" Foreground="{StaticResource Brush.Danger}"
                                   FontWeight="Bold" TextWrapping="Wrap"
                                   Text="⚠ Vérification après application : ces tweaks ont été appliqués, mais à la relecture la valeur diffère de l'état attendu. Un redémarrage peut être requis, ou l'opération n'a pas pris."/>
                        <TextBlock Style="{StaticResource Text.Mono}" TextWrapping="Wrap" Margin="0,4,0,0"
                                   Text="{Binding LastVerification.UnconfirmedLabel, Mode=OneWay}"/>
                    </StackPanel>
                </Border>

                <!-- Post-revert verification: the honest mirror of the apply banner above. After "Tout restaurer" we
                     re-read the machine and surface any tweak the engine reported reverted that is STILL active live
                     (a group policy re-applies it, another tool re-wrote it, a protected value). Shown only when real
                     (HasStillActiveAfterRevert) — never a fabricated "tout restauré" over changes still on the machine. -->
                <Border Margin="0,12,0,0" CornerRadius="6" Padding="10,8" Background="#1AEF4444"
                        BorderBrush="{StaticResource Brush.Danger}" BorderThickness="1"
                        Visibility="{Binding HasStillActiveAfterRevert, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource Text.Secondary}" Foreground="{StaticResource Brush.Danger}"
                                   FontWeight="Bold" TextWrapping="Wrap"
                                   Text="⚠ Vérification après restauration : ces tweaks ont été restaurés selon le moteur, mais à la relecture ils sont toujours actifs. Un redémarrage peut être requis, ou une stratégie de groupe / un autre outil les réapplique."/>
                        <TextBlock Style="{StaticResource Text.Mono}" TextWrapping="Wrap" Margin="0,4,0,0"
                                   Text="{Binding LastRevertVerification.UnconfirmedLabel, Mode=OneWay}"/>
                    </StackPanel>
                </Border>

                <!-- Edit-a-profile mode notice: shown only while a saved profile is loaded for editing
                     (VM.IsEditingProfile). It exists for honesty — edit mode is armed on this singleton VM, so
                     without a visible, dismissable banner a later « Enregistrer le profil » could silently overwrite
                     a forgotten profile. Gold-accented to read as an active mode, not an error. -->
                <Border Style="{StaticResource Card.Compact}" Margin="0,12,0,0"
                        Visibility="{Binding IsEditingProfile, Converter={StaticResource BoolToVisibility}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding EditingProfileBanner}" TextWrapping="Wrap"
                                   VerticalAlignment="Center" FontWeight="SemiBold"
                                   Style="{StaticResource Text.Secondary}"
                                   Foreground="{StaticResource Brush.Gold}"/>
                        <Button Grid.Column="1" Content="Annuler l'édition" Style="{StaticResource Button.Ghost}"
                                Margin="12,0,0,0" VerticalAlignment="Center"
                                Command="{Binding CancelEditingProfileCommand}"/>
                    </Grid>
                </Border>

                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                    <TextBlock Text="Enregistrer la sélection comme profil :" VerticalAlignment="Center"
                               Style="{StaticResource Text.Muted}" Margin="0,0,10,0"/>
                    <TextBox Width="220" Text="{Binding NewProfileName, UpdateSourceTrigger=PropertyChanged}"
                             Background="{StaticResource Brush.Bg.Elevated}"
                             Foreground="{StaticResource Brush.Text.Primary}"
                             BorderBrush="{StaticResource Brush.Border.Default}"
                             Padding="10,6" FontSize="12" VerticalContentAlignment="Center" Margin="0,0,10,0"/>
                    <Button Content="Enregistrer le profil" Style="{StaticResource Button.Secondary}"
                            Command="{Binding SaveSelectionAsProfileCommand}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Apply-plan preview: informed consent before a batch of as-admin changes. Lists every operation
             that will run (reusing the per-tweak summarizer), tallied and with honest reboot/irreversibility
             notes. The scrim is hit-testable so the page beneath is inert until the user chooses. -->
        <Border Grid.RowSpan="4" Background="#B8000000"
                Visibility="{Binding IsPlanVisible, Converter={StaticResource BoolToVisibility}}">
            <Border Style="{StaticResource Card}" MaxWidth="780" MaxHeight="660"
                    Background="{StaticResource Brush.Bg.Panel}"
                    VerticalAlignment="Center" HorizontalAlignment="Center" Margin="24">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Plan de modifications" Style="{StaticResource Text.H2}"/>
                    <TextBlock Grid.Row="1" Style="{StaticResource Text.Secondary}" Margin="0,4,0,0">
                        <Run Text="Tout ce qui sera modifié sur le système ·"/>
                        <Run Text="{Binding CurrentPlan.TweakCount, Mode=OneWay}"/>
                        <Run Text="tweak(s),"/>
                        <Run Text="{Binding CurrentPlan.TotalOperations, Mode=OneWay}"/>
                        <Run Text="opération(s)"/>
                    </TextBlock>

                    <StackPanel Grid.Row="2" Margin="0,12,0,0">
                        <ItemsControl ItemsSource="{Binding CurrentPlan.CountsByKind}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="4" Padding="7,2" Margin="0,0,6,6"
                                            Background="{StaticResource Brush.Bg.Elevated}"
                                            BorderBrush="{StaticResource Brush.Border.Default}" BorderThickness="1">
                                        <TextBlock FontSize="11" Foreground="{StaticResource Brush.Text.Secondary}">
                                            <Run Text="{Binding Kind, Mode=OneWay}" FontWeight="Bold" Foreground="{StaticResource Brush.Gold}"/>
                                            <Run Text=" ×"/>
                                            <Run Text="{Binding Count, Mode=OneWay}"/>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Margin="0,6,0,0" Style="{StaticResource Text.Secondary}"
                                   Foreground="{StaticResource Brush.Gold}"
                                   Visibility="{Binding CurrentPlan.RequiresReboot, Converter={StaticResource BoolToVisibility}}"
                                   Text="↻ Un redémarrage sera nécessaire pour appliquer entièrement certains tweaks."/>
                        <TextBlock Margin="0,2,0,0" Style="{StaticResource Text.Secondary}"
                                   Foreground="{StaticResource Brush.Danger}"
                                   Visibility="{Binding CurrentPlan.HasIrreversible, Converter={StaticResource BoolToVisibility}}"
                                   TextWrapping="Wrap"><Run Text="⚠ "/><Run Text="{Binding CurrentPlan.IrreversibleCount, Mode=OneWay}"/><Run Text=" opération(s) ne sont pas réversibles automatiquement — repérées en rouge ci-dessous."/></TextBlock>
                        <TextBlock Margin="0,2,0,0" Style="{StaticResource Text.Muted}"
                                   Text="Un point de restauration est créé avant l'application si l'option est activée dans les Réglages."/>
                        <TextBlock Margin="0,2,0,0" Style="{StaticResource Text.Muted}" TextWrapping="Wrap"
                                   Text="Aperçu en lecture seule : le Registre et les services sont lus pour afficher l'état actuel, mais aucune écriture n'est faite avant « Appliquer maintenant ». Une ligne « absent(e) ou non lisible » indique la limite exacte de lecture Windows."/>

                        <!-- Selection conflicts: two+ selected tweaks set the SAME registry value / service to
                             DIFFERENT values, so apply order silently decides the winner. Shown only when real
                             (HasConflicts) — it informs, it never blocks the apply. -->
                        <Border Margin="0,10,0,0" CornerRadius="6" Padding="10,8" Background="#1AEF4444"
                                BorderBrush="{StaticResource Brush.Danger}" BorderThickness="1"
                                Visibility="{Binding HasConflicts, Converter={StaticResource BoolToVisibility}}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource Text.Secondary}" Foreground="{StaticResource Brush.Danger}"
                                           FontWeight="Bold" TextWrapping="Wrap"
                                           Text="⚠ Conflits de sélection : plusieurs tweaks modifient le même réglage avec des valeurs différentes — l'ordre d'application décide silencieusement du gagnant."/>
                                <ScrollViewer MaxHeight="150" VerticalScrollBarVisibility="Auto" Margin="0,6,0,0">
                                    <ItemsControl ItemsSource="{Binding CurrentConflicts}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="0,0,0,6">
                                                    <TextBlock Style="{StaticResource Text.Mono}" TextWrapping="Wrap">
                                                        <Run Text="{Binding Kind, Mode=OneWay}" FontWeight="Bold" Foreground="{StaticResource Brush.Gold}"/>
                                                        <Run Text=" "/>
                                                        <Run Text="{Binding Target, Mode=OneWay}"/>
                                                    </TextBlock>
                                                    <ItemsControl ItemsSource="{Binding Values}" Margin="12,2,0,0">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Grid Margin="0,1,0,0">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Grid.Column="0" Style="{StaticResource Text.Mono}"
                                                                               VerticalAlignment="Top" Text="{Binding Value, Mode=OneWay}"/>
                                                                    <TextBlock Grid.Column="1" Style="{StaticResource Text.Muted}" Margin="8,0,0,0"
                                                                               TextWrapping="Wrap" VerticalAlignment="Top">
                                                                        <Run Text="←"/>
                                                                        <Run Text="{Binding TweakIdsLabel, Mode=OneWay}"/>
                                                                    </TextBlock>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" Margin="0,12,0,0">
                        <ItemsControl ItemsSource="{Binding CurrentPlan.Operations}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource Brush.Bg.Elevated}"
                                            BorderBrush="{StaticResource Brush.Border.Default}" BorderThickness="1"
                                            CornerRadius="6" Padding="10,7" Margin="0,0,0,6">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" CornerRadius="4" Padding="5,1" Margin="0,0,8,0" VerticalAlignment="Top"
                                                        Background="{StaticResource Brush.Bg.Panel}"
                                                        BorderBrush="{StaticResource Brush.Border.Default}" BorderThickness="1">
                                                    <TextBlock Text="{Binding Delta.Kind}" FontSize="9" FontWeight="Bold"
                                                               Foreground="{StaticResource Brush.Gold}"/>
                                                </Border>
                                                <TextBlock Grid.Column="1" Text="{Binding Delta.Target}" Style="{StaticResource Text.Mono}"
                                                           TextWrapping="Wrap" VerticalAlignment="Top"
                                                           Visibility="{Binding Delta.Target, Converter={StaticResource StringNotEmptyToVisibility}}"/>
                                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top" Margin="8,0,0,0">
                                                    <TextBlock Text="{Binding Delta.StatusLabel}" Style="{StaticResource Text.Muted}" Margin="0,0,8,0"/>
                                                    <TextBlock Text="{Binding TweakId}" Style="{StaticResource Text.Muted}"/>
                                                </StackPanel>
                                            </Grid>
                                            <Grid Margin="0,5,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Actuel : " Style="{StaticResource Text.Muted}" VerticalAlignment="Top"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Delta.Current}" Style="{StaticResource Text.Mono}" TextWrapping="Wrap"/>
                                            </Grid>
                                            <Grid Margin="0,5,0,0"
                                                  Visibility="{Binding Delta.Apply, Converter={StaticResource StringNotEmptyToVisibility}}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Appliquer : " Style="{StaticResource Text.Muted}" VerticalAlignment="Top"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Delta.Apply}" Style="{StaticResource Text.Mono}" TextWrapping="Wrap"/>
                                            </Grid>
                                            <Grid Margin="0,2,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Rétablir : " Style="{StaticResource Text.Muted}" VerticalAlignment="Top"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Delta.Revert}" TextWrapping="Wrap">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock" BasedOn="{StaticResource Text.Mono}">
                                                            <Style.Triggers>
                                                                <!-- The one op-kind the reversible-by-promise engine can't auto-undo: mark it, so the
                                                                     red count above maps to visible rows the user can scan. Bound to the per-op flag
                                                                     (not the sentinel string) so the marker and the count share one definition. -->
                                                                <DataTrigger Binding="{Binding IsIrreversible}" Value="True">
                                                                    <Setter Property="Foreground" Value="{StaticResource Brush.Danger}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                        <Button Content="Fermer" Style="{StaticResource Button.Secondary}"
                                Command="{Binding ClosePlanCommand}" Margin="0,0,10,0"/>
                        <Button Content="Appliquer maintenant" Style="{StaticResource Button.Primary}"
                                Command="{Binding ConfirmPlanCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>
