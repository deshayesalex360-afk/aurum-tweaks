<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ============================================================
         AURUM TWEAKS — LINEAR.APP-INSPIRED DEEP DARK + MARBLE GOLD
         Refined typography, sharper geometry, organic marble signature.
         ============================================================ -->

    <!-- Base surfaces (Linear-deep) -->
    <Color x:Key="Color.Bg.Base">#FF08080A</Color>
    <Color x:Key="Color.Bg.Panel">#FF0F0F12</Color>
    <Color x:Key="Color.Bg.Card">#FF131318</Color>
    <Color x:Key="Color.Bg.CardHover">#FF1A1A22</Color>
    <Color x:Key="Color.Bg.Elevated">#FF1F1F28</Color>
    <Color x:Key="Color.Bg.Sidebar">#FF0A0A0D</Color>
    <Color x:Key="Color.Bg.TitleBar">#FF08080A</Color>

    <!-- Borders (very subtle — Linear style) -->
    <Color x:Key="Color.Border.Subtle">#FF15151B</Color>
    <Color x:Key="Color.Border.Default">#FF22222B</Color>
    <Color x:Key="Color.Border.Strong">#FF323240</Color>
    <Color x:Key="Color.Border.Focus">#FFD4AF37</Color>

    <!-- Gold (signature) -->
    <Color x:Key="Color.Gold">#FFD4AF37</Color>
    <Color x:Key="Color.Gold.Bright">#FFF5D77E</Color>
    <Color x:Key="Color.Gold.Pale">#FFE8C66B</Color>
    <Color x:Key="Color.Gold.Deep">#FFB8941F</Color>
    <Color x:Key="Color.Gold.Glow">#66D4AF37</Color>
    <Color x:Key="Color.Gold.Subtle">#22D4AF37</Color>
    <Color x:Key="Color.Gold.Whisper">#0DD4AF37</Color>

    <!-- Marble vein colors -->
    <Color x:Key="Color.Marble.Base">#FF0C0C10</Color>
    <Color x:Key="Color.Marble.Deep">#FF050507</Color>
    <Color x:Key="Color.Marble.VeinGold">#FFD4AF37</Color>
    <Color x:Key="Color.Marble.VeinPale">#33F5E5B8</Color>
    <Color x:Key="Color.Marble.Highlight">#1AFFFFFF</Color>

    <!-- Text -->
    <Color x:Key="Color.Text.Primary">#FFF7F7F9</Color>
    <Color x:Key="Color.Text.Secondary">#FF9999A5</Color>
    <Color x:Key="Color.Text.Muted">#FF606069</Color>
    <Color x:Key="Color.Text.Faint">#FF404049</Color>
    <Color x:Key="Color.Text.OnGold">#FF08080A</Color>

    <!-- Status (Linear-style muted) -->
    <Color x:Key="Color.Success">#FF22C55E</Color>
    <Color x:Key="Color.Warning">#FFEAB308</Color>
    <Color x:Key="Color.Danger">#FFEF4444</Color>
    <Color x:Key="Color.Info">#FF3B82F6</Color>

    <!-- Tweak tier accents -->
    <Color x:Key="Color.Tier.Tranquille">#FF22C55E</Color>
    <Color x:Key="Color.Tier.Avance">#FFEAB308</Color>
    <Color x:Key="Color.Tier.Extreme">#FFEF4444</Color>

    <!-- ============================================================
         BRUSHES
         ============================================================ -->

    <SolidColorBrush x:Key="Brush.Bg.Base" Color="{StaticResource Color.Bg.Base}"/>
    <SolidColorBrush x:Key="Brush.Bg.Panel" Color="{StaticResource Color.Bg.Panel}"/>
    <SolidColorBrush x:Key="Brush.Bg.Card" Color="{StaticResource Color.Bg.Card}"/>
    <SolidColorBrush x:Key="Brush.Bg.CardHover" Color="{StaticResource Color.Bg.CardHover}"/>
    <SolidColorBrush x:Key="Brush.Bg.Elevated" Color="{StaticResource Color.Bg.Elevated}"/>
    <SolidColorBrush x:Key="Brush.Bg.Sidebar" Color="{StaticResource Color.Bg.Sidebar}"/>
    <SolidColorBrush x:Key="Brush.Bg.TitleBar" Color="{StaticResource Color.Bg.TitleBar}"/>

    <SolidColorBrush x:Key="Brush.Border.Subtle" Color="{StaticResource Color.Border.Subtle}"/>
    <SolidColorBrush x:Key="Brush.Border.Default" Color="{StaticResource Color.Border.Default}"/>
    <SolidColorBrush x:Key="Brush.Border.Strong" Color="{StaticResource Color.Border.Strong}"/>
    <SolidColorBrush x:Key="Brush.Border.Focus" Color="{StaticResource Color.Border.Focus}"/>

    <SolidColorBrush x:Key="Brush.Gold" Color="{StaticResource Color.Gold}"/>
    <SolidColorBrush x:Key="Brush.Gold.Bright" Color="{StaticResource Color.Gold.Bright}"/>
    <SolidColorBrush x:Key="Brush.Gold.Pale" Color="{StaticResource Color.Gold.Pale}"/>
    <SolidColorBrush x:Key="Brush.Gold.Deep" Color="{StaticResource Color.Gold.Deep}"/>
    <SolidColorBrush x:Key="Brush.Gold.Subtle" Color="{StaticResource Color.Gold.Subtle}"/>
    <SolidColorBrush x:Key="Brush.Gold.Whisper" Color="{StaticResource Color.Gold.Whisper}"/>

    <SolidColorBrush x:Key="Brush.Text.Primary" Color="{StaticResource Color.Text.Primary}"/>
    <SolidColorBrush x:Key="Brush.Text.Secondary" Color="{StaticResource Color.Text.Secondary}"/>
    <SolidColorBrush x:Key="Brush.Text.Muted" Color="{StaticResource Color.Text.Muted}"/>
    <SolidColorBrush x:Key="Brush.Text.Faint" Color="{StaticResource Color.Text.Faint}"/>
    <SolidColorBrush x:Key="Brush.Text.OnGold" Color="{StaticResource Color.Text.OnGold}"/>

    <SolidColorBrush x:Key="Brush.Success" Color="{StaticResource Color.Success}"/>
    <SolidColorBrush x:Key="Brush.Warning" Color="{StaticResource Color.Warning}"/>
    <SolidColorBrush x:Key="Brush.Danger" Color="{StaticResource Color.Danger}"/>
    <SolidColorBrush x:Key="Brush.Info" Color="{StaticResource Color.Info}"/>

    <SolidColorBrush x:Key="Brush.Tier.Tranquille" Color="{StaticResource Color.Tier.Tranquille}"/>
    <SolidColorBrush x:Key="Brush.Tier.Avance" Color="{StaticResource Color.Tier.Avance}"/>
    <SolidColorBrush x:Key="Brush.Tier.Extreme" Color="{StaticResource Color.Tier.Extreme}"/>

    <!-- Gold gradient (used on primary CTAs and logo accents) -->
    <LinearGradientBrush x:Key="Brush.Gold.Gradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource Color.Gold.Bright}" Offset="0"/>
        <GradientStop Color="{StaticResource Color.Gold}" Offset="0.5"/>
        <GradientStop Color="{StaticResource Color.Gold.Deep}" Offset="1"/>
    </LinearGradientBrush>

    <!-- Card gradient — Linear-style very subtle elevation -->
    <LinearGradientBrush x:Key="Brush.Card.Gradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF161620" Offset="0"/>
        <GradientStop Color="#FF11111A" Offset="1"/>
    </LinearGradientBrush>

    <!-- Sidebar gradient (deeper than base, marble will overlay) -->
    <LinearGradientBrush x:Key="Brush.Sidebar.Gradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF0A0A0D" Offset="0"/>
        <GradientStop Color="#FF06060A" Offset="1"/>
    </LinearGradientBrush>

    <!-- Glow brush (Linear's signature subtle gold halo) -->
    <RadialGradientBrush x:Key="Brush.Glow.Gold" Center="0.5,0.5" GradientOrigin="0.5,0.5" RadiusX="0.6" RadiusY="0.6">
        <GradientStop Color="#33D4AF37" Offset="0"/>
        <GradientStop Color="#00D4AF37" Offset="1"/>
    </RadialGradientBrush>

    <!-- ============================================================
         TYPOGRAPHY (Linear-inspired tight, refined)
         ============================================================ -->

    <FontFamily x:Key="Font.Display">Segoe UI Variable Display, Segoe UI, Inter, sans-serif</FontFamily>
    <FontFamily x:Key="Font.Body">Segoe UI Variable Text, Segoe UI, Inter, sans-serif</FontFamily>
    <FontFamily x:Key="Font.Mono">Cascadia Mono, Consolas, monospace</FontFamily>

    <sys:Double x:Key="FontSize.Hero">44</sys:Double>
    <sys:Double x:Key="FontSize.Display">30</sys:Double>
    <sys:Double x:Key="FontSize.H1">22</sys:Double>
    <sys:Double x:Key="FontSize.H2">17</sys:Double>
    <sys:Double x:Key="FontSize.H3">14</sys:Double>
    <sys:Double x:Key="FontSize.Body">13</sys:Double>
    <sys:Double x:Key="FontSize.Small">12</sys:Double>
    <sys:Double x:Key="FontSize.Tiny">11</sys:Double>
    <sys:Double x:Key="FontSize.Micro">10</sys:Double>

    <!-- ============================================================
         GEOMETRY (Linear's sharper corners + tight spacing)
         ============================================================ -->

    <Thickness x:Key="Padding.Card">18</Thickness>
    <Thickness x:Key="Padding.Card.Compact">12</Thickness>
    <Thickness x:Key="Padding.Card.Hero">28</Thickness>
    <CornerRadius x:Key="Radius.Card">6</CornerRadius>
    <CornerRadius x:Key="Radius.Card.Small">4</CornerRadius>
    <CornerRadius x:Key="Radius.Pill">999</CornerRadius>
    <CornerRadius x:Key="Radius.Btn">5</CornerRadius>

</ResourceDictionary>
