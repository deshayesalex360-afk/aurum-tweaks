<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="Text.Display" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Display}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSize.Display}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}"/>
    </Style>

    <Style x:Key="Text.H1" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Display}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSize.H1}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}"/>
    </Style>

    <Style x:Key="Text.H2" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Display}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSize.H2}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}"/>
    </Style>

    <Style x:Key="Text.H3" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Display}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSize.H3}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}"/>
    </Style>

    <Style x:Key="Text.Body" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Body}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSize.Body}"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="Text.Secondary" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Body}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSize.Body}"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="Text.Muted" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Body}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSize.Small}"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Muted}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="Text.Label" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Body}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSize.Small}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}"/>
        <Setter Property="LineHeight" Value="14"/>
    </Style>

    <Style x:Key="Text.Mono" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Mono}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSize.Small}"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}"/>
    </Style>

    <Style x:Key="Text.Gold" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Display}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSize.Body}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.Gold}"/>
    </Style>

</ResourceDictionary>
