<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Standard Linear-style card — flat, subtle border, no gradient -->
    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Brush.Bg.Card}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Default}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="18"/>
        <Setter Property="Margin" Value="0,0,0,10"/>
    </Style>

    <Style x:Key="Card.Compact" TargetType="Border" BasedOn="{StaticResource Card}">
        <Setter Property="Padding" Value="12"/>
        <Setter Property="Margin" Value="0,0,0,6"/>
    </Style>

    <Style x:Key="Card.Hero" TargetType="Border" BasedOn="{StaticResource Card}">
        <Setter Property="Padding" Value="28"/>
        <Setter Property="Margin" Value="0,0,0,16"/>
    </Style>

    <Style x:Key="Card.Gold" TargetType="Border" BasedOn="{StaticResource Card}">
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Gold}"/>
        <Setter Property="Background" Value="#0DD4AF37"/>
    </Style>

    <Style x:Key="Card.Subtle" TargetType="Border" BasedOn="{StaticResource Card}">
        <Setter Property="Background" Value="{StaticResource Brush.Bg.Panel}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}"/>
    </Style>

    <!-- Metric card (KPI tile) - tighter for live data display -->
    <Style x:Key="Card.Metric" TargetType="Border" BasedOn="{StaticResource Card}">
        <Setter Property="Padding" Value="16"/>
        <Setter Property="MinHeight" Value="108"/>
    </Style>

    <!-- Pill badge -->
    <Style x:Key="Badge" TargetType="Border">
        <Setter Property="CornerRadius" Value="999"/>
        <Setter Property="Padding" Value="8,3"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style x:Key="Badge.Tranquille" TargetType="Border" BasedOn="{StaticResource Badge}">
        <Setter Property="Background" Value="#1422C55E"/>
        <Setter Property="BorderBrush" Value="#5522C55E"/>
    </Style>

    <Style x:Key="Badge.Avance" TargetType="Border" BasedOn="{StaticResource Badge}">
        <Setter Property="Background" Value="#14EAB308"/>
        <Setter Property="BorderBrush" Value="#55EAB308"/>
    </Style>

    <Style x:Key="Badge.Extreme" TargetType="Border" BasedOn="{StaticResource Badge}">
        <Setter Property="Background" Value="#14EF4444"/>
        <Setter Property="BorderBrush" Value="#55EF4444"/>
    </Style>

    <Style x:Key="Badge.Gold" TargetType="Border" BasedOn="{StaticResource Badge}">
        <Setter Property="Background" Value="{StaticResource Brush.Gold.Subtle}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Gold}"/>
    </Style>

    <Style x:Key="Badge.Subtle" TargetType="Border" BasedOn="{StaticResource Badge}">
        <Setter Property="Background" Value="{StaticResource Brush.Bg.Elevated}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Default}"/>
    </Style>

</ResourceDictionary>
