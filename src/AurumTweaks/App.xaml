<Application x:Class="AurumTweaks.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:AurumTweaks.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Themes/AurumDarkGold.xaml"/>
                <ResourceDictionary Source="/Resources/Styles/Text.xaml"/>
                <ResourceDictionary Source="/Resources/Styles/Buttons.xaml"/>
                <ResourceDictionary Source="/Resources/Styles/Cards.xaml"/>
                <ResourceDictionary Source="/Resources/Styles/Toggles.xaml"/>
                <ResourceDictionary Source="/Resources/Styles/NavButton.xaml"/>
                <ResourceDictionary Source="/Resources/Styles/Scrollbars.xaml"/>
                <ResourceDictionary Source="/Resources/Styles/WindowChrome.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
            <conv:StringNotEmptyToVisibilityConverter x:Key="StringNotEmptyToVisibility"/>
            <conv:TierToBrushConverter x:Key="TierToBrush"/>
            <conv:TierToBackgroundConverter x:Key="TierToBackground"/>
            <conv:RiskToLabelConverter x:Key="RiskToLabel"/>
            <conv:AntiCheatHasConcernConverter x:Key="AcHasConcern"/>
            <conv:SeverityToBrushConverter x:Key="SeverityToBrush"/>
            <conv:SeverityToBackgroundConverter x:Key="SeverityToBackground"/>
            <conv:ScoreGradeToBrushConverter x:Key="ScoreGradeToBrush"/>
            <conv:TweakCategoryToLabelConverter x:Key="TweakCategoryToLabel"/>
            <conv:LastAppliedToTextConverter x:Key="LastAppliedToText"/>
            <conv:SensorValueOrDashConverter x:Key="SensorOrDash"/>
            <conv:ScorePolylineConverter x:Key="ScorePolyline"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
