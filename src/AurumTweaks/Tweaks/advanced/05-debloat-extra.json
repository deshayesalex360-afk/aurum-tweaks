    "antiCheat": { "vanguard": "Safe", "easyAntiCheat": "Safe", "battlEye": "Safe", "faceit": "Safe" },
    "operations": [
      {
        "type": "Registry", "hive": "HKCU",
        "key": "Software\\Microsoft\\Windows\\CurrentVersion\\Search",
        "name": "BingSearchEnabled", "valueType": "DWord",
        "apply": "0", "revert": "1"
      },
      {
        "type": "Registry", "hive": "HKCU",
        "key": "Software\\Microsoft\\Windows\\CurrentVersion\\Search",
        "name": "CortanaConsent", "valueType": "DWord",
        "apply": "0", "revert": "1"
      },
      {
        "type": "Registry", "hive": "HKLM",
        "key": "SOFTWARE\\Policies\\Microsoft\\Windows\\Windows Search",
        "name": "DisableWebSearch", "valueType": "DWord",
        "apply": "1", "revert": "0"
      }
    ]
  },
  {
