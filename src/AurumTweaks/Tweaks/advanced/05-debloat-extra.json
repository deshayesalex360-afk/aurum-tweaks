[
  {
    "id": "disable-edge-startup-boost",
    "name": { "fr": "Désactiver Edge Startup Boost", "en": "Disable Edge Startup Boost" },
    "description": {
      "fr": "Désactive le pré-lancement d'Edge au démarrage Windows. Libère RAM et accélère boot.",
      "en": "Disables Edge pre-launch at Windows startup. Frees RAM, faster boot."
    },
    "tier": "Avance",
    "category": "Debloat",
    "risk": "None",
    "reversible": true,
    "expectedImpact": "Libère ~150 MB RAM idle + boot plus rapide",
    "sources": [ "ChrisTitus", "Atlas OS" ],
    "antiCheat": { "vanguard": "Safe", "easyAntiCheat": "Safe", "battlEye": "Safe", "faceit": "Safe" },
    "operations": [
      {
        "type": "Registry", "hive": "HKLM",
        "key": "SOFTWARE\\Policies\\Microsoft\\Edge",
        "name": "StartupBoostEnabled", "valueType": "DWord",
        "apply": "0", "revert": "1"
      },
      {
        "type": "Registry", "hive": "HKLM",
        "key": "SOFTWARE\\Policies\\Microsoft\\Edge",
        "name": "BackgroundModeEnabled", "valueType": "DWord",
        "apply": "0", "revert": "1"
      }
    ]
  },
  {
    "id": "disable-search-web-results",
    "name": { "fr": "Désactiver Bing dans la recherche Windows", "en": "Disable Bing in Windows Search" },
    "description": {
      "fr": "Supprime les résultats web Bing du menu Démarrer. Recherche locale plus rapide, plus de privacy.",
      "en": "Removes Bing web results from Start menu search. Faster local search + privacy."
