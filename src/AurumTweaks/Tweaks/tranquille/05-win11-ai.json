[
  {
    "id": "disable-recall",
    "name": { "fr": "Désactiver Windows Recall", "en": "Disable Windows Recall" },
    "description": {
      "fr": "Désactive complètement Windows Recall (capture continue d'écran indexée par IA). Privacy + RAM + disque libérés.",
      "en": "Fully disables Windows Recall (AI-indexed continuous screenshot capture). Privacy + RAM + disk savings."
    },
    "tier": "Tranquille",
    "category": "PrivacyTelemetry",
    "risk": "None",
    "reversible": true,
    "expectedImpact": "Privacy ++ , libère 1-5 GB disque, supprime indexation IA background",
    "sources": [ "Microsoft docs", "Atlas OS", "ShutUp10" ],
    "antiCheat": { "vanguard": "Safe", "easyAntiCheat": "Safe", "battlEye": "Safe", "faceit": "Safe" },
    "windowsVersions": [ "11" ],
    "operations": [
      {
        "type": "Registry", "hive": "HKLM",
        "key": "SOFTWARE\\Policies\\Microsoft\\Windows\\WindowsAI",
        "name": "DisableAIDataAnalysis", "valueType": "DWord",
        "apply": "1", "revert": "0"
      },
      {
        "type": "Registry", "hive": "HKCU",
        "key": "Software\\Policies\\Microsoft\\Windows\\WindowsAI",
        "name": "DisableAIDataAnalysis", "valueType": "DWord",
        "apply": "1", "revert": "0"
      }
    ]
  },
