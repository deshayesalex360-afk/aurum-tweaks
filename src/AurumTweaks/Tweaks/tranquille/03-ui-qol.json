  {
    "id": "hung-app-timeout",
    "name": { "fr": "Accélérer la fermeture des apps figées", "en": "Speed up frozen-app close" },
    "description": {
      "fr": "Réduit les délais HungAppTimeout et WaitToKillAppTimeout pour fermer plus vite les apps qui freezent.",
      "en": "Reduces HungAppTimeout and WaitToKillAppTimeout to close frozen apps faster."
