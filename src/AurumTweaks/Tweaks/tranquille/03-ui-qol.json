[
  {
    "id": "menu-show-delay-zero",
    "name": { "fr": "Supprimer le délai des menus", "en": "Remove menu show delay" },
    "description": {
      "fr": "Réduit MenuShowDelay de 400 ms (défaut) à 0. Interface plus réactive instantanément.",
      "en": "Reduces MenuShowDelay from 400 ms default to 0. Instantly more responsive UI."
    },
    "tier": "Tranquille",
    "category": "UIQualityOfLife",
    "risk": "None",
    "reversible": true,
    "expectedImpact": "Réactivité menus +++ (perçue)",
    "sources": [ "FR33THY", "marvingdt/opti-pc" ],
    "antiCheat": { "vanguard": "Safe", "easyAntiCheat": "Safe", "battlEye": "Safe", "faceit": "Safe" },
    "operations": [
      {
        "type": "Registry",
        "hive": "HKCU",
        "key": "Control Panel\\Desktop",
        "name": "MenuShowDelay",
        "valueType": "String",
        "apply": "0",
        "revert": "400"
      }
    ]
  },
  {
