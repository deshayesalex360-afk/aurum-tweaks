[
  {
    "id": "disable-telemetry-base",
    "name": { "fr": "Désactiver la télémétrie de base", "en": "Disable base telemetry" },
    "description": {
      "fr": "Désactive DiagTrack et la collecte de données diagnostique non-essentielle.",
      "en": "Disables DiagTrack and non-essential diagnostic data collection."
    },
    "tier": "Tranquille",
    "category": "PrivacyTelemetry",
    "risk": "None",
    "reversible": true,
    "expectedImpact": "Libère ~150 MB RAM et un peu de CPU au repos",
    "sources": [ "Atlas OS", "Privatezilla", "O&O ShutUp10", "marvingdt/opti-pc" ],
    "antiCheat": { "vanguard": "Safe", "easyAntiCheat": "Safe", "battlEye": "Safe", "faceit": "Safe" },
    "operations": [
      {
        "type": "Service",
        "serviceName": "DiagTrack",
        "startupApply": "Disabled",
        "startupRevert": "Automatic"
      },
      {
        "type": "Service",
        "serviceName": "dmwappushservice",
        "startupApply": "Disabled",
        "startupRevert": "Manual"
      },
      {
        "type": "Registry",
        "hive": "HKLM",
        "key": "SOFTWARE\\Policies\\Microsoft\\Windows\\DataCollection",
        "name": "AllowTelemetry",
        "valueType": "DWord",
        "apply": "0",
        "revert": "1"
      },
      {
        "type": "Registry",
        "hive": "HKLM",
        "key": "SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Policies\\DataCollection",
        "name": "AllowTelemetry",
        "valueType": "DWord",
        "apply": "0",
        "revert": "1"
      }
    ]
  },
  {
